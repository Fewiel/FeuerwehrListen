@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav

@if (_ready)
{
    @if (_ok)
    {
        @ChildContent
    }
    else
    {
        <div class="container mt-5 text-center">
            <div class="alert alert-warning d-inline-block">
                <i class="bi bi-shield-lock me-1"></i> Kein Zugriff. Bitte anmelden.
            </div>
            <div><a class="btn btn-primary mt-2" href="login">Zum Login</a></div>
        </div>
    }
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool RequireAdmin { get; set; }

    // Kaskadierender Auth-State (aus CascadingAuthenticationState) -> ein geteilter Fetch.
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _ready;
    private bool _ok;

    protected override async Task OnParametersSetAsync()
    {
        if (AuthState is null)
        {
            // Kein kaskadierender State verfuegbar -> pending lassen (kein Flackern zum Login).
            _ready = false;
            return;
        }

        var state = await AuthState;
        var u = state.User;
        var authed = u.Identity?.IsAuthenticated == true;
        _ok = authed && (!RequireAdmin || u.IsInRole("Admin"));
        _ready = true;

        if (!_ok && !authed)
        {
            // Nicht angemeldet -> zum Login, mit Ruecksprungziel (F33).
            var returnUrl = Uri.EscapeDataString(Nav.ToBaseRelativePath(Nav.Uri));
            Nav.NavigateTo($"login?returnUrl={returnUrl}", forceLoad: false);
        }
    }
}
