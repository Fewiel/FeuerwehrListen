@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="sig-field">
    <div class="sig-canvas-wrap">
        <canvas id="@_id" width="640" height="170" class="sig-canvas"></canvas>
        <button type="button" class="btn btn-sm btn-outline-secondary sig-clear" @onclick="Clear" title="Löschen">
            <i class="bi bi-eraser"></i>
        </button>
    </div>
    <small class="text-muted">Hier mit Maus oder Finger unterschreiben.</small>
</div>

@code {
    [Parameter] public string? Initial { get; set; }

    private readonly string _id = "sig-" + Guid.NewGuid().ToString("N");
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            try
            {
                await JS.InvokeVoidAsync("signaturePad.attach", _id);
                if (!string.IsNullOrWhiteSpace(Initial))
                    await JS.InvokeVoidAsync("signaturePad.load", _id, Initial);
            }
            catch { }
        }
    }

    public async Task<string?> GetDataUrlAsync()
    {
        try
        {
            var data = await JS.InvokeAsync<string>("signaturePad.toDataUrl", _id);
            return string.IsNullOrWhiteSpace(data) ? null : data;
        }
        catch { return Initial; }
    }

    private async Task Clear()
    {
        try { await JS.InvokeVoidAsync("signaturePad.clear", _id); } catch { }
    }

    public async ValueTask DisposeAsync()
    {
        // Listener (v.a. window-"mouseup") entfernen -> kein Leak im Server-Circuit.
        try { await JS.InvokeVoidAsync("signaturePad.detach", _id); } catch { }
    }
}
