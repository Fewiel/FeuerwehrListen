@inherits LayoutComponentBase

@* Eigenstaendiges Layout fuer WASM-Seiten (das Server-MainLayout ist im Server-
   Projekt und fuer den Client nicht referenzierbar). Nutzt die global geladenen
   Bootstrap-/App-Styles. *@
<div class="tw-appbar" style="display:flex;align-items:center;gap:12px;">
    <a class="tw-brand" href="/" style="color:#fff;text-decoration:none;font-weight:700;">
        <i class="bi bi-broadcast"></i> Feuerwehr Listen
    </a>
    <span style="font-size:11px;background:rgba(255,255,255,.2);color:#fff;padding:2px 8px;border-radius:999px;">WASM &middot; ohne SignalR</span>
</div>

<main>
    <article class="content px-4">
        @Body
    </article>
</main>
