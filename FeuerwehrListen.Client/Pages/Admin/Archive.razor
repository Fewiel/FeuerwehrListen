@page "/admin/archive"
@layout MainLayout
@using System.Net.Http.Json
@using FeuerwehrListen.Client.Models
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Archiv - Admin</PageTitle>

<AuthGuard>
    <div class="container mt-4">
        <div class="row mb-4"><div class="col"><h1>Archiv</h1><p class="text-muted mb-0">Archivierte Listen. Löschen ist endgültig.</p></div></div>

        @if (_error is not null) { <div class="alert alert-danger">@_error</div> }
        @if (_data is null) { <p><em>Lade…</em></p> }
        else
        {
            @foreach (var cat in Categories())
            {
                <div class="card mb-3">
                    <div class="card-header fw-semibold"><i class="bi @cat.Icon me-2"></i>@cat.Title <span class="badge @cat.Badge ms-2">@cat.Items.Count</span></div>
                    <ul class="list-group list-group-flush">
                        @if (cat.Items.Count == 0) { <li class="list-group-item text-muted">Keine Einträge</li> }
                        else
                        {
                            @foreach (var it in cat.Items)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a href="@it.Href" class="text-decoration-none text-body">
                                        <strong>@it.Title</strong> <small class="text-muted">@it.Sub · @it.ClosedAt?.ToString("dd.MM.yyyy")</small>
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(cat.Type, it.Id)"><i class="bi bi-trash"></i></button>
                                </li>
                            }
                        }
                    </ul>
                </div>
            }
        }
    </div>
</AuthGuard>

@code {
    private ListMgmtDto? _data;
    private string? _error;

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load() { try { _data = await Http.GetFromJsonAsync<ListMgmtDto>("client-api/archived-lists"); } catch { } }

    private record Cat(string Title, string Icon, string Badge, string Type, List<ListMgmtItem> Items);
    private List<Cat> Categories() => _data is null ? new() : new()
    {
        new("Einsatzlisten", "bi-exclamation-triangle text-danger", "bg-danger", "operation", _data.Operations),
        new("Anwesenheitslisten", "bi-calendar-check", "bg-secondary", "attendance", _data.Attendance),
        new("Brandsicherheitswachen", "bi-shield-check text-primary", "bg-primary", "firesafety", _data.Watches),
    };

    private async Task Delete(string type, int id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Diese Liste ENDGÜLTIG löschen? Das kann nicht rückgängig gemacht werden.")) return;
        _error = null;
        try { await Http.DeleteAsync($"client-api/list/{type}/{id}"); await Load(); }
        catch { _error = "Löschen fehlgeschlagen."; }
    }
}
