@page "/admin/closed-lists"
@layout MainLayout
@using System.Net.Http.Json
@using FeuerwehrListen.Client.Models
@inject HttpClient Http

<PageTitle>Abgeschlossene Listen - Admin</PageTitle>

<AuthGuard>
    <div class="container mt-4">
        <div class="row mb-4"><div class="col"><h1>Abgeschlossene Listen</h1><p class="text-muted mb-0">Kategorie aufklappen.</p></div></div>

        @if (_error is not null) { <div class="alert alert-danger">@_error</div> }
        @if (_data is null) { <p><em>Lade…</em></p> }
        else
        {
            @foreach (var cat in Categories())
            {
                <div class="card mb-3">
                    <div class="card-header p-0">
                        <button class="btn w-100 text-start d-flex justify-content-between align-items-center p-3 fw-semibold" @onclick="() => Toggle(cat.Type)">
                            <span><i class="bi @cat.Icon me-2"></i>@cat.Title <span class="badge @cat.Badge ms-2">@cat.Items.Count</span></span>
                            <i class="bi @(IsOpen(cat.Type) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                        </button>
                    </div>
                    @if (IsOpen(cat.Type))
                    {
                        <ul class="list-group list-group-flush">
                            @if (cat.Items.Count == 0) { <li class="list-group-item text-muted">Keine Einträge</li> }
                            else
                            {
                                @foreach (var it in cat.Items)
                                {
                                    <li class="list-group-item">
                                        <a href="@it.Href" class="text-decoration-none d-block text-body">
                                            <div class="d-flex w-100 justify-content-between"><h6 class="mb-1">@it.Title</h6><small>@it.ClosedAt?.ToString("dd.MM.yyyy HH:mm")</small></div>
                                            <p class="mb-1"><strong>@it.Sub</strong></p>
                                        </a>
                                        <button class="btn btn-sm btn-warning mt-2" @onclick="() => Archive(cat.Type, it.Id)"><i class="bi bi-archive"></i> Archivieren</button>
                                    </li>
                                }
                            }
                        </ul>
                    }
                </div>
            }
        }
    </div>
</AuthGuard>

@code {
    private ListMgmtDto? _data;
    private readonly HashSet<string> _open = new();
    private string? _error;

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load() { try { _data = await Http.GetFromJsonAsync<ListMgmtDto>("client-api/closed-lists"); } catch { } }

    private record Cat(string Title, string Icon, string Badge, string Type, List<ListMgmtItem> Items);

    private List<Cat> Categories() => _data is null ? new() : new()
    {
        new("Einsatzlisten", "bi-exclamation-triangle text-danger", "bg-danger", "operation", _data.Operations),
        new("Anwesenheitslisten", "bi-calendar-check", "bg-secondary", "attendance", _data.Attendance),
        new("Brandsicherheitswachen", "bi-shield-check text-primary", "bg-primary", "firesafety", _data.Watches),
    };

    private bool IsOpen(string t) => _open.Contains(t);
    private void Toggle(string t) { if (!_open.Add(t)) _open.Remove(t); }
    private async Task Archive(string type, int id)
    {
        _error = null;
        try { await Http.PostAsync($"client-api/list/{type}/{id}/archive", null); await Load(); }
        catch { _error = "Archivieren fehlgeschlagen."; }
    }
}
