@page "/admin/members"
@layout MainLayout
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Mitglieder - Admin</PageTitle>

<style>
    .tagm-backdrop { position: fixed; inset: 0; background: rgba(15,20,28,.45); z-index: 1050; }
    .tagm { position: fixed; z-index: 1055; top: 50%; left: 50%; transform: translate(-50%,-50%); width: min(460px, calc(100vw - 24px)); max-height: calc(100vh - 40px); display: flex; flex-direction: column; background: var(--tw-surface, #fff); border: 1px solid var(--tw-line, #e3e6ea); border-radius: 16px; box-shadow: 0 24px 60px rgba(15,20,28,.28); overflow: hidden; }
    .tagm-head { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border-bottom: 1px solid var(--tw-line, #e3e6ea); }
    .tagm-head h5 { margin: 0; font-size: 15.5px; font-weight: 600; }
    .tagm-body { padding: 16px 18px; overflow-y: auto; text-align: center; }
    .tagm-preview { display: inline-block; background: #f6f7f9; border: 1px solid var(--tw-line, #e3e6ea); border-radius: 12px; padding: 10px; }
    .tagm-preview svg { width: 190px; height: auto; display: block; }
    .tagm-foot { display: flex; justify-content: flex-end; gap: 8px; padding: 12px 18px; border-top: 1px solid var(--tw-line, #e3e6ea); }
    .tagm-status { display: flex; align-items: center; font-size: 13px; padding: 8px 10px; border-radius: 9px; text-align: left; }
    .tagm-ok { background: #e6f4ea; color: #1e7b34; }
    .tagm-warn { background: #fbeeda; color: #a8690b; }
    .tagm-down { background: #fdecee; color: #c02a3b; }
    .tagm-check { background: #eef1f4; color: #55606c; }
    .tagm-settings { text-align: left; background: #f6f7f9; border: 1px solid var(--tw-line, #e3e6ea); border-radius: 10px; padding: 12px; margin-top: 8px; }
    .tagm-settings input { font-family: ui-monospace, Consolas, monospace; font-size: 12.5px; }
</style>

<AuthGuard>
    <div class="container mt-4">
        <div class="row mb-4">
            <div class="col"><h1>Mitgliederverwaltung</h1></div>
            <div class="col-auto">
                <button class="btn btn-outline-danger me-2" @onclick="ExportPdf"><i class="bi bi-file-earmark-pdf me-1"></i> PDF</button>
                <button class="btn btn-outline-primary me-2" @onclick="() => _showCsv = !_showCsv"><i class="bi bi-upload me-1"></i> CSV Import</button>
                <button class="btn btn-primary" @onclick="ShowAdd"><i class="bi bi-plus-circle"></i> Neues Mitglied</button>
            </div>
        </div>

        @if (_showCsv)
        {
            <div class="card mb-4"><div class="card-body">
                <h5 class="card-title">CSV Import</h5>
                <p class="text-muted small">Format je Zeile (Semikolon): <code>Nummer;Vorname;Nachname;Aktiv(ja/nein);Einheiten(z.B. 1,3)</code>. Erste Zeile = Kopfzeile.</p>
                <textarea class="form-control mb-2" rows="6" @bind="_csv" placeholder="Nummer;Vorname;Nachname;Aktiv;Einheiten&#10;1001;Max;Mustermann;ja;1,3"></textarea>
                <button class="btn btn-primary" @onclick="ImportCsv" disabled="@_importing">@(_importing ? "Importiere…" : "Importieren")</button>
                @if (_csvResult is not null) { <div class="alert alert-info mt-2 mb-0">@_csvResult</div> }
            </div></div>
        }

        @if (_showForm)
        {
            <div class="card mb-4"><div class="card-body">
                <h5 class="card-title">@(_editId is null ? "Neues Mitglied" : "Mitglied bearbeiten")</h5>
                <div class="row">
                    <div class="col-md-4 mb-3"><label class="form-label">Mitgliedsnummer</label><input class="form-control" @bind="_number" /></div>
                    <div class="col-md-4 mb-3"><label class="form-label">Vorname</label><input class="form-control" @bind="_firstName" /></div>
                    <div class="col-md-4 mb-3"><label class="form-label">Nachname</label><input class="form-control" @bind="_lastName" /></div>
                </div>
                <div class="mb-3"><label class="form-label">Einheiten</label><div class="d-flex flex-wrap gap-3">
                    @for (var i = 1; i <= 9; i++) { var u = i;
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="u@(u)" checked="@_units.Contains(u)" @onchange="e => ToggleUnit(u, (bool)e.Value!)" />
                            <label class="form-check-label" for="u@(u)">@u</label>
                        </div>
                    }
                </div></div>
                <div class="mb-3"><div class="form-check"><input class="form-check-input" type="checkbox" id="act" @bind="_isActive" /><label class="form-check-label" for="act">Aktiv</label></div></div>
                @if (_error is not null) { <div class="alert alert-danger py-2">@_error</div> }
                <button class="btn btn-primary me-2" @onclick="Save" disabled="@_saving">Speichern</button>
                <button class="btn btn-secondary" @onclick="() => _showForm = false">Abbrechen</button>
            </div></div>
        }

        <div class="card"><div class="card-body">
            @if (_items is null) { <p><em>Lade…</em></p> }
            else if (_items.Count == 0) { <p class="text-muted">Keine Mitglieder</p> }
            else
            {
                <div class="table-responsive"><table class="table table-hover table-sm">
                    <thead><tr><th>Nummer</th><th>Name</th><th>Einheiten</th><th>Status</th><th>Aktionen</th></tr></thead>
                    <tbody>
                        @foreach (var m in _items)
                        {
                            <tr>
                                <td>@m.MemberNumber</td>
                                <td><strong>@m.LastName</strong>, @m.FirstName</td>
                                <td>@if (m.Units.Count == 0) { <span class="text-muted">–</span> } else { @foreach (var u in m.Units) { <span class="badge bg-primary me-1">@u</span> } }</td>
                                <td>@if (m.IsActive) { <span class="badge bg-success">Aktiv</span> } else { <span class="badge bg-secondary">Inaktiv</span> }</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger me-2" @onclick="() => OpenTag(m)" title="Tag erstellen & herunterladen"><i class="bi bi-tag"></i> Tag</button>
                                    <button class="btn btn-sm btn-primary me-2" @onclick="() => Edit(m)">Bearbeiten</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => Delete(m.Id)">Löschen</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table></div>
            }
        </div></div>
    </div>

    @if (_tagMember is not null)
    {
        <div class="tagm-backdrop" @onclick="CloseTag"></div>
        <div class="tagm" role="dialog" aria-modal="true">
            <div class="tagm-head">
                <h5><i class="bi bi-tag me-1"></i>Tag – @_tagMember.LastName, @_tagMember.FirstName (@_tagMember.MemberNumber)</h5>
                <button type="button" class="btn-close" @onclick="CloseTag"></button>
            </div>
            <div class="tagm-body">
                <div class="tagm-preview">
                    @if (_tagPreview is null && _tagError is null) { <p class="text-muted my-4">Vorschau lädt…</p> }
                    else if (_tagPreview is not null) { @((MarkupString)_tagPreview) }
                </div>
                <p class="text-muted small mt-2 mb-2">Draufsicht – <span style="color:#1657b0;font-weight:600">Body blau</span>, <span style="color:#e4002b;font-weight:600">Inlay rot</span>. Das ZIP enthält <strong>body.stl</strong> + <strong>inlay.stl</strong> für den Zweifarbdruck.</p>

                @* Status des lokalen Renderers *@
                <div class="tagm-status @HelperCssClass">
                    <i class="bi @HelperIcon me-1"></i>@HelperStatusText
                    <button type="button" class="btn btn-link btn-sm p-0 ms-2" @onclick="() => _showSettings = !_showSettings">Einstellungen</button>
                </div>

                @if (_showSettings)
                {
                    <div class="tagm-settings">
                        <label class="form-label small mb-1">Renderer-URL</label>
                        <input class="form-control form-control-sm mb-2" @bind="_helperUrl" placeholder="http://localhost:47800" />
                        <label class="form-label small mb-1">OpenSCAD-Pfad (optional – sonst automatisch)</label>
                        <input class="form-control form-control-sm mb-2" @bind="_openscadPath" placeholder="C:\Program Files\OpenSCAD\openscad.com" />
                        <label class="form-label small mb-1">Eigene SCAD-Datei (optional – sonst mitgeliefert)</label>
                        <input class="form-control form-control-sm mb-2" @bind="_scadPath" placeholder="C:\...\FeuerwehrTag\feuerwehr_tag.scad" />
                        <button type="button" class="btn btn-sm btn-primary" @onclick="SaveSettings">Speichern &amp; testen</button>
                        <div class="mt-2"><a href="/downloads/fwtag-helper.zip" download><i class="bi bi-download me-1"></i>Renderer-Tool (fwtag-helper) herunterladen</a> – auf dem PC entpacken &amp; <code>fwtag-helper.exe</code> starten. Benötigt OpenSCAD.</div>
                    </div>
                }

                @if (_helperStatus == "down")
                {
                    <div class="alert alert-warning py-2 mt-2 mb-0 small">
                        Der lokale Renderer läuft nicht.
                        <a href="/downloads/fwtag-helper.zip" download><i class="bi bi-download"></i> Renderer-Tool herunterladen</a>,
                        entpacken und <code>fwtag-helper.exe</code> starten (Fenster offen lassen) – dann „Speichern &amp; testen".
                        Voraussetzung: OpenSCAD ist auf dem PC installiert.
                    </div>
                }
                @if (_tagError is not null) { <div class="alert alert-danger py-2 mt-2 mb-0 small">@_tagError</div> }
            </div>
            <div class="tagm-foot">
                <button type="button" class="btn btn-secondary" @onclick="CloseTag" disabled="@_tagDownloading">Schließen</button>
                <button type="button" class="btn btn-danger" @onclick="DownloadTag" disabled="@(_tagDownloading || _helperStatus == "down")">
                    @if (_tagDownloading)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <text>Erzeuge STL… (~20&nbsp;s)</text>
                    }
                    else
                    {
                        <i class="bi bi-download me-1"></i>
                        <text>ZIP herunterladen</text>
                    }
                </button>
            </div>
        </div>
    }
</AuthGuard>

@code {
    private List<MemberDto>? _items;
    private bool _showForm, _saving, _showCsv, _importing;
    private int? _editId;
    private string _number = "", _firstName = "", _lastName = "", _csv = "";
    private bool _isActive = true;
    private readonly HashSet<int> _units = new();
    private string? _error, _csvResult;

    protected override async Task OnInitializedAsync() => await Load();
    private async Task Load() { try { _items = await Http.GetFromJsonAsync<List<MemberDto>>("client-api/admin/members"); } catch { _items = new(); } }

    private async Task ExportPdf()
    {
        try
        {
            var path = "/api/export/members/pdf";
            var token = await Http.GetStringAsync($"token?path={Uri.EscapeDataString(path)}");
            await JS.InvokeVoidAsync("openPdf", $"{Nav.BaseUri.TrimEnd('/')}{path}?token={Uri.EscapeDataString(token)}");
        }
        catch { }
    }

    // --- Tag (3D-Druck) - Rendern via lokalem Helfer (fwtag-helper) ---
    private MemberDto? _tagMember;
    private string? _tagPreview;
    private bool _tagDownloading;
    private string? _tagError;
    private string _tagNumber = "", _tagName = "";
    private bool _showSettings;

    // Pro-Client-Einstellungen (localStorage)
    private string _helperUrl = "http://localhost:47800";
    private string _openscadPath = "";
    private string _scadPath = "";
    private string _helperStatus = "checking"; // checking | ok | no-openscad | down

    private string HelperCssClass => _helperStatus switch { "ok" => "tagm-ok", "no-openscad" => "tagm-warn", "down" => "tagm-down", _ => "tagm-check" };
    private string HelperIcon => _helperStatus switch { "ok" => "bi-check-circle-fill", "no-openscad" => "bi-exclamation-triangle-fill", "down" => "bi-x-circle-fill", _ => "bi-hourglass-split" };
    private string HelperStatusText => _helperStatus switch
    {
        "ok" => "Lokaler Renderer verbunden",
        "no-openscad" => "Renderer läuft – OpenSCAD nicht gefunden (Pfad in Einstellungen setzen)",
        "down" => "Lokaler Renderer nicht erreichbar",
        _ => "Prüfe Renderer…"
    };

    private async Task OpenTag(MemberDto m)
    {
        _tagMember = m; _tagPreview = null; _tagError = null; _tagDownloading = false; _showSettings = false;
        _tagNumber = m.MemberNumber; _tagName = "";
        await LoadTagSettings();
        try { _tagPreview = await Http.GetStringAsync($"client-api/admin/members/{m.Id}/tag-preview"); }
        catch { _tagError = "Vorschau konnte nicht geladen werden."; }
        try { var info = await Http.GetFromJsonAsync<TagInfo>($"client-api/admin/members/{m.Id}/tag-info"); if (info is not null) { _tagNumber = info.Number; _tagName = info.Name; } }
        catch { }
        await CheckHelper();
    }

    private void CloseTag() { if (_tagDownloading) return; _tagMember = null; _tagPreview = null; _tagError = null; _showSettings = false; }

    private async Task LoadTagSettings()
    {
        _helperUrl = await Ls("fwtag_helper_url") ?? "http://localhost:47800";
        _openscadPath = await Ls("fwtag_openscad") ?? "";
        _scadPath = await Ls("fwtag_scad") ?? "";
    }

    private async Task SaveSettings()
    {
        if (string.IsNullOrWhiteSpace(_helperUrl)) _helperUrl = "http://localhost:47800";
        await SetLs("fwtag_helper_url", _helperUrl.Trim());
        await SetLs("fwtag_openscad", _openscadPath?.Trim() ?? "");
        await SetLs("fwtag_scad", _scadPath?.Trim() ?? "");
        _showSettings = false;
        await CheckHelper();
    }

    private async Task CheckHelper()
    {
        _helperStatus = "checking"; StateHasChanged();
        try
        {
            var ping = await Http.GetFromJsonAsync<HelperPing>($"{_helperUrl.TrimEnd('/')}/ping");
            _helperStatus = ping is { Ok: true } ? (ping.OpenscadFound || !string.IsNullOrWhiteSpace(_openscadPath) ? "ok" : "no-openscad") : "down";
        }
        catch { _helperStatus = "down"; }
    }

    private async Task DownloadTag()
    {
        if (_tagMember is null) return;
        _tagDownloading = true; _tagError = null;
        try
        {
            var url = $"{_helperUrl.TrimEnd('/')}/tag?number={Uri.EscapeDataString(_tagNumber)}&name={Uri.EscapeDataString(_tagName)}";
            if (!string.IsNullOrWhiteSpace(_openscadPath)) url += $"&openscad={Uri.EscapeDataString(_openscadPath.Trim())}";
            if (!string.IsNullOrWhiteSpace(_scadPath)) url += $"&scad={Uri.EscapeDataString(_scadPath.Trim())}";

            var resp = await Http.GetAsync(url);
            if (!resp.IsSuccessStatusCode)
            {
                var body = await resp.Content.ReadAsStringAsync();
                _tagError = $"Renderer-Fehler: {body}";
                return;
            }
            var bytes = await resp.Content.ReadAsByteArrayAsync();
            using var stream = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("downloadFileFromStream", $"feuerwehr_tag_{_tagNumber}.zip", streamRef);
        }
        catch (Exception ex)
        {
            _tagError = $"Lokaler Renderer nicht erreichbar ({_helperUrl}). Läuft fwtag-helper.exe? [{ex.Message}]";
            _helperStatus = "down";
        }
        finally { _tagDownloading = false; }
    }

    private async Task<string?> Ls(string key) { try { var v = await JS.InvokeAsync<string?>("localStorage.getItem", key); return string.IsNullOrEmpty(v) ? null : v; } catch { return null; } }
    private async Task SetLs(string key, string val) { try { await JS.InvokeVoidAsync("localStorage.setItem", key, val ?? ""); } catch { } }

    private record TagInfo(string Number, string Name);
    private record HelperPing(bool Ok, string? Openscad, bool OpenscadFound, string? Scad);

    private void ShowAdd() { _editId = null; _number = ""; _firstName = ""; _lastName = ""; _isActive = true; _units.Clear(); _error = null; _showForm = true; }
    private void Edit(MemberDto m) { _editId = m.Id; _number = m.MemberNumber; _firstName = m.FirstName; _lastName = m.LastName; _isActive = m.IsActive; _units.Clear(); foreach (var u in m.Units) _units.Add(u); _error = null; _showForm = true; }
    private void ToggleUnit(int u, bool on) { if (on) _units.Add(u); else _units.Remove(u); }

    private async Task Save()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_number) || string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName)) { _error = "Bitte Nummer, Vor- und Nachname ausfüllen."; return; }
        _saving = true;
        try
        {
            var body = new { MemberNumber = _number, FirstName = _firstName, LastName = _lastName, IsActive = _isActive, Units = _units.ToList() };
            if (_editId is int id) await Http.PutAsJsonAsync($"client-api/admin/members/{id}", body);
            else await Http.PostAsJsonAsync("client-api/admin/members", body);
            _showForm = false; await Load();
        }
        finally { _saving = false; }
    }

    private async Task Delete(int id) { await Http.DeleteAsync($"client-api/admin/members/{id}"); await Load(); }

    private async Task ImportCsv()
    {
        _importing = true; _csvResult = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("client-api/admin/members/import-csv", new { Csv = _csv });
            var r = await resp.Content.ReadFromJsonAsync<CsvResult>();
            _csvResult = $"Import: {r?.Imported} importiert, {r?.Skipped} übersprungen" + (r?.Errors?.Count > 0 ? $", {r.Errors.Count} Fehler." : ".");
            _csv = ""; await Load();
        }
        catch { _csvResult = "Import fehlgeschlagen."; }
        finally { _importing = false; }
    }

    private record MemberDto(int Id, string MemberNumber, string FirstName, string LastName, bool IsActive, List<int> Units);
    private record CsvResult(int Imported, int Skipped, List<string> Errors);
}
