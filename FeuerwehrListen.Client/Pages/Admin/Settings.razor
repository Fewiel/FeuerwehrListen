@page "/admin/settings"
@layout MainLayout
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http

<PageTitle>Einstellungen</PageTitle>

<AuthGuard RequireAdmin="true">
    <div class="container mt-4">
        <h1 class="mb-4">Einstellungen</h1>

        @if (_s is null) { <p><em>Lade…</em></p> }
        else
        {
            @if (_saved) { <div class="alert alert-success">Gespeichert.</div> }
            @if (_error is not null) { <div class="alert alert-danger">@_error</div> }

            <div class="card mb-4"><div class="card-header"><i class="bi bi-eye me-2"></i>Modul-Sichtbarkeit</div><div class="card-body">
                @Switch("ModuleVisibility.Attendance", "Anwesenheitslisten")
                @Switch("ModuleVisibility.Operations", "Einsatzlisten")
                @Switch("ModuleVisibility.FireSafetyWatch", "Brandsicherheitswachen")
                @Switch("ModuleVisibility.Defects", "Mängelliste")
            </div></div>

            <div class="card mb-4"><div class="card-header"><i class="bi bi-envelope me-2"></i>E-Mail SMTP</div><div class="card-body">
                @Text("Smtp.Host", "SMTP Host")
                @Num("Smtp.Port", "SMTP Port", min: 1, max: 65535)
                <div class="mb-3"><label class="form-label">Absender-Adresse</label><input type="email" class="form-control" @bind:get='Get("Smtp.FromAddress")' @bind:set='(string v) => Set("Smtp.FromAddress", v)' /></div>
                @Text("Smtp.Username", "Benutzername (optional)")
                @Pass("Smtp.Password", "Passwort (optional)")
                @Switch("Smtp.UseSsl", "SSL/TLS verwenden")
            </div></div>

            <div class="card mb-4"><div class="card-header"><i class="bi bi-cloud-arrow-up me-2"></i>Nextcloud (Einsatzbilder)</div><div class="card-body">
                <p class="text-muted mb-3">
                    Für den automatischen Upload von Einsatzbildern. Lege in Nextcloud unter
                    <em>Einstellungen &rarr; Sicherheit &rarr; „App-Passwort erstellen"</em> ein App-Passwort an
                    (funktioniert auch mit 2FA) und trage Benutzername + App-Passwort hier ein.
                </p>

                <div class="mb-3"><label class="form-label">Server-URL</label><input class="form-control" placeholder="https://cloud.example.de" @bind:get='Get("Nextcloud.Url")' @bind:set='(string v) => Set("Nextcloud.Url", v)' /></div>
                @Text("Nextcloud.Username", "Benutzername")
                @Pass("Nextcloud.AppPassword", "App-Passwort")
                <div class="mb-3">
                    <label class="form-label">Basis-Ordner</label>
                    <input class="form-control" placeholder="/Feuerwehr Billerbeck/Einsatzbilder" @bind:get='Get("Nextcloud.BasePath")' @bind:set='(string v) => Set("Nextcloud.BasePath", v)' />
                    <small class="text-muted">Zielordner je Einsatz: <code>&lt;Basis&gt;/JJJJ/JJ&lt;Einsatznummer&gt;</code> &ndash; z.&nbsp;B. <code>&hellip;/2026/2629999</code></small>
                </div>

                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <button type="button" class="btn btn-outline-primary" @onclick="TestNextcloud" disabled="@_ncTesting">
                        @if (_ncTesting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-plug me-1"></i>Verbindung testen
                    </button>
                    @if (!string.IsNullOrEmpty(_ncTestMessage))
                    {
                        <span class="@(_ncTestOk ? "text-success" : "text-danger")">
                            <i class="bi @(_ncTestOk ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") me-1"></i>@_ncTestMessage
                        </span>
                    }
                </div>
                <small class="text-muted d-block mt-2">Zum Testen zuerst speichern oder direkt die eingegebenen Werte prüfen.</small>
            </div></div>

            <div class="card mb-4"><div class="card-header"><i class="bi bi-tag me-2"></i>Einheiten-Aliase</div><div class="card-body">
                @for (var i = 1; i <= 9; i++) { var n = i; @Text($"Unit.Alias.{n}", $"Einheit {n} – Alias") }
            </div></div>

            <div class="card mb-4"><div class="card-header"><i class="bi bi-send-check me-2"></i>Empfänger</div><div class="card-body">
                @for (var i = 1; i <= 9; i++) { var n = i; @Text($"Notifications.AttendanceRecipients.Unit.{n}", $"Anwesenheit Einheit {n}") }
                <hr />
                @Text("Notifications.OperationRecipients", "Einsatzlisten")
                @Text("Notifications.FireSafetyWatchRecipients", "Brandsicherheitswachen")
                @Text("Notifications.DefectRecipients", "Mängelliste")
                @Text("Notifications.FeedbackRecipients", "Einsatz-Feedback")
                @Text("Notifications.QrReorderRecipients", "QR-Nachbestellung")
                <small class="text-muted d-block mb-2">Wenn ein Mitglied „QR-Code nachbestellen" drückt, wird eine E-Mail an die QR-Nachbestellungs-Adresse gesendet.</small>
                @Switch("Notifications.SkipEmptyLists", "Leere Listen nicht versenden")
            </div></div>

            <div class="card mb-4"><div class="card-header"><i class="bi bi-clock-history me-2"></i>Automatisches Schließen (Minuten, 0 = aus)</div><div class="card-body">
                @Num("AutoClose.AttendanceMinutes", "Anwesenheitslisten", min: 0)
                @Num("AutoClose.OperationMinutes", "Einsatzlisten", min: 0)
                @Num("AutoClose.FireSafetyWatchMinutes", "Brandsicherheitswachen", min: 0)
            </div></div>

            <div class="card mb-4"><div class="card-header"><i class="bi bi-palette me-2"></i>Branding &amp; Sound</div><div class="card-body">
                @Text("Branding.AppName", "App-Name")

                <div class="mb-3">
                    <label class="form-label">Logo hochladen</label>
                    <InputFile class="form-control" OnChange="OnLogoFileSelected" accept=".png,.jpg,.jpeg,.svg" disabled="@_logoBusy" />
                    <small class="text-muted">PNG, JPG oder SVG. Wird als App-Icon und Logo verwendet.</small>
                    @if (_logoBusy) { <div class="mt-2"><span class="spinner-border spinner-border-sm me-1"></span>Wird hochgeladen…</div> }
                    @if (!string.IsNullOrWhiteSpace(Get("Branding.LogoUrl")))
                    {
                        <div class="mt-2 d-flex align-items-center gap-3">
                            <img src="@Get("Branding.LogoUrl")" alt="Logo" style="max-height: 64px; max-width: 200px; border-radius: 6px; background: #EDF0F3; border: 1px solid #D6DBE1; padding: 4px;" />
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="RemoveLogo" disabled="@_logoBusy">
                                <i class="bi bi-trash"></i> Entfernen
                            </button>
                        </div>
                    }
                    @if (_logoError is not null) { <div class="text-danger mt-2"><i class="bi bi-exclamation-triangle-fill me-1"></i>@_logoError</div> }
                </div>

                <div class="mb-3">
                    <label class="form-label">Icon hochladen (PWA)</label>
                    <InputFile class="form-control" OnChange="OnIconFileSelected" accept=".png" disabled="@_iconBusy" />
                    <small class="text-muted">PNG, empfohlen 512&times;512px für die PWA-Installation.</small>
                    @if (_iconBusy) { <div class="mt-2"><span class="spinner-border spinner-border-sm me-1"></span>Wird hochgeladen…</div> }
                    @if (_iconUploaded) { <div class="mt-2"><span class="badge bg-success"><i class="bi bi-check"></i> Icon hochgeladen</span></div> }
                    @if (_iconError is not null) { <div class="text-danger mt-2"><i class="bi bi-exclamation-triangle-fill me-1"></i>@_iconError</div> }
                </div>

                <hr />
                @Switch("Sound.Enabled", "Sound-Feedback bei QR-Scan")
            </div></div>

            <div class="mb-5">
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">@(_saving ? "Speichern…" : "Speichern")</button>
                <a class="btn btn-secondary ms-2" href="/">Zurück</a>
            </div>
        }
    </div>
</AuthGuard>

@code {
    private Dictionary<string, string>? _s;
    private bool _saving, _saved;
    private string? _error;

    // Nextcloud-Test
    private bool _ncTesting;
    private bool _ncTestOk;
    private string _ncTestMessage = string.Empty;

    // Logo-/Icon-Upload
    private bool _logoBusy;
    private string? _logoError;
    private bool _iconBusy;
    private bool _iconUploaded;
    private string? _iconError;

    protected override async Task OnInitializedAsync()
    {
        try { _s = await Http.GetFromJsonAsync<Dictionary<string, string>>("client-api/admin/settings") ?? new(); }
        catch { _s = new(); }
        // Standardordner vorbelegen, wenn das Basis-Ordner-Feld leer ist (wie Original).
        if (string.IsNullOrWhiteSpace(Get("Nextcloud.BasePath")))
            Set("Nextcloud.BasePath", "/Feuerwehr Billerbeck/Einsatzbilder");
        _saved = false; _error = null;
    }

    private string Get(string k) => _s != null && _s.TryGetValue(k, out var v) ? v : "";
    private void Set(string k, string v) { if (_s != null) _s[k] = v ?? ""; _saved = false; _error = null; }
    private bool GetBool(string k, bool def = false) { var v = Get(k); return string.IsNullOrEmpty(v) ? def : v.Equals("true", StringComparison.OrdinalIgnoreCase); }
    // Default-Wert (an = true), wenn der Schluessel noch nicht gesetzt ist. In eigener Methode,
    // damit im @bind:get-Attribut keine verschachtelten Anfuehrungszeichen stehen (bricht Razor).
    private bool GetBoolDef(string k) => GetBool(k, k.StartsWith("ModuleVisibility") || k == "Sound.Enabled" || k == "Notifications.SkipEmptyLists" || k == "Smtp.UseSsl");
    private void SetBool(string k, bool v) => Set(k, v ? "true" : "false");
    // Numerische Felder als String behandeln, damit ein nie gesetzter Wert leer bleibt
    // und beim Speichern NICHT als explizite "0" landet (z. B. Smtp.Port).
    private string GetNumStr(string k) => Get(k);
    private void SetNumStr(string k, string v)
    {
        v = v?.Trim() ?? "";
        // Nur Ziffern zulassen; leerer Wert = "nicht konfiguriert" (leer durchreichen).
        Set(k, string.IsNullOrEmpty(v) ? "" : (int.TryParse(v, out var n) ? n.ToString() : v));
    }

    private RenderFragment Text(string key, string label) =>@<div class="mb-3"><label class="form-label">@label</label><input class="form-control" @bind:get="Get(key)" @bind:set="v => Set(key, v)" /></div>;
    private RenderFragment Pass(string key, string label) =>@<div class="mb-3"><label class="form-label">@label</label><input type="password" class="form-control" @bind:get="Get(key)" @bind:set="v => Set(key, v)" /></div>;
    private RenderFragment Num(string key, string label, int? min = null, int? max = null) =>@<div class="mb-3"><label class="form-label">@label</label><input type="number" class="form-control" style="max-width:200px" min="@min" max="@max" @bind:get="GetNumStr(key)" @bind:set="v => SetNumStr(key, v)" /></div>;
    private RenderFragment Switch(string key, string label) =>@<div class="form-check form-switch mb-2"><input class="form-check-input" type="checkbox" @bind:get="GetBoolDef(key)" @bind:set="v => SetBool(key, v)" /><label class="form-check-label">@label</label></div>;

    private async Task TestNextcloud()
    {
        _ncTesting = true;
        _ncTestMessage = string.Empty;
        try
        {
            // Aktuell im Formular stehende Werte als JSON senden.
            var body = new { url = Get("Nextcloud.Url").Trim(), user = Get("Nextcloud.Username").Trim(), pass = Get("Nextcloud.AppPassword") };
            var resp = await Http.PostAsJsonAsync("client-api/admin/nextcloud/test", body);
            if (!resp.IsSuccessStatusCode)
            {
                _ncTestOk = false;
                _ncTestMessage = "Test fehlgeschlagen.";
            }
            else
            {
                var result = await resp.Content.ReadFromJsonAsync<NcTestResult>();
                _ncTestOk = result?.ok ?? false;
                _ncTestMessage = result?.message ?? (_ncTestOk ? "Verbindung erfolgreich." : "Verbindung fehlgeschlagen.");
            }
        }
        catch
        {
            _ncTestOk = false;
            _ncTestMessage = "Test fehlgeschlagen.";
        }
        finally
        {
            _ncTesting = false;
        }
    }

    private async Task OnLogoFileSelected(InputFileChangeEventArgs e)
    {
        _logoError = null;
        var file = e.File;
        if (file == null) return;
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (ext is not ".png" and not ".jpg" and not ".jpeg" and not ".svg")
        {
            _logoError = "Ungültiger Dateityp (erlaubt: png, jpg, jpeg, svg).";
            return;
        }
        _logoBusy = true;
        try
        {
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(5 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            if (!string.IsNullOrEmpty(file.ContentType))
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            var resp = await Http.PostAsync("client-api/admin/branding/logo", content);
            if (!resp.IsSuccessStatusCode)
            {
                _logoError = "Logo-Upload fehlgeschlagen.";
                return;
            }
            var result = await resp.Content.ReadFromJsonAsync<LogoResult>();
            if (!string.IsNullOrWhiteSpace(result?.logoUrl))
                Set("Branding.LogoUrl", result.logoUrl);
        }
        catch
        {
            _logoError = "Logo-Upload fehlgeschlagen.";
        }
        finally
        {
            _logoBusy = false;
        }
    }

    private async Task RemoveLogo()
    {
        _logoError = null;
        _logoBusy = true;
        try
        {
            var resp = await Http.PostAsync("client-api/admin/branding/logo/remove", null);
            if (!resp.IsSuccessStatusCode)
            {
                _logoError = "Logo konnte nicht entfernt werden.";
                return;
            }
            Set("Branding.LogoUrl", "");
        }
        catch
        {
            _logoError = "Logo konnte nicht entfernt werden.";
        }
        finally
        {
            _logoBusy = false;
        }
    }

    private async Task OnIconFileSelected(InputFileChangeEventArgs e)
    {
        _iconError = null;
        _iconUploaded = false;
        var file = e.File;
        if (file == null) return;
        if (!file.Name.EndsWith(".png", StringComparison.OrdinalIgnoreCase))
        {
            _iconError = "Nur PNG erlaubt.";
            return;
        }
        _iconBusy = true;
        try
        {
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(5 * 1024 * 1024);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new MediaTypeHeaderValue("image/png");
            content.Add(fileContent, "file", file.Name);

            var resp = await Http.PostAsync("client-api/admin/branding/icon", content);
            if (!resp.IsSuccessStatusCode)
            {
                _iconError = "Icon-Upload fehlgeschlagen.";
                return;
            }
            _iconUploaded = true;
        }
        catch
        {
            _iconError = "Icon-Upload fehlgeschlagen.";
        }
        finally
        {
            _iconBusy = false;
        }
    }

    private async Task Save()
    {
        if (_s is null) return;
        _error = null; _saved = false;
        // SMTP-Port beim Speichern auf gueltigen Bereich clampen (nur wenn gesetzt).
        var port = Get("Smtp.Port");
        if (!string.IsNullOrEmpty(port) && int.TryParse(port, out var p))
            Set("Smtp.Port", Math.Clamp(p, 1, 65535).ToString());
        _saving = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("client-api/admin/settings", _s);
            if (!resp.IsSuccessStatusCode) { _error = "Speichern fehlgeschlagen."; return; }
            _saved = true;
        }
        catch { _error = "Speichern fehlgeschlagen."; }
        finally { _saving = false; }
    }

    private sealed record NcTestResult(bool ok, string? message);
    private sealed record LogoResult(string? logoUrl);
}
