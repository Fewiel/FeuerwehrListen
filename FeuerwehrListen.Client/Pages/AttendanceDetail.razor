@page "/attendance/{Id:int}"
@layout MainLayout
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Anwesenheitsliste@(_list is null ? "" : " - " + _list.Title)</PageTitle>

@if (_list is null)
{
    <div class="container mt-4">
        @if (_loadError is not null)
        {
            <div class="alert alert-danger">@_loadError</div>
            <button class="btn btn-secondary" @onclick="Load"><i class="bi bi-arrow-clockwise me-1"></i>Erneut versuchen</button>
        }
        else
        {
            <p><em>Lade…</em></p>
        }
    </div>
}
else
{
    <div class="container mt-4">
        @if (_loadError is not null) { <div class="alert alert-warning py-2"><i class="bi bi-exclamation-triangle me-1"></i>@_loadError</div> }
        <div class="mb-4">
            <h1>@_list.Title</h1>
            <p class="lead">@_list.Unit</p>
            @if (_list.UnitNumber.HasValue) { <p><strong>Einheit:</strong> @_list.UnitNumber@(_list.UnitAlias is null ? "" : " – " + _list.UnitAlias)</p> }
            <p>@_list.Description</p>
            <small class="text-muted">Erstellt: @_list.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
            @if (!_list.IsOpen) { <div class="mt-3"><span class="badge bg-secondary fs-5">Abgeschlossen</span></div> }
        </div>

        @* Eintragen: offene Liste für alle; abgeschlossene nur für Angemeldete (Nachtragen) *@
        @if (_list.IsOpen)
        {
            @EntryUi
        }
        else
        {
            <AuthorizeView>
                <div class="alert alert-info mt-2"><i class="bi bi-pencil-square me-1"></i>Diese Liste ist abgeschlossen. Als angemeldeter Benutzer kannst du noch <strong>nachtragen</strong>.</div>
                @EntryUi
            </AuthorizeView>
        }

        @if (_confirmationVisible) { <div class="entry-confirmation-overlay"><i class="bi bi-check-circle-fill"></i><div class="entry-confirmation-name">@_confirmationName</div><small class="text-muted">eingetragen</small></div> }
        @if (!string.IsNullOrWhiteSpace(_info)) { <div class="alert alert-info mt-2">@_info</div> }
        @if (!string.IsNullOrWhiteSpace(_error)) { <div class="alert alert-danger mt-2">@_error</div> }

        @if (_chooseMembers is not null)
        {
            <div class="card mb-3"><div class="card-header">Mehrere Treffer – bitte wählen</div><div class="list-group list-group-flush">
                @foreach (var m in _chooseMembers) { <button class="list-group-item list-group-item-action" @onclick="() => AddByMember(m.Id)">@m.Name (@m.Number)</button> }
            </div></div>
        }
        @if (_chooseLists is not null)
        {
            <div class="card mb-3"><div class="card-header">@_chooseName gehört zu einer anderen Einheit – Zielliste wählen</div><div class="list-group list-group-flush">
                @foreach (var l in _chooseLists) { <button class="list-group-item list-group-item-action" @onclick="() => AddToList(l.Id)">@l.Title</button> }
            </div></div>
        }

        <div class="card">
            <div class="card-header"><h5 class="mb-0">Anwesend (@Present.Count)</h5></div>
            <div class="card-body">
                @if (Present.Count == 0) { <p class="text-muted">Noch keine Einträge</p> }
                else { @EntryTable(Present) }
            </div>
        </div>

        @if (Excused.Count > 0)
        {
            <div class="card mt-3"><div class="card-header"><h5 class="mb-0">Entschuldigt (@Excused.Count)</h5></div><div class="card-body">@EntryTable(Excused)</div></div>
        }

        <AuthorizeView Context="auth">
            <div class="d-grid gap-2 mt-4" style="max-width:500px;">
                @if (_list.IsOpen)
                {
                    <AuthorizeView Roles="Admin" Context="adm"><button class="btn btn-outline-warning btn-lg" @onclick="() => _showExcuse = !_showExcuse"><i class="bi bi-person-exclamation me-2"></i>Als Entschuldigt eintragen</button></AuthorizeView>
                    @if (_showExcuse)
                    {
                        <div class="input-group"><input class="form-control" placeholder="Mitgliedsnummer/Name" @bind="_excuseInput" @onkeyup="@(async e => { if (e.Key == "Enter") await Excuse(); })" /><button class="btn btn-warning" @onclick="Excuse" disabled="@_busy">Eintragen</button></div>
                    }
                    <button class="btn btn-warning btn-lg" @onclick="Close" disabled="@_busy"><i class="bi bi-lock me-2"></i>Liste abschließen</button>
                }
                <button class="btn btn-primary btn-lg" @onclick="ExportPdf"><i class="bi bi-file-earmark-pdf me-2"></i>PDF Export</button>
            </div>
        </AuthorizeView>

        <div class="mt-3 mb-4"><a class="btn btn-secondary" href="/">Zurück zur Übersicht</a></div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private ListDto? _list;
    private string? _loadError;
    private bool _busy;
    private int _confirmSeq;
    private bool _showManual;
    private string _manualInput = string.Empty;
    private string _error = "", _info = "";
    private bool _confirmationVisible; private string _confirmationName = "";
    private List<MemberChoice>? _chooseMembers; private List<ListChoice>? _chooseLists; private string _chooseName = "";
    private int? _pendingMemberId;
    private bool _showExcuse; private string _excuseInput = "";

    private List<EntryDto> Present => _list?.Entries.Where(e => !e.IsExcused).ToList() ?? new();
    private List<EntryDto> Excused => _list?.Entries.Where(e => e.IsExcused).ToList() ?? new();

    protected override async Task OnParametersSetAsync() => await Load();
    private async Task Load()
    {
        var hadData = _list is not null;
        try
        {
            _list = await Http.GetFromJsonAsync<ListDto>($"client-api/attendance/{Id}");
            _loadError = null;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            // 404: Liste gibt es nicht (mehr) -> klare Meldung, alte Daten verwerfen.
            _list = null;
            _loadError = "Diese Anwesenheitsliste wurde nicht gefunden.";
        }
        catch
        {
            // Netzfehler: bei bereits geladener Liste die funktionierende Anzeige behalten
            // und nur einen Hinweis zeigen; sonst (Erstladung) Fehlerzustand.
            _loadError = "Aktualisierung fehlgeschlagen – Netzwerkproblem.";
            if (!hadData) _list = null;
        }
    }

    private RenderFragment EntryUi =>@<div>
        <QrScanner IsActive="true" OnCodeScanned="HandleCode" OnManualEntryRequested="() => _showManual = !_showManual" />
        @if (_showManual)
        {
            <div class="input-group mb-3">
                <input class="form-control" placeholder="Mitgliedsnummer oder Name" @bind="_manualInput" @bind:event="oninput" @onkeyup="@(async e => { if (e.Key == "Enter") await HandleCode(_manualInput); })" />
                <button class="btn btn-success" @onclick="() => HandleCode(_manualInput)" disabled="@_busy">Eintragen</button>
            </div>
        }
    </div>;

    private RenderFragment EntryTable(List<EntryDto> list) =>@<div class="table-responsive"><table class="table table-hover">
        <thead><tr><th>#</th><th>Name/ID</th><th>Eingetragen um</th><AuthorizeView><th>Aktion</th></AuthorizeView></tr></thead>
        <tbody>
            @{ var i = 1; }
            @foreach (var e in list)
            {
                <tr><td>@(i++)</td><td><strong>@e.Name</strong></td><td>@e.EnteredAt.ToString("HH:mm:ss")</td>
                    <AuthorizeView Context="a"><td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEntry(e.Id)">🗑️ Entfernen</button></td></AuthorizeView>
                </tr>
            }
        </tbody>
    </table></div>;

    private async Task HandleCode(string code) { if (string.IsNullOrWhiteSpace(code)) return; await Post(new { Code = code.Trim() }); _manualInput = ""; }
    private async Task AddByMember(int memberId) => await Post(new { MemberId = memberId });
    private async Task AddToList(int listId) => await Post(new { MemberId = _pendingMemberId, TargetListId = listId });

    private async Task Post(object body)
    {
        if (_busy) return;
        _busy = true;
        _error = ""; _info = ""; _chooseMembers = null; _chooseLists = null;
        try
        {
            var resp = await Http.PostAsJsonAsync($"client-api/attendance/{Id}/add", body);
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized) { _error = "Sitzung abgelaufen – bitte neu anmelden."; return; }
            if (!resp.IsSuccessStatusCode) { _error = "Eintragen fehlgeschlagen."; return; }
            var r = await resp.Content.ReadFromJsonAsync<AddResult>();
            switch (r?.Status)
            {
                case "added": await Confirm(r.Name); await Load(); break;
                case "redirected": await Confirm(r.Name); _info = "Eintrag wurde in eine andere Liste übertragen."; await Load(); break;
                case "duplicate": _error = $"{r.Name} ist bereits eingetragen!"; await Sound("error"); break;
                case "notfound": _error = "Mitglied nicht gefunden!"; await Sound("error"); break;
                case "choose-member": _chooseMembers = r.Members; break;
                case "choose-list": _chooseLists = r.Lists; _chooseName = r.Name ?? ""; _pendingMemberId = r.MemberId; break;
                case "nomatch": _error = $"Keine offene Anwesenheitsliste für {r.Units} gefunden."; break;
            }
        }
        catch { _error = "Eintragen fehlgeschlagen. Bitte erneut versuchen."; }
        finally { _busy = false; }
    }

    private async Task Excuse()
    {
        if (string.IsNullOrWhiteSpace(_excuseInput)) return;
        if (_busy) return;
        _busy = true;
        _error = "";
        try
        {
            var resp = await Http.PostAsJsonAsync($"client-api/attendance/{Id}/excuse", new { Code = _excuseInput.Trim() });
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized) { _error = "Sitzung abgelaufen – bitte neu anmelden."; return; }
            var r = await resp.Content.ReadFromJsonAsync<AddResult>();
            if (r?.Status == "added") { await Confirm(r.Name); _excuseInput = ""; _showExcuse = false; await Load(); }
            else if (r?.Status == "duplicate") _error = $"{r.Name} ist bereits eingetragen!";
            else _error = "Mitglied nicht gefunden!";
        }
        catch { _error = "Eintragen fehlgeschlagen."; }
        finally { _busy = false; }
    }

    private async Task DeleteEntry(int entryId)
    {
        try
        {
            var resp = await Http.DeleteAsync($"client-api/attendance/{Id}/entry/{entryId}");
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized) { _error = "Sitzung abgelaufen – bitte neu anmelden."; return; }
            if (!resp.IsSuccessStatusCode) { _error = "Löschen fehlgeschlagen."; return; }
            await Load();
        }
        catch { _error = "Löschen fehlgeschlagen."; }
    }

    private async Task Close()
    {
        try
        {
            var resp = await Http.PostAsync($"client-api/attendance/{Id}/close", null);
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized) { _error = "Sitzung abgelaufen – bitte neu anmelden."; return; }
            if (!resp.IsSuccessStatusCode) { _error = "Abschließen fehlgeschlagen."; return; }
            await Load();
        }
        catch { _error = "Abschließen fehlgeschlagen."; }
    }

    private async Task ExportPdf()
    {
        // Inline-Endpoint direkt in der Klick-Geste oeffnen (kein vorheriges await -> iOS-WASM
        // behaelt die User-Geste, Cookie-Auth statt Token).
        try
        {
            await JS.InvokeVoidAsync("openPdf", $"{Nav.BaseUri}client-api/export/attendance/{Id}/pdf");
        }
        catch { _error = "PDF konnte nicht geöffnet werden."; }
    }

    private async Task Confirm(string? name)
    {
        await Sound("success");
        _confirmationName = name ?? "";
        _confirmationVisible = true;
        var seq = ++_confirmSeq;
        StateHasChanged();
        _ = Task.Run(async () => { await Task.Delay(2000); await InvokeAsync(() => { if (_confirmSeq == seq) { _confirmationVisible = false; StateHasChanged(); } }); });
    }
    private async Task Sound(string type) { try { await JS.InvokeVoidAsync("playSound", type); } catch { } }

    private record ListDto(int Id, string Title, string Unit, int? UnitNumber, string? UnitAlias, string? Description, DateTime CreatedAt, bool IsOpen, List<EntryDto> Entries);
    private record EntryDto(int Id, string Name, DateTime EnteredAt, bool IsExcused);
    private record MemberChoice(int Id, string Name, string Number);
    private record ListChoice(int Id, string Title);
    private record AddResult(string Status, string? Name, int? MemberId, string? Units, List<MemberChoice>? Members, List<ListChoice>? Lists);
}
