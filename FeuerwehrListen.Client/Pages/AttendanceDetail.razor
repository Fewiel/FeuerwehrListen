@page "/attendance/{Id:int}"
@layout MainLayout
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthProvider

<PageTitle>Anwesenheitsliste@(_list is null ? "" : " - " + _list.Title)</PageTitle>

@if (_list is null)
{
    <div class="container mt-4">
        @if (_loadError is not null)
        {
            <div class="alert alert-danger">@_loadError</div>
            <button class="btn btn-secondary" @onclick="Load"><i class="bi bi-arrow-clockwise me-1"></i>Erneut versuchen</button>
        }
        else
        {
            <p><em>Lade…</em></p>
        }
    </div>
}
else
{
    <div class="container mt-4">
        @if (_loadError is not null) { <div class="alert alert-warning py-2"><i class="bi bi-exclamation-triangle me-1"></i>@_loadError</div> }
        <div class="mb-4">
            <h1>@_list.Title</h1>
            <p class="lead">@_list.Unit</p>
            @if (_list.UnitNumber.HasValue) { <p><strong>Einheit:</strong> @_list.UnitNumber@(_list.UnitAlias is null ? "" : " – " + _list.UnitAlias)</p> }
            <p>@_list.Description</p>
            <small class="text-muted">Erstellt: @_list.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
            @if (!_list.IsOpen) { <div class="mt-3"><span class="badge bg-secondary fs-5">Abgeschlossen</span></div> }
        </div>

        @* Eintragen: offene Liste für alle; abgeschlossene nur für Angemeldete (Nachtragen) *@
        @if (_list.IsOpen)
        {
            @EntryUi
        }
        else
        {
            <AuthorizeView>
                <div class="alert alert-info mt-2"><i class="bi bi-pencil-square me-1"></i>Diese Liste ist abgeschlossen. Als angemeldeter Benutzer kannst du noch <strong>nachtragen</strong>.</div>
                @EntryUi
            </AuthorizeView>
        }

        @if (_confirmationVisible) { <div class="entry-confirmation-overlay"><i class="bi bi-check-circle-fill"></i><div class="entry-confirmation-name">@_confirmationName</div><small class="text-muted">eingetragen</small></div> }
        @if (!string.IsNullOrWhiteSpace(_info)) { <div class="alert alert-info mt-2">@_info</div> }
        @if (!string.IsNullOrWhiteSpace(_error)) { <div class="alert alert-danger mt-2">@_error</div> }

        @if (_showPinLogin)
        {
            <div class="card mb-3" style="max-width:360px;">
                <div class="card-header"><i class="bi bi-shield-lock me-1"></i>Admin-PIN eingeben</div>
                <div class="card-body">
                    <div class="input-group">
                        <input class="form-control" type="password" inputmode="numeric" placeholder="PIN" @bind="_pin" @bind:event="oninput" @onkeyup="@(async e => { if (e.Key == "Enter") await SubmitPinLogin(); })" />
                        <button class="btn btn-primary" @onclick="SubmitPinLogin" disabled="@_busy">Anmelden</button>
                        <button class="btn btn-secondary" @onclick="@(() => { _showPinLogin = false; _pin = string.Empty; })">Abbrechen</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_pinError)) { <div class="text-danger mt-2">@_pinError</div> }
                </div>
            </div>
        }

        <QuickActionsModal @ref="_quickActions"
                           ShowCloseList="@_list.IsOpen"
                           ShowAddExcused="@_list.IsOpen"
                           CloseLabel="Liste abschließen"
                           OnActionSelected="HandleQuickAction" />

        @if (_chooseMembers is not null)
        {
            <div class="card mb-3"><div class="card-header">Mehrere Treffer – bitte wählen</div><div class="list-group list-group-flush">
                @foreach (var m in _chooseMembers) { <button class="list-group-item list-group-item-action" @onclick="() => AddByMember(m.Id)">@m.Name (@m.Number)</button> }
            </div></div>
        }
        @if (_chooseLists is not null)
        {
            <div class="card mb-3"><div class="card-header">@_chooseName gehört zu einer anderen Einheit – Zielliste wählen</div><div class="list-group list-group-flush">
                @foreach (var l in _chooseLists) { <button class="list-group-item list-group-item-action" @onclick="() => AddToList(l.Id)">@l.Title</button> }
            </div></div>
        }

        <div class="card">
            <div class="card-header"><h5 class="mb-0">Anwesend (@Present.Count)</h5></div>
            <div class="card-body">
                @if (Present.Count == 0) { <p class="text-muted">Noch keine Einträge</p> }
                else { @EntryTable(Present) }
            </div>
        </div>

        @if (Excused.Count > 0)
        {
            <div class="card mt-3"><div class="card-header"><h5 class="mb-0">Entschuldigt (@Excused.Count)</h5></div><div class="card-body">@EntryTable(Excused)</div></div>
        }

        @* PDF-Export bewusst ohne Login (Kiosk-Wunsch). *@
        <div class="d-grid gap-2 mt-4" style="max-width:500px;">
            <button class="btn btn-primary btn-lg" @onclick="ExportPdf"><i class="bi bi-file-earmark-pdf me-2"></i>PDF Export</button>
        </div>

        <AuthorizeView Context="auth">
            <div class="d-grid gap-2 mt-3" style="max-width:500px;">
                @* Entschuldigen fuer jeden Angemeldeten - auch in GESCHLOSSENEN Listen (nachtraeglich). *@
                <button class="btn btn-outline-warning btn-lg" @onclick="ToggleExcuseUi"><i class="bi bi-person-exclamation me-2"></i>Als Entschuldigt eintragen</button>
                @if (_list.IsOpen)
                {
                    <button class="btn btn-warning btn-lg" @onclick="Close" disabled="@_busy"><i class="bi bi-lock me-2"></i>Liste abschließen</button>
                }
            </div>
            @if (_showExcuse)
            {
                <div class="card mt-3" style="max-width:640px;">
                    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <span><i class="bi bi-person-exclamation me-1"></i>Entschuldigt eintragen</span>
                        <input class="form-control form-control-sm" style="max-width:220px" placeholder="Suchen…" value="@_excuseFilter" @oninput="e => _excuseFilter = e.Value?.ToString() ?? string.Empty" />
                    </div>
                    <div class="card-body" style="max-height:60vh;overflow:auto;">
                        @if (_excuseCandidates is null) { <p class="text-muted mb-0"><em>Lade…</em></p> }
                        else if (FilteredExcuse.Count == 0) { <p class="text-muted mb-0">Keine Treffer.</p> }
                        else
                        {
                            @foreach (var m in FilteredExcuse)
                            {
                                <div class="form-check form-switch py-1">
                                    <input class="form-check-input" type="checkbox" role="switch" id="exc_@m.Id" checked="@m.IsExcused" disabled="@(m.IsPresent || _excuseBusy.Contains(m.Id))" @onchange="e => ToggleExcuse(m, (bool)(e.Value ?? false))" />
                                    <label class="form-check-label" for="exc_@m.Id">@m.Name <span class="text-muted">(@m.Number)</span>@if (m.IsPresent) { <span class="badge bg-success ms-2">anwesend</span> }</label>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </AuthorizeView>

        <div class="mt-3 mb-4"><a class="btn btn-secondary" href="/">Zurück zur Übersicht</a></div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private ListDto? _list;
    private string? _loadError;
    private bool _busy;
    private int _confirmSeq;
    private bool _showManual;
    private string _manualInput = string.Empty;
    private string _error = "", _info = "";
    private bool _confirmationVisible; private string _confirmationName = "";
    private List<MemberChoice>? _chooseMembers; private List<ListChoice>? _chooseLists; private string _chooseName = "";
    private int? _pendingMemberId;
    private bool _showExcuse;
    private QuickActionsModal? _quickActions;
    private List<MemberChoice>? _suggestions;
    private CancellationTokenSource? _searchCts;
    private List<ExcuseCand>? _excuseCandidates;
    private string _excuseFilter = "";
    private readonly HashSet<int> _excuseBusy = new();
    private bool _showPinLogin; private string _pin = ""; private string _pinError = ""; private string _pinLoginCode = "";

    private List<EntryDto> Present => _list?.Entries.Where(e => !e.IsExcused).ToList() ?? new();
    private List<EntryDto> Excused => _list?.Entries.Where(e => e.IsExcused).ToList() ?? new();

    protected override async Task OnParametersSetAsync() => await Load();
    private async Task Load()
    {
        var hadData = _list is not null;
        try
        {
            _list = await Http.GetFromJsonAsync<ListDto>($"client-api/attendance/{Id}");
            _loadError = null;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            // 404: Liste gibt es nicht (mehr) -> klare Meldung, alte Daten verwerfen.
            _list = null;
            _loadError = "Diese Anwesenheitsliste wurde nicht gefunden.";
        }
        catch
        {
            // Netzfehler: bei bereits geladener Liste die funktionierende Anzeige behalten
            // und nur einen Hinweis zeigen; sonst (Erstladung) Fehlerzustand.
            _loadError = "Aktualisierung fehlgeschlagen – Netzwerkproblem.";
            if (!hadData) _list = null;
        }
    }

    private RenderFragment EntryUi =>@<div>
        <QrScanner IsActive="true" OnCodeScanned="HandleScan" OnManualEntryRequested="() => _showManual = !_showManual" />
        @if (_showManual)
        {
            <div class="mb-3 position-relative" style="max-width:640px;">
                <div class="input-group">
                    <input class="form-control" placeholder="Mitgliedsnummer oder Name" value="@_manualInput" @oninput="OnManualInput" @onkeyup="@(async e => { if (e.Key == "Enter") await HandleCode(_manualInput); })" />
                    <button class="btn btn-success" @onclick="() => HandleCode(_manualInput)" disabled="@_busy">Eintragen</button>
                </div>
                @if (_suggestions is { Count: > 0 })
                {
                    <div class="list-group position-absolute w-100 shadow" style="z-index:1030;">
                        @foreach (var s in _suggestions)
                        {
                            <button type="button" class="list-group-item list-group-item-action" @onclick="() => PickSuggestion(s)">@s.Name <span class="text-muted">(@s.Number)</span></button>
                        }
                    </div>
                }
            </div>
        }
    </div>;

    private RenderFragment EntryTable(List<EntryDto> list) =>@<div class="table-responsive"><table class="table table-hover">
        <thead><tr><th>#</th><th>Name/ID</th><th>Eingetragen um</th><AuthorizeView><th>Aktion</th></AuthorizeView></tr></thead>
        <tbody>
            @{ var i = 1; }
            @foreach (var e in list)
            {
                <tr><td>@(i++)</td><td><strong>@e.Name</strong></td><td>@e.EnteredAt.ToString("HH:mm:ss")</td>
                    <AuthorizeView Context="a"><td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEntry(e.Id)">🗑️ Entfernen</button></td></AuthorizeView>
                </tr>
            }
        </tbody>
    </table></div>;

    // Gescannten Code zuerst als BENUTZER-Ausweis pruefen. Angemeldet -> Schnellaktionen;
    // NICHT angemeldet -> direkt per QR anmelden (statt auf die Login-Seite zu verweisen).
    // Kein User-Code -> normaler Mitglieds-Lookup.
    private async Task HandleScan(string code)
    {
        if (string.IsNullOrWhiteSpace(code)) return;
        var trimmed = code.Trim();
        try
        {
            var id = await Http.GetFromJsonAsync<QrIdentifyResult>($"client-api/auth/qr-identify?code={Uri.EscapeDataString(trimmed)}");
            if (id?.IsUser == true)
            {
                var authState = await AuthProvider.GetAuthenticationStateAsync();
                if (authState.User.Identity?.IsAuthenticated == true) _quickActions?.Show(id.Username ?? "");
                else await StartQrLogin(trimmed);
                return;
            }
        }
        catch { /* qr-identify fehlgeschlagen -> als Mitglieds-Code behandeln */ }
        await HandleCode(code);
    }

    private async Task StartQrLogin(string code)
    {
        _error = ""; _pinError = "";
        try
        {
            var resp = await Http.PostAsJsonAsync("client-api/auth/qr", new { Code = code });
            var r = await resp.Content.ReadFromJsonAsync<QrLoginDto>();
            switch (r?.Status)
            {
                case "ok": CompleteLogin(r.Ticket); break;
                case "pin": _pinLoginCode = code; _pin = ""; _pinError = ""; _showPinLogin = true; break;
                case "badpin": _error = "Falsche PIN."; break;
                default: _error = "Ungültiger QR-Code."; break;
            }
        }
        catch { _error = "Anmeldung fehlgeschlagen."; }
    }

    private async Task SubmitPinLogin()
    {
        if (_busy) return;
        if (string.IsNullOrWhiteSpace(_pin)) { _pinError = "Bitte PIN eingeben."; return; }
        _busy = true;
        try
        {
            var resp = await Http.PostAsJsonAsync("client-api/auth/qr", new { Code = _pinLoginCode, Pin = _pin });
            var r = await resp.Content.ReadFromJsonAsync<QrLoginDto>();
            if (r?.Status == "ok") CompleteLogin(r.Ticket);
            else if (r?.Status == "badpin") _pinError = "Falsche PIN.";
            else _pinError = "Anmeldung fehlgeschlagen.";
        }
        catch { _pinError = "Anmeldung fehlgeschlagen."; }
        finally { _busy = false; }
    }

    private void CompleteLogin(string? ticket)
    {
        if (string.IsNullOrWhiteSpace(ticket)) { _error = "Anmeldung fehlgeschlagen (kein Ticket)."; return; }
        var ret = Uri.EscapeDataString($"/attendance/{Id}");
        // Echte Browser-Navigation: Cookie wird gesetzt, danach zurueck zu dieser Liste (returnUrl).
        Nav.NavigateTo($"client-api/auth/complete?ticket={Uri.EscapeDataString(ticket)}&returnUrl={ret}", forceLoad: true);
    }

    private async Task HandleQuickAction(QuickActionsModal.QuickAction action)
    {
        switch (action)
        {
            case QuickActionsModal.QuickAction.CloseList:
                await Close();
                break;
            case QuickActionsModal.QuickAction.AddExcused:
                _showExcuse = true;
                break;
        }
    }

    private async Task HandleCode(string code) { if (string.IsNullOrWhiteSpace(code)) return; _suggestions = null; await Post(new { Code = code.Trim() }); _manualInput = ""; }

    // #1 Live-Suche bei manueller Eingabe: waehrend des Tippens passende Mitglieder vorschlagen.
    private async Task OnManualInput(ChangeEventArgs e)
    {
        _manualInput = e.Value?.ToString() ?? "";
        var term = _manualInput.Trim();
        _searchCts?.Cancel();
        if (term.Length < 2) { _suggestions = null; return; }
        var cts = new CancellationTokenSource();
        _searchCts = cts;
        try
        {
            var res = await Http.GetFromJsonAsync<List<MemberChoice>>($"client-api/members/search?q={Uri.EscapeDataString(term)}", cts.Token);
            if (!cts.IsCancellationRequested) _suggestions = res;
        }
        catch { /* Abbruch/Netzfehler ignorieren */ }
    }

    private async Task PickSuggestion(MemberChoice s)
    {
        _suggestions = null; _manualInput = "";
        await AddByMember(s.Id);
    }
    private async Task AddByMember(int memberId) => await Post(new { MemberId = memberId });
    private async Task AddToList(int listId) => await Post(new { MemberId = _pendingMemberId, TargetListId = listId });

    private async Task Post(object body)
    {
        if (_busy) return;
        _busy = true;
        _error = ""; _info = ""; _chooseMembers = null; _chooseLists = null;
        try
        {
            var resp = await Http.PostAsJsonAsync($"client-api/attendance/{Id}/add", body);
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized) { _error = "Sitzung abgelaufen – bitte neu anmelden."; return; }
            if (!resp.IsSuccessStatusCode) { _error = "Eintragen fehlgeschlagen."; return; }
            var r = await resp.Content.ReadFromJsonAsync<AddResult>();
            switch (r?.Status)
            {
                case "added": await Confirm(r.Name); await Load(); break;
                case "redirected": await Confirm(r.Name); _info = "Eintrag wurde in eine andere Liste übertragen."; await Load(); break;
                case "duplicate": _error = $"{r.Name} ist bereits eingetragen!"; await Sound("error"); break;
                case "notfound": _error = "Mitglied nicht gefunden!"; await Sound("error"); break;
                case "choose-member": _chooseMembers = r.Members; break;
                case "choose-list": _chooseLists = r.Lists; _chooseName = r.Name ?? ""; _pendingMemberId = r.MemberId; break;
                case "nomatch": _error = $"Keine offene Anwesenheitsliste für {r.Units} gefunden."; break;
            }
        }
        catch { _error = "Eintragen fehlgeschlagen. Bitte erneut versuchen."; }
        finally { _busy = false; }
    }

    // #4 Entschuldigt als Switch-Liste (alle aktiven Mitglieder, nach Nachname a-z).
    private async Task ToggleExcuseUi()
    {
        _showExcuse = !_showExcuse;
        if (_showExcuse && _excuseCandidates is null) await LoadExcuseCandidates();
    }

    private async Task LoadExcuseCandidates()
    {
        try { _excuseCandidates = await Http.GetFromJsonAsync<List<ExcuseCand>>($"client-api/attendance/{Id}/excuse-candidates"); }
        catch { _error = "Mitgliederliste konnte nicht geladen werden."; }
    }

    private List<ExcuseCand> FilteredExcuse => _excuseCandidates is null ? new()
        : string.IsNullOrWhiteSpace(_excuseFilter) ? _excuseCandidates
        : _excuseCandidates.Where(m => m.Name.Contains(_excuseFilter, StringComparison.OrdinalIgnoreCase)
                                    || m.Number.Contains(_excuseFilter, StringComparison.OrdinalIgnoreCase)).ToList();

    private async Task ToggleExcuse(ExcuseCand m, bool value)
    {
        if (m.IsPresent || _excuseBusy.Contains(m.Id)) return;
        _excuseBusy.Add(m.Id);
        _error = "";
        try
        {
            var resp = await Http.PostAsJsonAsync($"client-api/attendance/{Id}/excuse-toggle", new { MemberId = m.Id, Excused = value });
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized) { _error = "Sitzung abgelaufen – bitte neu anmelden."; return; }
            if (!resp.IsSuccessStatusCode) { _error = "Änderung fehlgeschlagen."; return; }
            var r = await resp.Content.ReadFromJsonAsync<ToggleResult>();
            m.IsExcused = r?.Excused ?? value;
            if (r?.Status == "present") m.IsPresent = true;
            await Load(); // Anwesend-/Entschuldigt-Karten aktualisieren
        }
        catch { _error = "Änderung fehlgeschlagen."; }
        finally { _excuseBusy.Remove(m.Id); }
    }

    private async Task DeleteEntry(int entryId)
    {
        try
        {
            var resp = await Http.DeleteAsync($"client-api/attendance/{Id}/entry/{entryId}");
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized) { _error = "Sitzung abgelaufen – bitte neu anmelden."; return; }
            if (!resp.IsSuccessStatusCode) { _error = "Löschen fehlgeschlagen."; return; }
            await Load();
        }
        catch { _error = "Löschen fehlgeschlagen."; }
    }

    private async Task Close()
    {
        try
        {
            var resp = await Http.PostAsync($"client-api/attendance/{Id}/close", null);
            if (resp.StatusCode == System.Net.HttpStatusCode.Unauthorized) { _error = "Sitzung abgelaufen – bitte neu anmelden."; return; }
            if (!resp.IsSuccessStatusCode) { _error = "Abschließen fehlgeschlagen."; return; }
            await Load();
        }
        catch { _error = "Abschließen fehlgeschlagen."; }
    }

    private async Task ExportPdf()
    {
        // Inline-Endpoint direkt in der Klick-Geste oeffnen (kein vorheriges await -> iOS-WASM
        // behaelt die User-Geste, Cookie-Auth statt Token).
        try
        {
            await JS.InvokeVoidAsync("openPdf", $"{Nav.BaseUri}client-api/export/attendance/{Id}/pdf");
        }
        catch { _error = "PDF konnte nicht geöffnet werden."; }
    }

    private async Task Confirm(string? name)
    {
        await Sound("success");
        _confirmationName = name ?? "";
        _confirmationVisible = true;
        var seq = ++_confirmSeq;
        StateHasChanged();
        _ = Task.Run(async () => { await Task.Delay(2000); await InvokeAsync(() => { if (_confirmSeq == seq) { _confirmationVisible = false; StateHasChanged(); } }); });
    }
    private async Task Sound(string type) { try { await JS.InvokeVoidAsync("playSound", type); } catch { } }

    private record ListDto(int Id, string Title, string Unit, int? UnitNumber, string? UnitAlias, string? Description, DateTime CreatedAt, bool IsOpen, List<EntryDto> Entries);
    private record EntryDto(int Id, string Name, DateTime EnteredAt, bool IsExcused);
    private record MemberChoice(int Id, string Name, string Number);
    private record ListChoice(int Id, string Title);
    private record AddResult(string Status, string? Name, int? MemberId, string? Units, List<MemberChoice>? Members, List<ListChoice>? Lists);
    private record QrIdentifyResult(bool IsUser, string? Username, string? Role);
    private record QrLoginDto(string Status, string? Ticket);
    private record ToggleResult(string Status, bool Excused);
    private class ExcuseCand { public int Id { get; set; } public string Name { get; set; } = ""; public string Number { get; set; } = ""; public bool IsExcused { get; set; } public bool IsPresent { get; set; } }
}
