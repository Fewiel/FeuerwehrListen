@page "/camera-settings"
@layout MainLayout
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Kamera-Einstellungen</PageTitle>

<div class="container">
    <div class="content">
        <h1><i class="bi bi-camera-video me-2"></i>Kamera-Einstellungen</h1>
        <p class="text-muted">Wähle die Kamera für den QR-Code-Scanner. Standard ist die <strong>Frontkamera</strong>. Die Auswahl wird auf diesem Gerät gespeichert und bleibt auch nach Updates erhalten.</p>

        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><h5>Kamera auswählen</h5></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Kamera</label>
                            <select class="form-select" value="@_facing" @onchange="OnCameraChanged">
                                <option value="user">Frontkamera (Standard)</option>
                                <option value="environment">Rückkamera</option>
                            </select>
                        </div>
                        <button class="btn btn-primary" @onclick="SaveSettings"><i class="bi bi-check-lg me-2"></i>Speichern</button>
                        @if (_saved) { <span class="badge bg-success ms-2">Gespeichert!</span> }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><h5>Vorschau</h5></div>
                    <div class="card-body p-0">
                        <video id="@_previewVideoId" style="width: 100%; display: block; border-radius: 0 0 4px 4px;" autoplay muted playsinline></video>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _facing = "user";
    private string _previewVideoId = $"camera-preview-{Guid.NewGuid():N}";
    private bool _saved;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _facing = await JS.InvokeAsync<string?>("qrScanner.loadFacing") ?? "user";
                StateHasChanged();
                await Task.Delay(100);
                await StartPreview();
            }
            catch { }
        }
    }

    private async Task OnCameraChanged(ChangeEventArgs e)
    {
        _facing = e.Value?.ToString() == "environment" ? "environment" : "user";
        _saved = false;
        await StartPreview();
    }

    private async Task StartPreview()
    {
        try
        {
            await JS.InvokeVoidAsync("qrScanner.stopPreview", _previewVideoId);
            await JS.InvokeVoidAsync("qrScanner.startPreview", _previewVideoId, _facing);
        }
        catch { }
    }

    private async Task SaveSettings()
    {
        await JS.InvokeVoidAsync("qrScanner.saveFacing", _facing);
        _saved = true;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("qrScanner.stopPreview", _previewVideoId); } catch { }
    }
}
