@page "/live"
@rendermode InteractiveWebAssembly
@layout ClientLayout
@using FeuerwehrListen.Client.Models
@inject HttpClient Http
@implements IDisposable

<PageTitle>Live-Übersicht</PageTitle>

<style>
    .lv-note { font-size: 12.5px; color: #5B646F; margin: 14px 0 16px; }
    .lv-h { font-size: 15px; margin: 22px 0 10px; font-weight: 600; }
    .lv-grid { display: grid; gap: 12px; grid-template-columns: 1fr; }
    @@media (min-width: 620px) { .lv-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (min-width: 940px) { .lv-grid { grid-template-columns: repeat(3, 1fr); } }
    .lv-card { background: #fff; border: 1px solid #E4E8ED; border-radius: 12px; padding: 14px; text-decoration: none; color: inherit; display: block; }
    .lv-card.op { border-left: 3px solid #E4002B; }
    .lv-card .t { font-weight: 600; font-size: 14.5px; overflow-wrap: anywhere; }
    .lv-card .s { font-size: 12.5px; color: #5B646F; margin-top: 2px; overflow-wrap: anywhere; }
    .lv-card .m { font-size: 12px; color: #5B646F; margin-top: 8px; font-variant-numeric: tabular-nums; }
    .lv-empty { color: #5B646F; font-size: 13px; padding: 8px 2px; }
    .lv-status { font-size: 12.5px; color: #5B646F; display: inline-flex; align-items: center; gap: 6px; }
    .lv-dot { width: 9px; height: 9px; border-radius: 50%; background: #1E7B34; display: inline-block; }
    .lv-dot.err { background: #C77700; }
</style>

<div class="container mt-3">
    <div class="d-flex align-items-center justify-content-between flex-wrap">
        <h1 style="margin:0;font-size:24px;">Live-Übersicht</h1>
        <span class="lv-status"><span class="lv-dot @(_error ? "err" : "")"></span>@_statusText</span>
    </div>

    <p class="lv-note">
        Diese Seite läuft als <b>Blazor WebAssembly</b> im Browser und holt ihre Daten ausschließlich
        über den Endpoint <code>/client-api/open-lists</code> &ndash; <b>keine SignalR-Dauerverbindung</b>.
        Aktualisierung alle 15&nbsp;Sekunden.
    </p>

    @if (_data is null && !_error)
    {
        <p class="lv-empty">Lade&hellip;</p>
    }
    else
    {
        <div class="lv-h"><i class="bi bi-truck" style="color:#E4002B"></i> Einsätze laufend (@(_data?.Operations.Count ?? 0))</div>
        @RenderList(_data?.Operations, "op")

        <div class="lv-h"><i class="bi bi-clipboard-check"></i> Anwesenheitslisten offen (@(_data?.Attendance.Count ?? 0))</div>
        @RenderList(_data?.Attendance, null)

        <div class="lv-h"><i class="bi bi-shield-check"></i> Wachen geplant (@(_data?.Watches.Count ?? 0))</div>
        @RenderList(_data?.Watches, null)
    }
</div>

@code {
    private OpenListsResponse? _data;
    private bool _error;
    private string _statusText = "verbinde…";
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _timer = new System.Threading.Timer(async _ => await InvokeAsync(LoadAsync), null,
            TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
    }

    private async Task LoadAsync()
    {
        try
        {
            _data = await Http.GetFromJsonAsync<OpenListsResponse>("client-api/open-lists");
            _error = false;
            _statusText = "aktualisiert " + (_data?.ServerTime.ToString("dd.MM. HH:mm") ?? "");
        }
        catch
        {
            _error = true;
            _statusText = "offline – neuer Versuch…";
        }
        StateHasChanged();
    }

    private RenderFragment RenderList(List<ListItem>? items, string? cls) => builder =>
    {
        if (items is null || items.Count == 0)
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "lv-empty");
            builder.AddContent(2, "Keine offenen Einträge.");
            builder.CloseElement();
            return;
        }
        builder.OpenElement(3, "div");
        builder.AddAttribute(4, "class", "lv-grid");
        var seq = 5;
        foreach (var i in items)
        {
            builder.OpenElement(seq++, "a");
            builder.AddAttribute(seq++, "class", "lv-card " + (cls ?? ""));
            builder.AddAttribute(seq++, "href", i.Href);
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "t");
            builder.AddContent(seq++, i.Title);
            builder.CloseElement();
            if (!string.IsNullOrWhiteSpace(i.Sub))
            {
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "s");
                builder.AddContent(seq++, i.Sub);
                builder.CloseElement();
            }
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "m");
            builder.AddContent(seq++, i.Time.ToString("dd.MM. HH:mm") + " Uhr");
            builder.CloseElement();
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    public void Dispose() => _timer?.Dispose();
}
