@page "/logout"
@layout MainLayout
@inject NavigationManager Nav

<PageTitle>Abmelden</PageTitle>
<div class="container mt-5 text-center"><p>Du wirst abgemeldet…</p></div>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        // Echte Browser-Navigation (GET): der Server loescht via /client-api/auth/logout-redirect
        // das Cookie und redirectet auf /. So greift das Cookie-Loeschen in beiden Render-Modi.
        Nav.NavigateTo("client-api/auth/logout-redirect", forceLoad: true);
    }
}
