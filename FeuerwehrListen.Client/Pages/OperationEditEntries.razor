@page "/operation/{Id:int}/edit-entries"
@layout MainLayout
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Einträge bearbeiten</PageTitle>

<AuthGuard>
    <div class="container mt-4">
        @if (_data is null) { <p><em>Lade…</em></p> }
        else
        {
            <div class="mb-4"><h1>Einträge bearbeiten</h1><p class="lead">Einsatz @_data.Number — @_data.Keyword</p></div>
            @if (_msg is not null) { <div class="alert alert-info">@_msg</div> }
            <div class="card"><div class="card-header"><h5 class="mb-0">Einträge (@_data.Entries.Count)</h5></div><div class="card-body">
                @if (_data.Entries.Count == 0) { <p class="text-muted">Keine Einträge</p> }
                else
                {
                    <div class="table-responsive"><table class="table table-hover">
                        <thead><tr><th>#</th><th>Name/ID</th><th>Fahrzeug</th><th>Funktionen</th><th>AGT</th><th>Aktion</th></tr></thead>
                        <tbody>
                            @{ var i = 1; }
                            @foreach (var e in _data.Entries)
                            {
                                <tr>
                                    <td>@(i++)</td><td><strong>@e.Name</strong></td><td>@e.Vehicle</td>
                                    <td>@string.Join(", ", e.Functions)</td>
                                    <td>@if (e.Breathing) { <span class="badge bg-warning">Ja</span> } else { <span class="badge bg-secondary">Nein</span> }</td>
                                    <td><button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(e.Id)"><i class="bi bi-trash"></i> Löschen</button></td>
                                </tr>
                            }
                        </tbody>
                    </table></div>
                }
            </div></div>
            <div class="mt-3"><a class="btn btn-secondary" href="/operation/@Id"><i class="bi bi-arrow-left me-2"></i>Zurück zur Liste</a></div>
        }
    </div>
</AuthGuard>

@code {
    [Parameter] public int Id { get; set; }
    private OpDto? _data;
    private string? _msg;

    protected override async Task OnParametersSetAsync() => await Load();
    private async Task Load() { try { _data = await Http.GetFromJsonAsync<OpDto>($"client-api/operation/{Id}"); } catch { _data = null; } }

    private async Task Delete(int entryId)
    {
        try { await Http.DeleteAsync($"client-api/operation/{Id}/entry/{entryId}"); _msg = "Eintrag gelöscht."; await Load(); }
        catch { _msg = "Fehler beim Löschen."; }
    }

    private record OpDto(int Id, string Number, string Keyword, string? Address, bool IsOpen, List<EntryDto> Entries);
    private record EntryDto(int Id, string Name, string? Vehicle, bool Breathing, List<string> Functions);
}
