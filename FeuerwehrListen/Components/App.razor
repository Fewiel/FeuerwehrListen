<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="theme-color" content="#0d1117"/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <link rel="manifest" href="manifest.json"/>
    <link rel="apple-touch-icon" href="favicon.png"/>
    <base href="/"/>
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>
    <link rel="stylesheet" href="app.css"/>
    <link rel="stylesheet" href="FeuerwehrListen.styles.css"/>
    <HeadOutlet/>
</head>

<body>
    <Routes />
    <script src="https://fastly.jsdelivr.net/npm/barcode-detector@@3/dist/iife/polyfill.min.js"></script>
    <script src="qr-scanner.js"></script>
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        // Sound feedback helper
        window.playSound = function(type) {
            try {
                var audio = new Audio('/sounds/' + type + '.wav');
                audio.volume = 0.5;
                audio.play().catch(function() {});
            } catch(e) {}
        };

        // Custom Blazor start with reconnect handling
        (function() {
            var maxRetries = 30;
            var delays = [500, 1000, 2000, 5000, 10000];
            var currentProcess = null;

            function showBanner(text, cls) {
                var b = document.getElementById('reconnect-banner');
                if (b) { b.className = 'reconnect-banner ' + cls; b.innerHTML = text; }
            }

            function startReconnect() {
                var isCanceled = false;
                showBanner('<i class="bi bi-wifi-off"></i> Verbindung unterbrochen — Reconnect...', 'reconnect-down');

                (async function() {
                    for (var i = 0; i < maxRetries; i++) {
                        await new Promise(function(r) { setTimeout(r, delays[Math.min(i, delays.length - 1)]); });
                        if (isCanceled) return;
                        try {
                            var result = await Blazor.reconnect();
                            if (!result) { location.reload(); return; }
                            return;
                        } catch(e) { /* server not reached, retry */ }
                    }
                    showBanner('<i class="bi bi-wifi-off"></i> Verbindung verloren — <a href="" style="color:#fff;text-decoration:underline">Seite neu laden</a>', 'reconnect-down');
                })();

                return { cancel: function() { isCanceled = true; } };
            }

            Blazor.start({
                circuit: {
                    reconnectionHandler: {
                        onConnectionDown: function() {
                            currentProcess = currentProcess || startReconnect();
                        },
                        onConnectionUp: function() {
                            if (currentProcess) { currentProcess.cancel(); currentProcess = null; }
                            showBanner('<i class="bi bi-wifi"></i> Wieder verbunden', 'reconnect-up');
                            setTimeout(function() { showBanner('', 'reconnect-hidden'); }, 3000);
                        }
                    }
                }
            });
        })();

        // PWA Service Worker registration
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js', { updateViaCache: 'none' })
                .then(function(reg) {
                    reg.update();
                    console.log('SW registered, scope:', reg.scope);
                })
                .catch(function(e) { console.error('SW registration failed:', e); });
        }

        // PWA install prompt capture
        window.addEventListener('beforeinstallprompt', function(e) {
            console.log('PWA: beforeinstallprompt fired');
            window._pwaInstallPrompt = e;
        });
    </script>
</body>

</html>
