<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="theme-color" content="#E4002B"/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <link rel="manifest" href="manifest.json"/>
    <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png"/>
    <base href="/"/>
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css"/>
    <link rel="stylesheet" href="lib/bootstrap-icons/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="app.css"/>
    @* Statisch: sonst wuerde der HeadOutlet auf reinen WASM-Seiten einen
       Circuit oeffnen. Seitentitel werden beim (Pre-)Rendern gesetzt. *@
    <HeadOutlet />

    @* Alt-Geraet-Erkennung (ES5, laeuft auch auf iOS 12): Die .NET-8-WASM-Runtime
       braucht u.a. BigInt (Safari 14+/iOS 14). Fehlt es, kann die WASM-App nicht booten.
       Dann Cookie fw_srv=1 setzen und einmal neu laden -> der Server rendert die App im
       Server-Modus (InteractiveServer/SignalR), der auch auf iOS 12 laeuft (blazor.web.js
       ist ES5-kompatibel). So bekommen alte Geraete die VOLLE App, nicht nur eine
       abgespeckte Seite. Sicherheitsnetz zusaetzlich zur server-seitigen UA-Erkennung. *@
    <script>
        (function () {
            var ok = (typeof WebAssembly !== "undefined") && (typeof Promise !== "undefined") && (typeof BigInt === "function");
            var hasSrv = document.cookie.indexOf("fw_srv=1") !== -1;

            if (ok) {
                // Umkehr-Fall: Geraet kann jetzt WASM (z.B. iPad von iOS 13 auf 15 aktualisiert),
                // aber fw_srv=1 steckt noch -> Cookie loeschen, damit wieder WASM genutzt wird.
                // KEIN reload noetig: Der Server rendert diesen Request evtl. noch im Server-Modus,
                // ab dem naechsten normalen Seitenaufruf greift dann wieder WASM.
                if (hasSrv) {
                    document.cookie = "fw_srv=;path=/;max-age=0";
                }
                return;
            }

            // Altgeraet ohne WASM: Server-Modus erzwingen. Gegen Endlos-Reload absichern,
            // falls Cookies blockiert sind (das Cookie waere nach reload wieder weg).
            if (!hasSrv) {
                var TRIED = "fw_srv_try";
                var already = false;
                try { already = sessionStorage.getItem(TRIED) === "1"; } catch (e) { }

                document.cookie = "fw_srv=1;path=/;max-age=31536000";

                // Prueft, ob das Cookie tatsaechlich gesetzt werden konnte.
                var cookieStuck = document.cookie.indexOf("fw_srv=1") !== -1;

                if (cookieStuck && !already) {
                    try { sessionStorage.setItem(TRIED, "1"); } catch (e) { }
                    location.reload();
                } else if (!cookieStuck) {
                    // Cookies blockiert -> statt Endlosschleife eine klare Meldung anzeigen.
                    document.addEventListener("DOMContentLoaded", function () {
                        try {
                            var d = document.createElement("div");
                            d.style.cssText = "font-family:-apple-system,Helvetica,Arial,sans-serif;max-width:34em;margin:12vh auto;padding:24px;color:#171B21;line-height:1.5;text-align:center";
                            d.innerHTML = "<h2 style='color:#B3001F;margin:0 0 12px'>Cookies erforderlich</h2>"
                                + "<p>Dieses Geraet ist zu alt fuer die schnelle App-Variante. Fuer die volle Funktion muessen Cookies aktiviert sein.</p>"
                                + "<p>Bitte aktivieren Sie in den Safari-Einstellungen &bdquo;Cookies zulassen&ldquo; und laden Sie die Seite neu.</p>";
                            document.body.appendChild(d);
                        } catch (e) { }
                    });
                }
                // already === true: nicht erneut reloaden (Endlosschutz).
            }
        })();
    </script>
</head>

<body>
    @* Render-Modus pro Geraet: moderne Geraete WebAssembly (client-seitig, kein SignalR);
       alte Geraete (kein WASM moeglich) InteractiveServer (SignalR) -> volle App auf iOS 12. *@
    <FeuerwehrListen.Client.Routes @rendermode="Mode" />

    <script src="lib/barcode-detector/polyfill.min.js"></script>
    <script>
        // WASM des Barcode-Polyfills lokal laden (statt CDN) – für Altgeräte / falls das CDN ausfällt.
        // Projektregel: ALLES lokal, kein CDN. Fehlt der Override-Hook, laut failen (console.error)
        // statt still - sonst faellt der Polyfill unbemerkt auf die einkompilierte jsdelivr-URL zurueck.
        try {
            if (window.BarcodeDetectionAPI && window.BarcodeDetectionAPI.setZXingModuleOverrides) {
                window.BarcodeDetectionAPI.setZXingModuleOverrides({
                    locateFile: function (path, prefix) {
                        return (path && path.endsWith('.wasm')) ? '/lib/barcode-detector/' + path : (prefix || '') + path;
                    }
                });
            } else {
                console.error('BarcodeDetector: setZXingModuleOverrides fehlt - WASM koennte vom CDN geladen werden (verletzt "alles lokal"). Polyfill-Version pruefen.');
            }
        } catch (e) { console.error('BarcodeDetector WASM override failed', e); }
    </script>
    <script src="qr-scanner.js?v=3"></script>
    <script src="signature.js?v=2"></script>
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        // Sound-Feedback
        window.playSound = function (type) {
            try {
                var audio = new Audio('/sounds/' + type + '.wav');
                audio.volume = 0.5;
                audio.play().catch(function () { });
            } catch (e) { }
        };

        // PDF/Datei robust oeffnen - window.open('_blank') wird auf altem iOS-Safari
        // aus async-Handlern vom Popup-Blocker geblockt. Ein Anker-Klick (gleiche Seite)
        // navigiert bzw. laedt herunter und wird NICHT geblockt.
        window.openPdf = function (url) {
            try {
                var a = document.createElement('a');
                a.href = url;
                a.rel = 'noopener';
                document.body.appendChild(a);
                a.click();
                setTimeout(function () { try { document.body.removeChild(a); } catch (e) { } }, 100);
            } catch (e) {
                try { window.location.href = url; } catch (e2) { }
            }
        };

        // Datei aus einem .NET-Stream herunterladen (fuer Tag-ZIP etc.)
        window.downloadFileFromStream = async function (fileName, contentStreamRef) {
            try {
                var arrayBuffer = await contentStreamRef.arrayBuffer();
                var blob = new Blob([arrayBuffer]);
                var url = URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url; a.download = fileName || 'download';
                document.body.appendChild(a); a.click();
                setTimeout(function () { try { document.body.removeChild(a); } catch (e) { } URL.revokeObjectURL(url); }, 150);
            } catch (e) { console.error('downloadFileFromStream failed', e); }
        };

        // Start: moderne Geraete booten WebAssembly; alte Geraete (Server-Modus) oeffnen
        // stattdessen einen SignalR-Circuit. Fuer den Circuit Long-Polling erzwingen - das
        // Einsatznetz kappt WebSocket-Dauerverbindungen (~40s). Die circuit-Optionen werden
        // auf WASM-Geraeten ignoriert (dort entsteht kein Circuit).
        Blazor.start({
            circuit: {
                configureSignalR: function (builder) {
                    try { builder.withUrl('_blazor', { transport: 4 }); } catch (e) { }
                    try { builder.withServerTimeout(120000).withKeepAliveInterval(15000); } catch (e) { }
                }
            }
        });

        // PWA Service Worker
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js', { updateViaCache: 'none' })
                .then(function (reg) { reg.update(); })
                .catch(function (e) { console.error('SW registration failed:', e); });
        }
    </script>
</body>

</html>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    // Render-Modus je Request: ?rmode=server/wasm (Test-Override) > Cookie fw_srv=1
    // (Client-BigInt-Check) > server-seitige UA-Erkennung (iOS 10-13) > sonst WASM.
    // Prerender MUSS an bleiben (prerender:true): im Server-Modus (iOS 12/SignalR) liefert der
    // Server sonst KEIN initiales HTML -> die Seite bleibt weiss, bis der Circuit ueber
    // Long-Polling steht. Auf alten iPads reicht das fuer eine dauerhaft weisse Seite.
    // Mit Prerender ist sofort Inhalt da; die Runtime hydriert danach.
    private static readonly IComponentRenderMode ServerMode = new InteractiveServerRenderMode(prerender: true);
    private static readonly IComponentRenderMode WasmMode = new InteractiveWebAssemblyRenderMode(prerender: true);

    private IComponentRenderMode Mode
    {
        get
        {
            var ctx = HttpContext;
            if (ctx is null) return WasmMode;
            var rmode = ctx.Request.Query["rmode"].ToString();
            if (rmode == "server") return ServerMode;
            if (rmode == "wasm") return WasmMode;
            if (ctx.Request.Cookies.TryGetValue("fw_srv", out var c) && c == "1") return ServerMode;
            return IsOldBrowser(ctx.Request.Headers.UserAgent.ToString()) ? ServerMode : WasmMode;
        }
    }

    // iOS 10-13 (kein .NET-8-WASM) an der UA erkennen.
    private static bool IsOldBrowser(string ua) =>
        !string.IsNullOrEmpty(ua) && ua.Contains("Safari")
        && System.Text.RegularExpressions.Regex.IsMatch(ua, "OS 1[0-3]_");
}
