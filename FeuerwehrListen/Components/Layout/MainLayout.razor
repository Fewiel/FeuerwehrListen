@inherits LayoutComponentBase

<div class="tw-shell">
    <NavMenu />

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="reconnect-banner" class="reconnect-banner reconnect-hidden"></div>
@* Diagnose-Protokoll: wird per Tipp auf das Reconnect-Banner ein-/ausgeblendet (App.razor) *@
<pre id="diag-details" style="display:none; position:fixed; left:0; right:0; bottom:0; max-height:45vh; overflow:auto; margin:0; padding:10px 12px; background:#14181D; color:#B7E3C0; font-size:11px; line-height:1.45; white-space:pre-wrap; word-break:break-word; z-index:99999; border-top:2px solid #E4002B;"></pre>

<div id="blazor-error-ui">
    Ein unerwarteter Fehler ist aufgetreten.
    <a href="" class="reload">Neu laden</a>
    <a class="dismiss">🗙</a>
</div>