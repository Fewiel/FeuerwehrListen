@using FeuerwehrListen.Models
@inject AuthenticationService AuthService
@inject SettingsService SettingsService
@inject NavigationManager Navigation
@implements IDisposable

@{
    var logo = SettingsService.GetSetting(SettingKeys.BrandingLogoUrl);
    var appName = SettingsService.GetSetting(SettingKeys.BrandingAppName);
    appName = string.IsNullOrWhiteSpace(appName) ? "Feuerwehr Listen" : appName;
}

<header class="tw-appbar">
    <a class="tw-brand" href="/">
        @if (!string.IsNullOrWhiteSpace(logo))
        {
            <img src="@logo" alt="" />
        }
        else
        {
            <i class="bi bi-fire"></i>
        }
        <span>@appName</span>
    </a>

    <nav class="tw-nav">
        <NavLink href="" Match="NavLinkMatch.All"><i class="bi bi-house"></i> Übersicht</NavLink>
        @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityAttendance))
        {
            <NavLink href="create-attendance"><i class="bi bi-clipboard-check"></i> Anwesenheit</NavLink>
        }
        @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityOperations))
        {
            <NavLink href="create-operation"><i class="bi bi-truck"></i> Einsatz</NavLink>
        }
        @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityFireSafetyWatch))
        {
            <NavLink href="firesafetywatches"><i class="bi bi-shield-check"></i> Wachen</NavLink>
        }
        @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityDefects))
        {
            <NavLink href="defects"><i class="bi bi-tools"></i> Mängel</NavLink>
        }
    </nav>

    <div class="tw-right">
        @if (AuthService.IsAuthenticated)
        {
            <div class="tw-drop">
                <button @onclick="@(() => Toggle("admin"))">
                    <i class="bi bi-grid"></i> @(AuthService.IsAdmin ? "Verwaltung" : "Listen") <i class="bi bi-chevron-down" style="font-size:.8rem"></i>
                </button>
            </div>
            <div class="tw-drop">
                <button @onclick="@(() => Toggle("user"))">
                    <span class="tw-avatar">@Initials()</span> <i class="bi bi-chevron-down" style="font-size:.8rem"></i>
                </button>
            </div>
        }
        else
        {
            <a class="tw-login" href="login"><i class="bi bi-unlock"></i> Login</a>
        }
    </div>

    <button class="tw-hamburger" @onclick="@(() => Toggle("mobile"))" aria-label="Menü">
        <i class="bi bi-list"></i>
    </button>
</header>

@if (_open is not null)
{
    <div class="tw-backdrop" @onclick="Close"></div>
}

@if (_open == "admin")
{
    <div class="tw-drop-menu tw-menu-fixed">
        <div class="tw-drop-head">Listen &amp; Daten</div>
        <a href="admin/closed-lists"><i class="bi bi-check-circle"></i> Abgeschlossene Listen</a>
        <a href="admin/archive"><i class="bi bi-archive"></i> Archiv</a>
        <a href="admin/members"><i class="bi bi-person"></i> Mitglieder</a>
        <a href="admin/scheduled"><i class="bi bi-calendar"></i> Geplante Listen</a>
        @if (AuthService.IsAdmin)
        {
            <hr />
            <div class="tw-drop-head">Verwaltung</div>
            <a href="admin/vehicles"><i class="bi bi-truck"></i> Fahrzeuge</a>
            <a href="admin/functions"><i class="bi bi-puzzle"></i> Funktionen</a>
            <a href="admin/keywords"><i class="bi bi-tags"></i> Stichwörter</a>
            <a href="admin/users"><i class="bi bi-people"></i> Benutzer</a>
            <a href="admin/apikeys"><i class="bi bi-key"></i> API Keys</a>
            <a href="admin/statistics"><i class="bi bi-bar-chart"></i> Statistiken</a>
            <a href="admin/service-status"><i class="bi bi-gear"></i> Service Status</a>
            <a href="admin/settings"><i class="bi bi-sliders"></i> Einstellungen</a>
        }
    </div>
}

@if (_open == "user")
{
    <div class="tw-drop-menu tw-menu-fixed">
        <div class="tw-drop-head">@AuthService.CurrentUser?.Username</div>
        <a href="camera-settings"><i class="bi bi-camera-video"></i> Kamera-Einstellungen</a>
        <a href="change-password"><i class="bi bi-key"></i> Passwort ändern</a>
        <hr />
        <a href="logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
    </div>
}

@if (_open == "mobile")
{
    <nav class="tw-mobile-menu">
        <div class="mm-head">
            <b>@appName</b>
            <button @onclick="Close" aria-label="Schließen"><i class="bi bi-x"></i></button>
        </div>
        <a href="/" class="@ActiveExact"><i class="bi bi-house"></i> Übersicht</a>
        @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityAttendance))
        {
            <a href="create-attendance"><i class="bi bi-clipboard-check"></i> Neue Anwesenheitsliste</a>
        }
        @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityOperations))
        {
            <a href="create-operation"><i class="bi bi-truck"></i> Neue Einsatzliste</a>
        }
        @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityFireSafetyWatch))
        {
            <a href="firesafetywatches"><i class="bi bi-shield-check"></i> Brandsicherheitswachen</a>
        }
        @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityDefects))
        {
            <a href="defects"><i class="bi bi-tools"></i> Mängelliste</a>
        }

        @if (AuthService.IsAuthenticated)
        {
            <div class="mm-sect">Listen &amp; Daten</div>
            <a href="admin/closed-lists"><i class="bi bi-check-circle"></i> Abgeschlossene Listen</a>
            <a href="admin/archive"><i class="bi bi-archive"></i> Archiv</a>
            <a href="admin/members"><i class="bi bi-person"></i> Mitglieder</a>
            <a href="admin/scheduled"><i class="bi bi-calendar"></i> Geplante Listen</a>

            @if (AuthService.IsAdmin)
            {
                <div class="mm-sect">Verwaltung</div>
                <a href="admin/vehicles"><i class="bi bi-truck"></i> Fahrzeuge</a>
                <a href="admin/functions"><i class="bi bi-puzzle"></i> Funktionen</a>
                <a href="admin/keywords"><i class="bi bi-tags"></i> Stichwörter</a>
                <a href="admin/users"><i class="bi bi-people"></i> Benutzer</a>
                <a href="admin/apikeys"><i class="bi bi-key"></i> API Keys</a>
                <a href="admin/statistics"><i class="bi bi-bar-chart"></i> Statistiken</a>
                <a href="admin/service-status"><i class="bi bi-gear"></i> Service Status</a>
                <a href="admin/settings"><i class="bi bi-sliders"></i> Einstellungen</a>
            }

            <div class="mm-sect">Konto</div>
            <a href="camera-settings"><i class="bi bi-camera-video"></i> Kamera-Einstellungen</a>
            <a href="change-password"><i class="bi bi-key"></i> Passwort ändern</a>
            <a href="logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
        }
        else
        {
            <div class="mm-sect">Konto</div>
            <a href="login"><i class="bi bi-unlock"></i> Login</a>
        }
    </nav>
}

@code {
    private string? _open;
    private bool _sessionChecked;

    private string ActiveExact => Navigation.Uri == Navigation.BaseUri ? "active" : "";

    protected override void OnInitialized()
    {
        SettingsService.OnSettingsChanged += OnStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_sessionChecked)
        {
            _sessionChecked = true;
            var restored = await AuthService.TryRestoreSessionAsync();
            if (restored)
            {
                StateHasChanged();
            }
        }
    }

    private void Toggle(string name) => _open = _open == name ? null : name;
    private void Close() => _open = null;

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _open = null;
        InvokeAsync(StateHasChanged);
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private string Initials()
    {
        var u = AuthService.CurrentUser;
        if (u == null) return "?";
        var fn = (u.FirstName ?? "").Trim();
        var ln = (u.LastName ?? "").Trim();
        if (fn.Length > 0 && ln.Length > 0) return $"{char.ToUpper(fn[0])}{char.ToUpper(ln[0])}";
        var un = (u.Username ?? "").Trim();
        return un.Length >= 2 ? un.Substring(0, 2).ToUpper() : (un.Length == 1 ? un.ToUpper() : "?");
    }

    public void Dispose()
    {
        SettingsService.OnSettingsChanged -= OnStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
