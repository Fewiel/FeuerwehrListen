@using FeuerwehrListen.Models
@inject AuthenticationService AuthService
@inject SidebarService SidebarService
@inject SettingsService SettingsService
@rendermode InteractiveServer

<div class="sidebar @(SidebarService.IsCollapsed ? "collapsed" : "")">
    <div class="sidebar-header d-flex align-items-center justify-content-between">
        <h4 class="px-3 py-3 mb-0 @(SidebarService.IsCollapsed ? "d-none" : "")">
            @{
                var navLogo = SettingsService.GetSetting(SettingKeys.BrandingLogoUrl);
                var navAppName = SettingsService.GetSetting(SettingKeys.BrandingAppName);
            }
            @if (!string.IsNullOrWhiteSpace(navLogo))
            {
                <img src="@navLogo" alt="" style="height: 22px; margin-right: 8px; vertical-align: middle;" />
            }
            else
            {
                <i class="bi bi-fire me-2"></i>
            }
            @(string.IsNullOrWhiteSpace(navAppName) ? "Feuerwehr Listen" : navAppName)
        </h4>
        <button class="btn btn-link text-white p-2" @onclick="ToggleCollapse">
            <i class="bi @(SidebarService.IsCollapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
        </button>
    </div>

    <div class="nav-scrollable">
        <nav class="flex-column">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All" title="@(SidebarService.IsCollapsed ? "Übersicht" : "")">
                    <i class="bi bi-house @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                    <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Übersicht</span>
                </NavLink>
            </div>

            @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityAttendance))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="create-attendance" title="@(SidebarService.IsCollapsed ? "Neue Anwesenheitsliste" : "")">
                        <i class="bi bi-plus-circle @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                        <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Neue Anwesenheitsliste</span>
                    </NavLink>
                </div>
            }

            @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityOperations))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="create-operation" title="@(SidebarService.IsCollapsed ? "Neue Einsatzliste" : "")">
                        <i class="bi bi-exclamation-triangle @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                        <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Neue Einsatzliste</span>
                    </NavLink>
                </div>
            }

            @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityFireSafetyWatch))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="firesafetywatches" title="@(SidebarService.IsCollapsed ? "Brandsicherheitswachen" : "")">
                        <i class="bi bi-shield-check @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                        <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Brandsicherheitswachen</span>
                    </NavLink>
                </div>
            }

            @if (SettingsService.IsModuleVisible(SettingKeys.VisibilityDefects))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="defects" title="@(SidebarService.IsCollapsed ? "M\u00e4ngelliste" : "")">
                        <i class="bi bi-tools @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                        <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">M&auml;ngelliste</span>
                    </NavLink>
                </div>
            }
            
            @if (AuthService.IsAuthenticated)
            {
                @if (AuthService.IsAdmin)
                {
                    <hr class="my-3 mx-3"/>

                    <div class="nav-item px-3">
                        <div class="nav-link-header @(SidebarService.IsCollapsed ? "d-none" : "")">
                            Admin-Bereich
                        </div>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/closed-lists" title="@(SidebarService.IsCollapsed ? "Abgeschlossene Listen" : "")">
                            <i class="bi bi-check-circle @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Abgeschlossene Listen</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/archive" title="@(SidebarService.IsCollapsed ? "Archiv" : "")">
                            <i class="bi bi-archive @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Archiv</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/members" title="@(SidebarService.IsCollapsed ? "Mitglieder" : "")">
                            <i class="bi bi-person @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Mitglieder</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/vehicles" title="@(SidebarService.IsCollapsed ? "Fahrzeuge" : "")">
                            <i class="bi bi-truck @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Fahrzeuge</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/functions" title="@(SidebarService.IsCollapsed ? "Funktionen" : "")">
                            <i class="bi bi-puzzle @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Funktionen</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/keywords" title="@(SidebarService.IsCollapsed ? "Stichwörter" : "")">
                            <i class="bi bi-tags @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Stichwörter</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/users" title="@(SidebarService.IsCollapsed ? "Benutzer" : "")">
                            <i class="bi bi-people @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Benutzer</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/apikeys" title="@(SidebarService.IsCollapsed ? "API Keys" : "")">
                            <i class="bi bi-key @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">API Keys</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/statistics" title="@(SidebarService.IsCollapsed ? "Statistiken" : "")">
                            <i class="bi bi-bar-chart @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Statistiken</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/scheduled" title="@(SidebarService.IsCollapsed ? "Geplante Listen" : "")">
                            <i class="bi bi-calendar @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Geplante Listen</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/service-status" title="@(SidebarService.IsCollapsed ? "Service Status" : "")">
                            <i class="bi bi-gear @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Service Status</span>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/settings" title="@(SidebarService.IsCollapsed ? "Einstellungen" : "")">
                            <i class="bi bi-sliders @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Einstellungen</span>
                        </NavLink>
                    </div>
                }

                @if (!AuthService.IsAdmin)
                {
                    <hr class="my-3 mx-3"/>
                    <div class="nav-item px-3">
                        <div class="nav-link-header @(SidebarService.IsCollapsed ? "d-none" : "")">
                            Listen &amp; Daten
                        </div>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/closed-lists" title="@(SidebarService.IsCollapsed ? "Abgeschlossene Listen" : "")">
                            <i class="bi bi-check-circle @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Abgeschlossene Listen</span>
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/archive" title="@(SidebarService.IsCollapsed ? "Archiv" : "")">
                            <i class="bi bi-archive @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Archiv</span>
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/members" title="@(SidebarService.IsCollapsed ? "Mitglieder" : "")">
                            <i class="bi bi-person @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Mitglieder</span>
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="admin/scheduled" title="@(SidebarService.IsCollapsed ? "Geplante Listen" : "")">
                            <i class="bi bi-calendar @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                            <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Geplante Listen</span>
                        </NavLink>
                    </div>
                }

                <hr class="my-3 mx-3"/>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="camera-settings" title="@(SidebarService.IsCollapsed ? "Kamera" : "")">
                        <i class="bi bi-camera-video @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                        <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Kamera-Einstellungen</span>
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="change-password" title="@(SidebarService.IsCollapsed ? "Passwort ändern" : "")">
                        <i class="bi bi-key @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                        <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Passwort ändern</span>
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="logout" title="@(SidebarService.IsCollapsed ? "Logout" : "")">
                        <i class="bi bi-box-arrow-right @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                        <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Logout</span>
                    </NavLink>
                </div>
            }
            else
            {
                <hr class="my-3 mx-3"/>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login" title="@(SidebarService.IsCollapsed ? "Login" : "")">
                        <i class="bi bi-unlock @(SidebarService.IsCollapsed ? "" : "me-2")"></i>
                        <span class="@(SidebarService.IsCollapsed ? "d-none" : "")">Login</span>
                    </NavLink>
                </div>
            }
        </nav>
    </div>
</div>

@implements IDisposable

@code {
    private bool _sessionChecked;

    protected override void OnInitialized()
    {
        SidebarService.OnStateChanged += OnStateChanged;
        SettingsService.OnSettingsChanged += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_sessionChecked)
        {
            _sessionChecked = true;
            var restored = await AuthService.TryRestoreSessionAsync();
            if (restored)
            {
                StateHasChanged();
            }
        }
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ToggleCollapse()
    {
        SidebarService.ToggleCollapse();
    }
    
    public void Dispose()
    {
        SidebarService.OnStateChanged -= OnStateChanged;
        SettingsService.OnSettingsChanged -= OnStateChanged;
    }
}