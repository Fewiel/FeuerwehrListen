@page "/admin/members"
@using FeuerwehrListen.Models
@using FeuerwehrListen.Repositories
@using FeuerwehrListen.Components.Layout
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using FeuerwehrListen.Services
@inject MemberRepository MemberRepo
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject DownloadTokenService TokenService
@rendermode InteractiveServer

<PageTitle>Mitgliederverwaltung</PageTitle>

<UserAuthCheck>
    <div class="container mt-4">
        <div class="row mb-4">
            <div class="col">
                <h1>Mitgliederverwaltung</h1>
            </div>
            <div class="col-auto d-flex gap-2">
                <button class="btn btn-primary" @onclick="ShowCreateForm">
                    <i class="bi bi-plus-circle me-1"></i> Neues Mitglied
                </button>
                <button class="btn btn-outline-primary" @onclick="() => _showCsvImport = !_showCsvImport">
                    <i class="bi bi-upload me-1"></i> CSV Import
                </button>
                <button class="btn btn-outline-secondary" @onclick="ExportPdf">
                    <i class="bi bi-file-earmark-pdf me-1"></i> PDF Export
                </button>
            </div>
        </div>

        @if (_showForm)
        {
            <div class="row mb-4">
                <div class="col-md-8 offset-md-2">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">@(_editingMember?.Id > 0 ? "Mitglied bearbeiten" : "Neues Mitglied")</h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Mitgliedsnummer</label>
                                <input type="text" class="form-control" @bind="_editingMember!.MemberNumber" />
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Vorname</label>
                                        <input type="text" class="form-control" @bind="_editingMember!.FirstName" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">Nachname</label>
                                        <input type="text" class="form-control" @bind="_editingMember!.LastName" />
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Primäre Einheit (optional)</label>
                                <select class="form-select" @bind="_editingMember!.UnitNumber">
                                    <option value="">Keine Zuordnung</option>
                                    @for (int u = 1; u <= 9; u++)
                                    {
                                        <option value="@u">Einheit @u</option>
                                    }
                                </select>
                                <small class="text-muted">Wenn leer, wird die Einheit aus der Mitgliedsnummer abgeleitet.</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Weitere Einheiten</label>
                                <div class="border rounded p-2 d-flex flex-wrap gap-3">
                                    @for (int u = 1; u <= 9; u++)
                                    {
                                        var unit = u;
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="@($"unit-{unit}")"
                                                   checked="@_editingUnits.Contains(unit)"
                                                   @onchange="@((ChangeEventArgs e) => ToggleEditingUnit(unit, (bool)(e.Value ?? false)))" />
                                            <label class="form-check-label" for="@($"unit-{unit}")">Einheit @unit</label>
                                        </div>
                                    }
                                </div>
                                <small class="text-muted">
                                    Mehrfachzuordnung möglich. Die Primäreinheit wird automatisch mit aufgenommen.
                                </small>
                            </div>
                            <div class="mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" @bind="_editingMember!.IsActive" id="activeCheck" />
                                    <label class="form-check-label" for="activeCheck">
                                        Aktiv
                                    </label>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-primary" @onclick="SaveMember">Speichern</button>
                                <button class="btn btn-secondary" @onclick="CancelEdit">Abbrechen</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (_showCsvImport)
        {
            <div class="row mb-4">
                <div class="col-md-8 offset-md-2">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-upload me-2"></i>CSV Import</h5>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showCsvImport = false">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="alert alert-info">
                                <strong>CSV-Format:</strong> Die CSV-Datei muss folgende Spalten enthalten (mit Semikolon als Trennzeichen):
                                <br/>
                                <code>Mitgliedsnummer;Vorname;Nachname;Aktiv;Einheit(en)</code>
                                <br/>
                                <small class="text-muted">
                                    Die erste Zeile wird als Header erkannt und übersprungen.
                                    "Aktiv" akzeptiert: ja/nein, true/false, 1/0.
                                    "Einheit(en)" ist optional (1-9). <strong>Mehrere Einheiten</strong> per Komma trennen, z.&nbsp;B. <code>1,3</code>.
                                    Die erste angegebene Einheit wird als Primäreinheit übernommen.
                                    Existierende Mitgliedsnummern werden übersprungen.
                                </small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">CSV-Datei auswählen</label>
                                <InputFile class="form-control" OnChange="OnCsvFileSelected" accept=".csv" />
                            </div>

                            @if (_csvImporting)
                            {
                                <div class="d-flex align-items-center">
                                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                    <span>Importiere...</span>
                                </div>
                            }

                            @if (_csvImportResult != null)
                            {
                                <div class="alert @(_csvImportErrors.Any() ? "alert-warning" : "alert-success") mt-3">
                                    <strong>@_csvImportResult</strong>
                                    @if (_csvImportErrors.Any())
                                    {
                                        <ul class="mb-0 mt-2">
                                            @foreach (var error in _csvImportErrors)
                                            {
                                                <li>@error</li>
                                            }
                                        </ul>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row">
            <div class="col">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Alle Mitglieder (@_members.Count)</h5>
                    </div>
                    <div class="card-body">
                        @if (_members.Count == 0)
                        {
                            <p class="text-muted">Keine Mitglieder vorhanden</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Mitgliedsnummer</th>
                                            <th>Name</th>
                                            <th>Einheit</th>
                                            <th>Status</th>
                                            <th>Erstellt</th>
                                            <th>Aktionen</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var member in _members)
                                        {
                                            <tr>
                                                <td><strong>@member.MemberNumber</strong></td>
                                                <td>@member.FirstName @member.LastName</td>
                                                <td>
                                                    @{
                                                        var units = _memberUnits.TryGetValue(member.Id, out var ul) ? ul : new List<int>();
                                                        if (units.Count == 0 && member.UnitNumber.HasValue)
                                                            units = new List<int> { member.UnitNumber.Value };
                                                    }
                                                    @if (units.Count == 0)
                                                    {
                                                        <span class="text-muted">—</span>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var u in units)
                                                        {
                                                            var isPrimary = member.UnitNumber == u;
                                                            <span class="badge @(isPrimary ? "bg-primary" : "bg-secondary") me-1" title="@(isPrimary ? "Primäreinheit" : "Zusätzliche Einheit")">
                                                                Einheit @u
                                                            </span>
                                                        }
                                                    }
                                                </td>
                                                <td>
                                                    @if (member.IsActive)
                                                    {
                                                        <span class="badge bg-success">Aktiv</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Inaktiv</span>
                                                    }
                                                </td>
                                                <td>@member.CreatedAt.ToString("dd.MM.yyyy")</td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => EditMember(member)">Bearbeiten</button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteMember(member.Id)">Löschen</button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col">
                <button class="btn btn-secondary" @onclick='() => Navigation.NavigateTo("/")'>Zurück zur Übersicht</button>
            </div>
        </div>
    </div>
</UserAuthCheck>

@code {
    private List<Member> _members = new();
    private Dictionary<int, List<int>> _memberUnits = new();
    private Member? _editingMember;
    private HashSet<int> _editingUnits = new();
    private bool _showForm = false;
    private bool _showCsvImport = false;
    private bool _csvImporting = false;
    private string? _csvImportResult;
    private List<string> _csvImportErrors = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMembers();
    }

    private async Task LoadMembers()
    {
        _members = await MemberRepo.GetAllAsync();
        _memberUnits = await MemberRepo.GetUnitsForMembersAsync(_members.Select(m => m.Id));
    }

    private void ShowCreateForm()
    {
        _editingMember = new Member
        {
            IsActive = true,
            CreatedAt = DateTime.Now
        };
        _editingUnits = new HashSet<int>();
        _showForm = true;
    }

    private void EditMember(Member member)
    {
        _editingMember = new Member
        {
            Id = member.Id,
            MemberNumber = member.MemberNumber,
            FirstName = member.FirstName,
            LastName = member.LastName,
            IsActive = member.IsActive,
            UnitNumber = member.UnitNumber,
            CreatedAt = member.CreatedAt
        };
        _editingUnits = _memberUnits.TryGetValue(member.Id, out var units)
            ? new HashSet<int>(units)
            : new HashSet<int>();
        if (member.UnitNumber.HasValue)
            _editingUnits.Add(member.UnitNumber.Value);
        _showForm = true;
    }

    private void ToggleEditingUnit(int unit, bool isChecked)
    {
        if (isChecked)
            _editingUnits.Add(unit);
        else
            _editingUnits.Remove(unit);
    }

    private async Task SaveMember()
    {
        if (_editingMember == null || string.IsNullOrWhiteSpace(_editingMember.MemberNumber) ||
            string.IsNullOrWhiteSpace(_editingMember.FirstName) || string.IsNullOrWhiteSpace(_editingMember.LastName))
            return;

        // Primäreinheit muss in der Liste der zugeordneten Einheiten enthalten sein.
        var unitSet = new HashSet<int>(_editingUnits.Where(u => u >= 1 && u <= 9));
        if (_editingMember.UnitNumber.HasValue)
            unitSet.Add(_editingMember.UnitNumber.Value);

        int memberId;
        if (_editingMember.Id == 0)
        {
            memberId = await MemberRepo.CreateAsync(_editingMember);
        }
        else
        {
            await MemberRepo.UpdateAsync(_editingMember);
            memberId = _editingMember.Id;
        }

        await MemberRepo.SetUnitsForMemberAsync(memberId, unitSet, _editingMember.UnitNumber);

        _showForm = false;
        _editingMember = null;
        _editingUnits = new HashSet<int>();
        await LoadMembers();
    }

    private void CancelEdit()
    {
        _showForm = false;
        _editingMember = null;
        _editingUnits = new HashSet<int>();
    }

    private async Task DeleteMember(int id)
    {
        await MemberRepo.DeleteAsync(id);
        await LoadMembers();
    }

    private async Task ExportPdf()
    {
        var path = "/api/export/members/pdf";
        var token = TokenService.CreateToken(path);
        var baseUri = Navigation.BaseUri.TrimEnd('/');
        var url = $"{baseUri}/api/export/members/pdf?token={Uri.EscapeDataString(token)}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task OnCsvFileSelected(InputFileChangeEventArgs e)
    {
        _csvImportResult = null;
        _csvImportErrors = new List<string>();
        _csvImporting = true;
        StateHasChanged();

        try
        {
            var file = e.File;
            if (file == null)
                return;

            // Limit to 5MB
            if (file.Size > 5 * 1024 * 1024)
            {
                _csvImportResult = "Datei ist zu groß (max. 5 MB).";
                return;
            }

            using var reader = new System.IO.StreamReader(file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024));
            var content = await reader.ReadToEndAsync();
            var lines = content.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);

            if (lines.Length < 2)
            {
                _csvImportResult = "Die CSV-Datei enthält keine Daten (nur Header oder leer).";
                return;
            }

            // Load existing member numbers to skip duplicates
            var existingMembers = await MemberRepo.GetAllAsync();
            var existingNumbers = existingMembers.Select(m => m.MemberNumber.Trim()).ToHashSet(StringComparer.OrdinalIgnoreCase);

            var imported = 0;
            var skipped = 0;

            // Skip first line (header)
            for (var i = 1; i < lines.Length; i++)
            {
                var line = lines[i].Trim();
                if (string.IsNullOrWhiteSpace(line))
                    continue;

                var parts = line.Split(';');

                if (parts.Length < 3)
                {
                    _csvImportErrors.Add($"Zeile {i + 1}: Zu wenige Spalten ({parts.Length}), erwartet mindestens 3.");
                    continue;
                }

                var memberNumber = parts[0].Trim();
                var firstName = parts[1].Trim();
                var lastName = parts[2].Trim();

                if (string.IsNullOrWhiteSpace(memberNumber) || string.IsNullOrWhiteSpace(firstName) || string.IsNullOrWhiteSpace(lastName))
                {
                    _csvImportErrors.Add($"Zeile {i + 1}: Mitgliedsnummer, Vorname oder Nachname ist leer.");
                    continue;
                }

                if (existingNumbers.Contains(memberNumber))
                {
                    skipped++;
                    continue;
                }

                var isActive = true;
                if (parts.Length >= 4)
                {
                    var activeValue = parts[3].Trim().ToLowerInvariant();
                    isActive = activeValue is "ja" or "true" or "1";
                }

                int? unitNumber = null;
                var allUnits = new List<int>();
                if (parts.Length >= 5)
                {
                    var raw = parts[4].Trim();
                    if (!string.IsNullOrWhiteSpace(raw))
                    {
                        // Mehrere Einheiten können per Komma (oder Leerzeichen / Pipe) getrennt werden.
                        var tokens = raw.Split(new[] { ',', ' ', '|', '/' }, StringSplitOptions.RemoveEmptyEntries);
                        foreach (var t in tokens)
                        {
                            if (int.TryParse(t.Trim(), out var parsedUnit) && parsedUnit >= 1 && parsedUnit <= 9
                                && !allUnits.Contains(parsedUnit))
                            {
                                allUnits.Add(parsedUnit);
                            }
                        }
                        if (allUnits.Count > 0)
                            unitNumber = allUnits.First();
                    }
                }

                var member = new Member
                {
                    MemberNumber = memberNumber,
                    FirstName = firstName,
                    LastName = lastName,
                    IsActive = isActive,
                    UnitNumber = unitNumber,
                    CreatedAt = DateTime.Now
                };

                var newId = await MemberRepo.CreateAsync(member);
                if (allUnits.Count > 0)
                {
                    await MemberRepo.SetUnitsForMemberAsync(newId, allUnits, unitNumber);
                }
                existingNumbers.Add(memberNumber);
                imported++;
            }

            _csvImportResult = $"Import abgeschlossen: {imported} Mitglieder importiert, {skipped} übersprungen (bereits vorhanden).";
            if (_csvImportErrors.Any())
                _csvImportResult += $" {_csvImportErrors.Count} Fehler.";

            await LoadMembers();
        }
        catch (Exception ex)
        {
            _csvImportResult = $"Fehler beim Import: {ex.Message}";
        }
        finally
        {
            _csvImporting = false;
            StateHasChanged();
        }
    }
}


