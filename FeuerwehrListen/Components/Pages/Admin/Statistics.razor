@page "/admin/statistics"
@using FeuerwehrListen.Models
@using FeuerwehrListen.Services
@using FeuerwehrListen.Components.Layout
@using FeuerwehrListen.Components.Shared
@using FeuerwehrListen.Repositories
@inject StatisticsService StatsService
@inject PdfExportService PdfService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject DownloadTokenService TokenService

<PageTitle>Statistiken - Admin</PageTitle>

<AdminAuthCheck>

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h1>📊 Statistiken & Auswertungen</h1>
            <p class="text-muted">Übersicht über Teilnahmequoten, Trends und Leistungsindikatoren</p>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" @onclick="ExportStatisticsPdf">
                <i class="bi bi-file-earmark-pdf"></i> PDF-Export (mit Filter)
            </button>
        </div>
    </div>

    @* ---------- Filterleiste ---------- *@
    <style>
        /* Alle Filter-Controls exakt gleiche Höhe */
        .stat-filters .form-select,
        .stat-filters .form-control,
        .stat-filters .btn { height: 38px; }
    </style>
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold"><i class="bi bi-funnel me-1"></i>Filter</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ResetFilter">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Zurücksetzen
            </button>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end stat-filters">
                <div class="col-12 col-md-4">
                    <label class="form-label mb-1"><i class="bi bi-collection me-1"></i>Listentyp</label>
                    <select class="form-select" @bind="_filter.ListType" @bind:after="ReloadStatistics">
                        <option value="@StatListType.Operation">Einsatzlisten</option>
                        <option value="@StatListType.Attendance">Anwesenheitslisten</option>
                        <option value="@StatListType.FireSafetyWatch">Brandsicherheitswachen</option>
                        <option value="@StatListType.All">Gesamt</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label mb-1"><i class="bi bi-calendar-event me-1"></i>Von</label>
                    <input type="datetime-local" class="form-control" @bind="_filter.From" @bind:after="ReloadStatistics" />
                </div>
                <div class="col-6 col-md-3">
                    <label class="form-label mb-1"><i class="bi bi-calendar-event me-1"></i>Bis</label>
                    <input type="datetime-local" class="form-control" @bind="_filter.To" @bind:after="ReloadStatistics" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label mb-1"><i class="bi bi-diagram-3 me-1"></i>Einheit</label>
                    <select class="form-select" @bind="_filter.Unit" @bind:after="ReloadStatistics">
                        <option value="0">Alle Einheiten</option>
                        @for (int u = 1; u <= 9; u++)
                        {
                            <option value="@u">Einheit @u</option>
                        }
                    </select>
                </div>
            </div>
            @if (!_filter.IncludeOperations)
            {
                <div class="alert alert-info py-2 mb-0 mt-3">
                    <i class="bi bi-info-circle me-1"></i>
                    Fahrzeug-, Funktions-, Atemschutz-, Stichwort- und Requirements-Auswertungen gelten nur für <strong>Einsatzlisten</strong>
                    und werden bei diesem Listentyp ausgeblendet.
                </div>
            }
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Lädt...</span>
            </div>
            <p class="mt-2">Statistiken werden berechnet...</p>
        </div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-primary">@_listStats.TotalLists</h5>
                        <p class="card-text">Gesamt Listen</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-success">@_listStats.OpenLists</h5>
                        <p class="card-text">Offene Listen</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-info">@_listStats.AverageParticipants</h5>
                        <p class="card-text">Ø Teilnehmer</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title text-warning">@_listStats.TotalParticipants</h5>
                        <p class="card-text">Gesamt Teilnahmen</p>
                    </div>
                </div>
            </div>
        </div>

        @if (_filter.IncludeOperations)
        {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">📉 Teilnahme-Trend nach Einsatzart</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">
                            Teilnehmerzahl je Einsatz im gew&auml;hlten Zeitraum (chronologisch).
                            <span class="text-danger fw-semibold">Rot/fallend</span> bedeutet: zu dieser Einsatzart kommen zunehmend <strong>weniger</strong> Kr&auml;fte.
                        </p>
                        @if (_typeTrends.Count == 0)
                        {
                            <p class="text-muted mb-0">Keine Eins&auml;tze im Zeitraum.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Einsatzart</th>
                                            <th class="text-center">Eins&auml;tze</th>
                                            <th class="text-center">&Oslash; Teiln.</th>
                                            <th>Verlauf</th>
                                            <th class="text-center">Trend</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var tr in _typeTrends)
                                        {
                                            <tr>
                                                <td><strong>@tr.Einsatzart</strong></td>
                                                <td class="text-center">@tr.OperationCount</td>
                                                <td class="text-center">@tr.AverageParticipants.ToString("F1")</td>
                                                <td>@((MarkupString)Sparkline(tr))</td>
                                                <td class="text-center">@((MarkupString)TrendBadge(tr.TrendPercent, tr.OperationCount))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        }

        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">🏆 Top Teilnehmer</h5>
                    </div>
                    <div class="card-body">
                        @if (_topParticipants.Count == 0)
                        {
                            <p class="text-muted">Keine Daten verfügbar</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Name</th>
                                            <th>Teilnahmen</th>
                                            <th>Anteil</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var (participant, index) in _topParticipants.Select((p, i) => (p, i)))
                                        {
                                            <tr>
                                                <td>@(index + 1)</td>
                                                <td>
                                                    <strong>@participant.MemberName</strong>
                                                    <br><small class="text-muted">@participant.MemberNumber</small>
                                                </td>
                                                <td>@participant.ParticipationCount</td>
                                                <td>
                                                    <ProgressBar Value="@participant.Percentage" Color="@GetProgressBarColor(participant.Percentage)" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            @if (_filter.IncludeOperations)
            {
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">🚒 Fahrzeug-Nutzung</h5>
                    </div>
                    <div class="card-body">
                        @if (_vehicleStats.Count == 0)
                        {
                            <p class="text-muted">Keine Daten verfügbar</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Fahrzeug</th>
                                            <th>Einsätze</th>
                                            <th>Ø Besatzung</th>
                                            <th>Anteil</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var vehicle in _vehicleStats.Take(5))
                                        {
                                            <tr>
                                                <td><strong>@vehicle.VehicleName</strong></td>
                                                <td>@vehicle.UsageCount</td>
                                                <td>@vehicle.AverageCrew.ToString("F1")</td>
                                                <td>
                                                    <ProgressBar Value="@vehicle.UsagePercentage" Color="#dc3545" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">👥 Funktionen-Verteilung</h5>
                    </div>
                    <div class="card-body">
                        @if (_functionStats.Count == 0)
                        {
                            <p class="text-muted">Keine Daten verfügbar</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Funktion</th>
                                            <th>Anzahl</th>
                                            <th>Anteil</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var func in _functionStats)
                                        {
                                            <tr>
                                                <td><strong>@func.FunctionName</strong></td>
                                                <td>@func.Count</td>
                                                <td>
                                                    <ProgressBar Value="@func.Percentage" Color="#0dcaf0" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">🫁 Unter Atemschutz</h5>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-6">
                                <h3 class="text-warning">@_breathingStats.WithApparatus</h3>
                                <p class="mb-0">Unter Atemschutz</p>
                            </div>
                            <div class="col-6">
                                <h3 class="text-secondary">@_breathingStats.WithoutApparatus</h3>
                                <p class="mb-0">Ohne Atemschutz</p>
                            </div>
                        </div>
                        <hr>
                        <ProgressBar Value="@_breathingStats.WithApparatusPercentage"
                                     Color="#ffc107"
                                     Height="30px"
                                     FontSize="14px"
                                     CustomLabel="@($"{_breathingStats.WithApparatusPercentage:F1}% unter Atemschutz")" />
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">🏷️ Stichwort-Verwendung</h5>
                    </div>
                    <div class="card-body">
                        @if (_keywordStats.Count == 0)
                        {
                            <p class="text-muted">Keine Stichwort-Daten verfügbar</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>Stichwort</th>
                                            <th>Einsätze</th>
                                            <th>Erfüllung</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var keyword in _keywordStats.Take(5))
                                        {
                                            <tr>
                                                <td><strong>@keyword.KeywordName</strong></td>
                                                <td>@keyword.UsageCount</td>
                                                <td>
                                                    @if (keyword.OperationsWithRequirements > 0)
                                                    {
                                                        <ProgressBar Value="@keyword.RequirementsFulfillmentRate"
                                                                     Color="@GetRequirementsColor(keyword.RequirementsFulfillmentRate)" />
                                                        <small class="text-muted">@keyword.RequirementsFulfillmentRate.ToString("F1")%</small>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Keine Requirements</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">✅ Personal Requirements Status</h5>
                    </div>
                    <div class="card-body">
                        <div class="row text-center mb-3">
                            <div class="col-4">
                                <h4 class="text-primary">@_requirementsStats.TotalOperations</h4>
                                <small class="text-muted">Einsätze mit Requirements</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-info">@_requirementsStats.OperationsFulfillingRequirements</h4>
                                <small class="text-muted">Erfüllt</small>
                            </div>
                            <div class="col-4">
                                <h4 class="@GetRequirementsStatusColor(_requirementsStats.RequirementsFulfillmentRate)">@_requirementsStats.RequirementsFulfillmentRate.ToString("F1")%</h4>
                                <small class="text-muted">Erfüllungsrate</small>
                            </div>
                        </div>
                        <hr>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span><strong>Gesamt-Erfüllungsrate</strong></span>
                                <span class="badge @GetRequirementsBadgeClass(_requirementsStats.RequirementsFulfillmentRate)">
                                    @_requirementsStats.RequirementsFulfillmentRate.ToString("F1")%
                                </span>
                            </div>
                            <ProgressBar Value="@_requirementsStats.RequirementsFulfillmentRate"
                                         Color="@GetRequirementsColor(_requirementsStats.RequirementsFulfillmentRate)"
                                         Height="25px" />
                        </div>
                        @if (_requirementsStats.KeywordSummaries.Any())
                        {
                            <h6 class="mb-2">Top Stichwörter:</h6>
                            <div class="row">
                                @foreach (var keyword in _requirementsStats.KeywordSummaries.Take(3))
                                {
                                    <div class="col-12 mb-2">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span>@keyword.KeywordName</span>
                                            <div class="d-flex align-items-center">
                                                <span class="me-2">@keyword.FulfillmentRate.ToString("F0")%</span>
                                                <ProgressBar Value="@keyword.FulfillmentRate"
                                                             Color="@GetRequirementsColor(keyword.FulfillmentRate)"
                                                             Height="15px" />
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">Keine Einsätze mit gesetzten Requirements im Filterzeitraum.</p>
                        }
                    </div>
                </div>
            </div>
            }
        </div>

        @if (_filter.IncludeOperations)
        {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">📋 Einsatz-Übersicht</h5>
                        <div>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="PreviousPage" disabled="@(_currentPage == 0)">
                                <i class="bi bi-chevron-left"></i> Zurück
                            </button>
                            <span class="mx-2">Seite @(_currentPage + 1) / @_totalPages</span>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(_currentPage >= _totalPages - 1)">
                                Weiter <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        @if (_opCompositionData.Any())
                        {
                            var pagedOperations = _opCompositionData
                                .OrderByDescending(o => o.OperationNumber)
                                .Skip(_currentPage * _pageSize)
                                .Take(_pageSize)
                                .ToList();

                            @foreach (var op in pagedOperations)
                            {
                                var isExpanded = _expandedOperations.Contains(op.OperationNumber);
                                <div class="card mb-3">
                                    <div class="card-header" style="cursor: pointer;" @onclick="() => ToggleOperation(op.OperationNumber)">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <strong>@op.OperationNumber</strong>
                                                @if (!string.IsNullOrEmpty(op.Keyword))
                                                {
                                                    <span class="ms-2 text-muted">| @op.Keyword</span>
                                                }
                                                @if (!string.IsNullOrEmpty(op.Address))
                                                {
                                                    <span class="ms-2 text-muted">| @op.Address</span>
                                                }
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <span class="badge bg-primary me-2">@op.TotalParticipants Teilnehmer</span>
                                                @if (op.HasPersonalRequirements)
                                                {
                                                    <span class="badge @(op.RequirementsFulfilled ? "bg-success" : "bg-warning") me-2">
                                                        @if (op.RequirementsFulfilled)
                                                        {
                                                            <i class="bi bi-check-circle"></i> @($"{op.RequirementsFulfillmentRate:F0}%")
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-exclamation-triangle"></i> @($"{op.RequirementsFulfillmentRate:F0}%")
                                                        }
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary me-2">
                                                        <i class="bi bi-info-circle"></i> Keine Requirements
                                                    </span>
                                                }
                                                <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                            </div>
                                        </div>
                                    </div>
                                    @if (isExpanded)
                                    {
                                        <div class="card-body">
                                            @if (op.HasPersonalRequirements)
                                            {
                                                <div class="alert @(op.RequirementsFulfilled ? "alert-success" : "alert-warning") mb-3">
                                                    <div class="d-flex align-items-center">
                                                        <i class="bi @(op.RequirementsFulfilled ? "bi-check-circle" : "bi-exclamation-triangle") me-2"></i>
                                                        <div>
                                                            <strong>Personal Requirements Status:</strong>
                                                            @if (op.RequirementsFulfilled)
                                                            {
                                                                <span class="text-success">Alle Requirements erfüllt (@op.RequirementsFulfillmentRate.ToString("F0")%)</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-warning">Requirements teilweise erfüllt (@op.RequirementsFulfillmentRate.ToString("F0")%)</span>
                                                            }
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="alert alert-info mb-3">
                                                    <i class="bi bi-info-circle me-2"></i>
                                                    <strong>Keine Personal Requirements definiert</strong> - Stichwort ohne Requirements-Konfiguration
                                                </div>
                                            }

                                            @if (op.FunctionCounts.Any(f => f.Value > 0) || op.WithVehicleTruppCount > 0)
                                            {
                                                <h6 class="mb-3">Funktionen (mit Fahrzeug):</h6>
                                                <div class="row">
                                                    @foreach (var func in op.FunctionCounts.Where(f => f.Value > 0).OrderByDescending(f => f.Value))
                                                    {
                                                        <div class="col-md-6 mb-2">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <span>@func.Key</span>
                                                                <span class="badge bg-primary">@func.Value</span>
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (op.WithVehicleTruppCount > 0)
                                                    {
                                                        <div class="col-md-6 mb-2">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <span>Trupp</span>
                                                                <span class="badge bg-secondary">@op.WithVehicleTruppCount</span>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            @if (op.NoVehicleFunctionCounts.Any(f => f.Value > 0) || op.WithoutVehicleTruppCount > 0)
                                            {
                                                <hr class="my-3" />
                                                <h6 class="mb-3">Funktionen (ohne Fahrzeug):</h6>
                                                <div class="row">
                                                    @foreach (var func in op.NoVehicleFunctionCounts.Where(f => f.Value > 0).OrderByDescending(f => f.Value))
                                                    {
                                                        <div class="col-md-6 mb-2">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <span>@func.Key</span>
                                                                <span class="badge bg-warning text-dark">@func.Value</span>
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (op.WithoutVehicleTruppCount > 0)
                                                    {
                                                        <div class="col-md-6 mb-2">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <span>Trupp</span>
                                                                <span class="badge bg-secondary">@op.WithoutVehicleTruppCount</span>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            @if (!op.FunctionCounts.Any(f => f.Value > 0) && !op.NoVehicleFunctionCounts.Any(f => f.Value > 0) && op.WithVehicleTruppCount == 0 && op.WithoutVehicleTruppCount == 0)
                                            {
                                                <p class="text-muted mb-0">Keine Funktionen zugewiesen</p>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted">Keine Einsätze verfügbar.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
        }

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">👤 Mitglieder-Statistiken</h5>
                    </div>
                    <div class="card-body">
                        @if (_memberStats.Count == 0)
                        {
                            <p class="text-muted">Keine Daten verfügbar</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Mitgliedsnummer</th>
                                            <th>Anwesenheit</th>
                                            <th>Einsätze</th>
                                            <th>Gesamt</th>
                                            <th>Letzte Teilnahme</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var member in _memberStats.Take(20))
                                        {
                                            <tr>
                                                <td><strong>@member.MemberName</strong></td>
                                                <td>@member.MemberNumber</td>
                                                <td>@member.TotalAttendance</td>
                                                <td>@member.TotalOperations</td>
                                                <td>@(member.TotalAttendance + member.TotalOperations)</td>
                                                <td>
                                                    @if (member.LastParticipation != DateTime.MinValue)
                                                    {
                                                        @member.LastParticipation.ToString("dd.MM.yyyy")
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Nie</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

</AdminAuthCheck>

@code {
    private bool _loading = true;
    private ListStatistics _listStats = new();
    private List<TopParticipant> _topParticipants = new();
    private List<MemberStatistics> _memberStats = new();
    private List<VehicleStatistics> _vehicleStats = new();
    private List<FunctionStatistics> _functionStats = new();
    private BreathingApparatusStatistics _breathingStats = new();
    private List<OperationComposition> _opCompositionData = new();
    private List<KeywordStatistics> _keywordStats = new();
    private PersonalRequirementsStatistics _requirementsStats = new();
    private List<ParticipationTypeTrend> _typeTrends = new();
    private double _trendMax = 1;
    private HashSet<string> _expandedOperations = new();
    private int _currentPage = 0;
    private int _pageSize = 10;
    private int _totalPages => _opCompositionData.Any() ? (int)Math.Ceiling(_opCompositionData.Count / (double)_pageSize) : 1;

    // Vorausgewählt: Einsatzlisten, Von = Jahresanfang (01.01. 00:01)
    private StatsFilter _filter = new StatsFilter { ListType = StatListType.Operation, From = new DateTime(DateTime.Now.Year, 1, 1, 0, 1, 0) };

    protected override async Task OnInitializedAsync()
    {
        await LoadStatistics();
    }

    private async Task ReloadStatistics()
    {
        await LoadStatistics();
    }

    private async Task ResetFilter()
    {
        _filter = new StatsFilter { ListType = StatListType.Operation, From = new DateTime(DateTime.Now.Year, 1, 1, 0, 1, 0) };
        await LoadStatistics();
    }

    private async Task LoadStatistics()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _listStats = await StatsService.GetListStatisticsAsync(_filter);
            _topParticipants = await StatsService.GetTopParticipantsAsync(_filter, 10);
            _memberStats = await StatsService.GetMemberStatisticsAsync(_filter);
            _vehicleStats = await StatsService.GetVehicleStatisticsAsync(_filter);
            _functionStats = await StatsService.GetFunctionStatisticsAsync(_filter);
            _breathingStats = await StatsService.GetBreathingApparatusStatisticsAsync(_filter);
            _opCompositionData = await StatsService.GetOperationCompositionAsync(_filter, 100);
            _keywordStats = await StatsService.GetKeywordStatisticsAsync(_filter);
            _requirementsStats = await StatsService.GetPersonalRequirementsStatisticsAsync(_filter);
            _typeTrends = await StatsService.GetParticipationTrendByTypeAsync(_filter);
            _trendMax = _typeTrends.SelectMany(t => t.Series).DefaultIfEmpty(0).Max();
            if (_trendMax <= 0) _trendMax = 1;
            _currentPage = 0;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ToggleOperation(string operationNumber)
    {
        if (_expandedOperations.Contains(operationNumber))
            _expandedOperations.Remove(operationNumber);
        else
            _expandedOperations.Add(operationNumber);
    }

    private void NextPage()
    {
        if (_currentPage < _totalPages - 1)
            _currentPage++;
    }

    private void PreviousPage()
    {
        if (_currentPage > 0)
            _currentPage--;
    }

    private async Task ExportStatisticsPdf()
    {
        try
        {
            var path = "/api/export/statistics/pdf";
            var token = TokenService.CreateToken(path);
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            var query = $"?token={Uri.EscapeDataString(token)}&listType={(int)_filter.ListType}&unit={_filter.Unit}";
            if (_filter.From.HasValue)
                query += $"&from={Uri.EscapeDataString(_filter.From.Value.ToString("o"))}";
            if (_filter.To.HasValue)
                query += $"&to={Uri.EscapeDataString(_filter.To.Value.ToString("o"))}";
            var url = $"{baseUri}{path}{query}";
            await JSRuntime.InvokeVoidAsync("open", url, "_blank");
        }
        catch (Exception)
        {
        }
    }

    // Zahl mit Invariant-Kultur (Punkt als Dezimaltrenner) für SVG-Koordinaten
    private static string N(double d) => d.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);

    private string Sparkline(ParticipationTypeTrend tr)
    {
        var s = tr.Series;
        if (s.Count == 0) return string.Empty;
        double w = 150, h = 32, pad = 4;
        var max = _trendMax <= 0 ? 1 : _trendMax;
        var color = tr.TrendPercent < -5 ? "#dc3545" : tr.TrendPercent > 5 ? "#198754" : "#6c757d";

        if (s.Count == 1)
        {
            double cy1 = h - pad - ((double)s[0] / max) * (h - 2 * pad);
            return $"<svg width=\"{N(w)}\" height=\"{N(h)}\"><circle cx=\"{N(w / 2)}\" cy=\"{N(cy1)}\" r=\"3\" fill=\"{color}\"/></svg>";
        }

        var pts = new List<string>();
        for (int i = 0; i < s.Count; i++)
        {
            double x = pad + (double)i / (s.Count - 1) * (w - 2 * pad);
            double y = h - pad - ((double)s[i] / max) * (h - 2 * pad);
            pts.Add($"{N(x)},{N(y)}");
        }
        var poly = string.Join(" ", pts);
        var last = pts[^1].Split(',');
        return $"<svg width=\"{N(w)}\" height=\"{N(h)}\"><polyline points=\"{poly}\" fill=\"none\" stroke=\"{color}\" stroke-width=\"2\"/><circle cx=\"{last[0]}\" cy=\"{last[1]}\" r=\"2.5\" fill=\"{color}\"/></svg>";
    }

    private string TrendBadge(double pct, int opCount)
    {
        if (opCount < 2)
            return "<span class=\"badge bg-light text-muted\">&ndash;</span>";
        if (pct < -5)
            return $"<span class=\"badge bg-danger\"><i class=\"bi bi-arrow-down-right\"></i> {N(pct)}%</span>";
        if (pct > 5)
            return $"<span class=\"badge bg-success\"><i class=\"bi bi-arrow-up-right\"></i> +{N(pct)}%</span>";
        return "<span class=\"badge bg-secondary\"><i class=\"bi bi-arrow-right\"></i> stabil</span>";
    }

    private string GetProgressBarColor(double rate)
    {
        return rate switch
        {
            >= 80 => "#198754",
            >= 60 => "#0dcaf0",
            >= 40 => "#ffc107",
            _ => "#dc3545"
        };
    }

    private string GetRequirementsColor(double rate)
    {
        return rate switch
        {
            >= 90 => "#198754",
            >= 70 => "#20c997",
            >= 50 => "#ffc107",
            >= 30 => "#fd7e14",
            _ => "#dc3545"
        };
    }

    private string GetRequirementsStatusColor(double rate)
    {
        return rate switch
        {
            >= 90 => "text-success",
            >= 70 => "text-info",
            >= 50 => "text-warning",
            >= 30 => "text-warning",
            _ => "text-danger"
        };
    }

    private string GetRequirementsBadgeClass(double rate)
    {
        return rate switch
        {
            >= 90 => "bg-success",
            >= 70 => "bg-info",
            >= 50 => "bg-warning",
            >= 30 => "bg-warning",
            _ => "bg-danger"
        };
    }
}
