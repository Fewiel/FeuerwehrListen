@page "/attendance/{Id:int}"
@using FeuerwehrListen.Models
@using FeuerwehrListen.Services
@using FeuerwehrListen.Repositories
@using FeuerwehrListen.Components.Shared
@inject AttendanceListRepository AttendanceRepo
@inject AttendanceEntryRepository EntryRepo
@inject MemberRepository MemberRepo
@inject PdfExportService PdfService
@inject NavigationManager Navigation
@inject AuthenticationService AuthService
@inject UnitAssignmentService UnitAssignmentService
@inject ListNotificationService ListNotificationService
@inject EmailSenderService EmailSender
@inject SettingsService SettingsService
@rendermode InteractiveServer

<PageTitle>Anwesenheitsliste - @_list?.Title</PageTitle>

@if (_list != null)
{
    <div class="container mt-4">
        <div class="mb-4">
            <h1>@_list.Title</h1>
            <p class="lead">@_list.Unit</p>
            @if (_list.UnitNumber.HasValue)
            {
                <p><strong>Einheit:</strong> @_list.UnitNumber</p>
            }
            <p>@_list.Description</p>
            <small class="text-muted">Erstellt: @_list.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
            @if (_list.Status != ListStatus.Open)
            {
                <div class="mt-3"><span class="badge bg-secondary fs-5">Abgeschlossen</span></div>
            }
        </div>

        <QrScanner IsActive="@(_list?.Status == ListStatus.Open)" OnCodeScanned="HandleQrCodeScanned" OnManualEntryRequested="ShowNumpad" />

        @if (_confirmationVisible)
        {
            <div class="entry-confirmation-overlay">
                <i class="bi bi-check-circle-fill"></i>
                <div class="entry-confirmation-name">@_confirmationName</div>
                <small class="text-muted">eingetragen</small>
            </div>
        }

        <Numpad @ref="_numpad" OnInput="HandleNumpadInput" OnSearchByName="ShowMemberSelectionModal" OnReorderQrTag="HandleReorderQrTag" />
        <MemberSelectionModal @ref="_memberSelectionModal" OnMemberSelected="HandleMemberSelection" />
        <ExcuseModal @ref="_excuseModal" ListId="Id" UnitNumber="_list?.UnitNumber" OnChanged="LoadData" />
        <UnitRedirectModal @ref="_unitRedirectModal" OnListSelected="HandleUnitRedirectSelection" />

        @if (!string.IsNullOrWhiteSpace(_infoMessage))
        {
            <div class="alert alert-info mt-3" role="alert">@_infoMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="alert alert-danger mt-3" role="alert">@_errorMessage</div>
        }

        <div class="row">
            <div class="col">
                @{
                    var presentEntries = _entries.Where(e => !e.IsExcused).ToList();
                    var excusedEntries = _entries.Where(e => e.IsExcused).ToList();
                }
                
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Anwesend (@presentEntries.Count)</h5>
                    </div>
                    <div class="card-body">
                        @if (presentEntries.Count == 0)
                        {
                            <p class="text-muted">Noch keine Einträge</p>
                        }
                        else
                        {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Name/ID</th>
                                        <th>Eingetragen um</th>
                                            @if (_list.Status == ListStatus.Open && AuthService.IsAdmin)
                                            {
                                                <th>Aktion</th>
                                            }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var (entry, index) in presentEntries.Select((e, i) => (e, i)))
                                    {
                                        <tr>
                                            <td>@(index + 1)</td>
                                            <td><strong>@entry.NameOrId</strong></td>
                                            <td>@entry.EnteredAt.ToString("HH:mm:ss")</td>
                                            @if (_list.Status == ListStatus.Open && AuthService.IsAdmin)
                                            {
                                                <td>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEntry(entry.Id)" title="Entfernen">
                                                        🗑️ Entfernen
                                                    </button>
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        }
                    </div>
                </div>

                @if (excusedEntries.Count > 0)
                {
                    <div class="card mt-3">
                        <div class="card-header">
                            <h5 class="mb-0">Entschuldigt (@excusedEntries.Count)</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Name/ID</th>
                                            <th>Eingetragen um</th>
                                            @if (_list.Status == ListStatus.Open && AuthService.IsAdmin)
                                            {
                                                <th>Aktion</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var (entry, index) in excusedEntries.Select((e, i) => (e, i)))
                                        {
                                            <tr>
                                                <td>@(index + 1)</td>
                                                <td><strong>@entry.NameOrId</strong></td>
                                                <td>@entry.EnteredAt.ToString("HH:mm:ss")</td>
                                                @if (_list.Status == ListStatus.Open && AuthService.IsAdmin)
                                                {
                                                    <td>
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEntry(entry.Id)" title="Entfernen">
                                                            🗑️ Entfernen
                                                        </button>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (_list.Status == ListStatus.Open)
        {
            <div class="d-grid gap-2 mt-4" style="max-width: 500px;">
                @if (AuthService.IsAuthenticated)
                {
                    <button class="btn btn-outline-warning btn-lg" @onclick="ShowExcuseModal">
                        <i class="bi bi-person-exclamation me-2"></i>Als Entschuldigt eintragen
                    </button>
                }
                <button class="btn btn-warning btn-lg" @onclick="CloseList">
                    <i class="bi bi-lock me-2"></i>Liste abschließen
                </button>
                <button class="btn btn-primary btn-lg" @onclick="ExportPdf">
                    <i class="bi bi-file-earmark-pdf me-2"></i>PDF Export
                </button>
            </div>
        }
        else
        {
            <div class="d-grid gap-2 mt-4" style="max-width: 500px;">
                <button class="btn btn-primary btn-lg" @onclick="ExportPdf">
                    <i class="bi bi-file-earmark-pdf me-2"></i>PDF Export
                </button>
            </div>
        }

        <div class="mt-3 mb-4">
            <button class="btn btn-secondary" @onclick='() => Navigation.NavigateTo("/")'>Zurück zur Übersicht</button>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private AttendanceList? _list;
    private List<AttendanceEntry> _entries = new();
    private string _combinedInput = string.Empty;
    private string _errorMessage = string.Empty;
    private string _infoMessage = string.Empty;
    private bool _isExcused = false;
    private ElementReference _inputElement;
    private List<Member> _suggestions = new();
    private bool _showSuggestions = false;
    private CancellationTokenSource? _searchCts;
    private Numpad? _numpad;
    private MemberSelectionModal? _memberSelectionModal;
    private ExcuseModal? _excuseModal;
    private UnitRedirectModal? _unitRedirectModal;
    private Member? _pendingMember;
    private bool _confirmationVisible;
    private string _confirmationName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var restored = await AuthService.TryRestoreSessionAsync();
            if (restored)
            {
                StateHasChanged();
            }
        }
    }

    private async Task LoadData()
    {
        _list = await AttendanceRepo.GetByIdAsync(Id);
        if (_list != null)
        {
            _entries = await EntryRepo.GetByListIdAsync(Id);
        }
    }

    private async Task AddEntry()
    {
        if (_list?.Status != ListStatus.Open)
            return;

        _errorMessage = string.Empty;
        _infoMessage = string.Empty;
        
        if (string.IsNullOrWhiteSpace(_combinedInput))
            return;

        string input = _combinedInput;
        
        // Wenn es ein Name mit ID in Klammern ist, extrahiere die ID
        var openIdx = input.LastIndexOf('(');
        var closeIdx = input.LastIndexOf(')');
        if (openIdx >= 0 && closeIdx > openIdx)
        {
            var inside = input.Substring(openIdx + 1, closeIdx - openIdx - 1).Trim();
            if (!string.IsNullOrEmpty(inside))
            {
                var byNum = await MemberRepo.GetByMemberNumberAsync(inside);
                if (byNum != null)
                {
                    input = inside;
                }
            }
        }

        var member = await MemberRepo.FindByNameOrNumberAsync(input);
        if (member == null)
        {
            _errorMessage = $"Mitglied nicht gefunden!";
            return;
        }

        var targetListId = Id;
        if (_list.UnitNumber.HasValue)
        {
            var resolvedUnit = UnitAssignmentService.ResolveUnitNumber(member);
            if (resolvedUnit.HasValue && resolvedUnit.Value != _list.UnitNumber.Value)
            {
                // Member belongs to a different unit
                var unitLists = await AttendanceRepo.GetAllOpenByUnitNumberAsync(resolvedUnit.Value);
                var noUnitLists = await AttendanceRepo.GetOpenWithoutUnitAsync();
                var availableLists = unitLists.Concat(noUnitLists).ToList();

                if (availableLists.Count == 0)
                {
                    _errorMessage = $"Keine offene Anwesenheitsliste für Einheit {resolvedUnit.Value} gefunden.";
                    return;
                }

                if (availableLists.Count == 1)
                {
                    // Nur eine Alternative — eintragen, Bestätigung abwarten, dann navigieren
                    await SaveEntry(member, availableLists[0].Id);
                    await Task.Delay(2500);
                    try { Navigation.NavigateTo($"/attendance/{availableLists[0].Id}"); } catch { }
                    return;
                }

                // Mehrere Alternativen — Auswahl zeigen
                _pendingMember = member;
                _unitRedirectModal?.Show(
                    $"{member.FirstName} {member.LastName}",
                    resolvedUnit.Value,
                    _list.UnitNumber.Value,
                    availableLists);
                return;
            }
        }

        await SaveEntry(member, targetListId);
    }

    private async Task SaveEntry(Member member, int targetListId)
    {
        // Duplikat-Check — auch für Zielliste bei Unit-Redirect
        var entriesToCheck = targetListId == Id
            ? _entries
            : await EntryRepo.GetByListIdAsync(targetListId);
        if (entriesToCheck.Any(e => e.NameOrId.Contains($"({member.MemberNumber})")))
        {
            _errorMessage = $"{member.FirstName} {member.LastName} ist bereits eingetragen!";
            try { await JS.InvokeVoidAsync("playSound", "error"); } catch { }
            return;
        }

        var isExcused = AuthService.IsAdmin && _isExcused;

        var entry = new AttendanceEntry
        {
            AttendanceListId = targetListId,
            NameOrId = $"{member.FirstName} {member.LastName} ({member.MemberNumber})",
            EnteredAt = DateTime.Now,
            IsExcused = isExcused
        };

        await EntryRepo.CreateAsync(entry);
        _combinedInput = string.Empty;
        _isExcused = false;
        _showSuggestions = false;

        // Sound + Bestätigung
        try { await JS.InvokeVoidAsync("playSound", "success"); } catch { }
        _confirmationName = $"{member.FirstName} {member.LastName}";
        _confirmationVisible = true;
        StateHasChanged();
        _ = Task.Run(async () =>
        {
            await Task.Delay(2000);
            await InvokeAsync(() => { _confirmationVisible = false; StateHasChanged(); });
        });

        if (targetListId == Id)
        {
            await LoadData();
        }
        else
        {
            _infoMessage = $"Eintrag wurde in eine andere Liste übertragen.";
        }
    }

    private async Task HandleUnitRedirectSelection(int listId)
    {
        if (_pendingMember != null)
        {
            await SaveEntry(_pendingMember, listId);
            _pendingMember = null;
            await Task.Delay(2500);
            try { Navigation.NavigateTo($"/attendance/{listId}"); } catch { }
        }
    }

    private void ShowNumpad()
    {
        _numpad?.Show();
    }

    private async Task ShowExcuseModal()
    {
        if (_excuseModal != null)
            await _excuseModal.Show();
    }
    
    private void ShowMemberSelectionModal()
    {
        _memberSelectionModal?.Show();
    }
    
    private async Task HandleQrCodeScanned(string value)
    {
        await HandleNumpadInput(value.Trim());
    }

    private async Task HandleNumpadInput(string input)
    {
        if (int.TryParse(input, out _))
        {
            var member = await MemberRepo.GetByMemberNumberAsync(input);
            if (member != null)
            {
                await HandleMemberSelection(member.Id);
                return;
            }
        }
        
        var members = await MemberRepo.SearchAsync(input);
        if (members.Count == 1)
        {
            SelectSuggestion(members.First());
            await AddEntry();
        }
        else if (members.Count > 1)
        {
            _memberSelectionModal?.Show(members);
        }
        else
        {
            _errorMessage = "Mitglied nicht gefunden!";
        }
    }
    
    private async Task HandleMemberSelection(int memberId)
    {
        var member = await MemberRepo.GetByIdAsync(memberId);
        if (member != null)
        {
            SelectSuggestion(member);
            await AddEntry();
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await AddEntry();
        }
    }

    private async Task OnCombinedInput(ChangeEventArgs e)
    {
        _combinedInput = e.Value?.ToString() ?? string.Empty;
        _showSuggestions = false;
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;
        try
        {
            await Task.Delay(200, token);
            if (token.IsCancellationRequested) return;
            if (string.IsNullOrWhiteSpace(_combinedInput) || _combinedInput.Length < 2)
            {
                _suggestions.Clear();
                return;
            }
            var results = await MemberRepo.SearchAsync(_combinedInput, 10);
            if (!token.IsCancellationRequested)
            {
                _suggestions = results;
                _showSuggestions = _suggestions.Count > 0;
                StateHasChanged();
            }
        }
        catch { }
    }

    private void SelectSuggestion(Member m)
    {
        _combinedInput = $"{m.FirstName} {m.LastName} ({m.MemberNumber})";
        _showSuggestions = false;
        _memberSelectionModal?.Hide();
    }

    private void OnDigitEntered(string digit)
    {
        _combinedInput += digit;
        _showSuggestions = false;
    }

    private void ClearInput()
    {
        _combinedInput = string.Empty;
        _showSuggestions = false;
    }

    private async Task DeleteEntry(int entryId)
    {
        if (_list?.Status != ListStatus.Open)
            return;

        try
        {
            await EntryRepo.DeleteAsync(entryId);
            _errorMessage = string.Empty;
            await LoadData();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Löschen: {ex.Message}";
        }
    }

    private async Task CloseList()
    {
        if (_list == null) return;

        _list.Status = ListStatus.Closed;
        _list.ClosedAt = DateTime.Now;
        await AttendanceRepo.UpdateAsync(_list);
        await ListNotificationService.NotifyAttendanceClosedAsync(_list);
        await LoadData();
    }

    private async Task ExportPdf()
    {
        try
        {
            var path = $"/api/export/attendance/{_list.Id}/pdf";
            var token = await CreateDownloadToken(path);
            var url = $"api/export/attendance/{_list.Id}/pdf?token={Uri.EscapeDataString(token)}";
            await OpenInNewTab(url);
        }
        catch (Exception ex)
        {
        }
    }

    private Task<string> CreateDownloadToken(string path)
    {
        var baseUri = Navigation.BaseUri.TrimEnd('/');
        var tokenEndpoint = $"{baseUri}/token?path={Uri.EscapeDataString(path)}";
        return FetchToken(tokenEndpoint);
    }

    private static async Task<string> FetchToken(string url)
    {
        using var http = new HttpClient();
        return await http.GetStringAsync(url);
    }

    private async Task HandleReorderQrTag(string memberNumber)
    {
        var settings = await SettingsService.GetAllSettingsAsync();
        settings.TryGetValue(SettingKeys.QrReorderRecipients, out var recipients);
        if (string.IsNullOrWhiteSpace(recipients)) return;

        var member = await MemberRepo.GetByMemberNumberAsync(memberNumber);
        var name = member != null ? $"{member.FirstName} {member.LastName} ({member.MemberNumber})" : memberNumber;

        try
        {
            await EmailSender.SendAsync(
                new[] { recipients },
                "QR-Tag Nachbestellung",
                $"Nachbestellung eines QR-Tags für:\n\n{name}\n\nBitte neuen QR-Code Ausweis erstellen.");
            _infoMessage = $"QR-Tag Nachbestellung für {name} wurde angefragt.";
        }
        catch
        {
            _errorMessage = "E-Mail für QR-Tag Nachbestellung konnte nicht gesendet werden.";
        }
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
    private async Task OpenInNewTab(string relativeUrl)
    {
        var baseUri = Navigation.BaseUri.TrimEnd('/');
        var full = $"{baseUri}/{relativeUrl}";
        await JS.InvokeVoidAsync("window.open", full, "_blank");
    }
}

