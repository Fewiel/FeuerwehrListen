@page "/create-operation"
@using FeuerwehrListen.Models
@using FeuerwehrListen.Services
@using FeuerwehrListen.Repositories
@inject OperationListRepository OperationRepo
@inject KeywordRepository KeywordRepo
@inject SettingsService SettingsService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Neue Einsatzliste</PageTitle>

@if (!SettingsService.IsModuleVisible(SettingKeys.VisibilityOperations))
{
    <div class="container mt-4">
        <div class="alert alert-warning">Dieses Modul ist deaktiviert.</div>
    </div>
    return;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h3>Neue Einsatzliste erstellen</h3>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Einsatznummer</label>
                        <input type="text" class="form-control" @bind="_operationNumber" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Stichwort</label>
                        <input type="text" class="form-control" list="keyword-suggestions" @bind="_keywordInput" placeholder="Stichwort eingeben oder auswählen" />
                        <datalist id="keyword-suggestions">
                            @foreach (var keyword in _availableKeywords)
                            {
                                <option value="@keyword.Name">@keyword.Description</option>
                            }
                        </datalist>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Alarmierungszeit</label>
                        <input type="datetime-local" class="form-control" @bind="_alertTime" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Adresse (optional)</label>
                        <input type="text" class="form-control" @bind="_address" placeholder="Straße Hausnummer, PLZ Ort" />
                    </div>
                    <div class="d-grid gap-2">
                        <button class="btn btn-danger btn-lg" @onclick="CreateList">Liste erstellen</button>
                        <button class="btn btn-secondary" @onclick='() => Navigation.NavigateTo("/")'>Abbrechen</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _operationNumber = string.Empty;
    private string _keywordInput = string.Empty;
    private DateTime _alertTime = DateTime.Now;
    private string _address = string.Empty;
    private List<Keyword> _availableKeywords = new();

    protected override async Task OnInitializedAsync()
    {
        _availableKeywords = await KeywordRepo.GetAllAsync();
    }

    private async Task CreateList()
    {
        if (string.IsNullOrWhiteSpace(_operationNumber) || string.IsNullOrWhiteSpace(_keywordInput))
            return;

        var keywordName = _keywordInput.Trim();
        var existingKeyword = _availableKeywords.FirstOrDefault(k => k.Name.Equals(keywordName, StringComparison.OrdinalIgnoreCase));

        int keywordId;
        if (existingKeyword != null)
        {
            keywordId = existingKeyword.Id;
            keywordName = existingKeyword.Name;
        }
        else
        {
            var newKeyword = new Keyword
            {
                Name = keywordName,
                IsActive = true,
                CreatedAt = DateTime.Now
            };
            keywordId = await KeywordRepo.CreateAsync(newKeyword);
        }

        var newList = new OperationList
        {
            OperationNumber = _operationNumber,
            Keyword = keywordName,
            KeywordId = keywordId,
            AlertTime = _alertTime,
            CreatedAt = DateTime.Now,
            Status = ListStatus.Open,
            Address = string.IsNullOrWhiteSpace(_address) ? null : _address.Trim()
        };

        var id = await OperationRepo.CreateAsync(newList);
        Navigation.NavigateTo($"/operation/{id}");
    }
}

