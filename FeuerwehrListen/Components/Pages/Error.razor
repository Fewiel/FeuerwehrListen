@page "/Error"
@using System.Diagnostics

<PageTitle>Fehler</PageTitle>

@* Bewusst statisches, eigenstaendiges Markup ohne Client-Layout/-Komponenten, damit diese
   Seite im Fehlerfall garantiert rendert (der Client-Router kennt die Route "/Error" nicht). *@
<div style="max-width:38em;margin:10vh auto;padding:0 20px;font-family:system-ui,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#171B21;line-height:1.55">
    <div style="height:6px;background:#E4002B;border-radius:6px;margin-bottom:24px"></div>
    <h1 style="color:#B3001F;font-size:26px;margin:0 0 12px">Es ist ein Fehler aufgetreten</h1>
    <p style="color:#5B646F;margin:0 0 16px">
        Bei der Verarbeitung Ihrer Anfrage ist ein unerwarteter Fehler aufgetreten.
        Bitte versuchen Sie es erneut oder kehren Sie zur Startseite zurück.
    </p>

    @if (ShowRequestId)
    {
        <p style="color:#8A929C;font-size:13px;margin:0 0 20px">
            Referenz-ID: <code style="background:#EDF0F3;padding:.15rem .4rem;border-radius:4px">@RequestId</code>
        </p>
    }

    <p style="margin:24px 0 0">
        <a href="/" style="display:inline-block;background:#171B21;color:#fff;text-decoration:none;padding:11px 20px;border-radius:10px;font-weight:500">
            Zur Startseite
        </a>
    </p>
</div>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
