@page "/firesafetywatches/{Id:int}"
@using FeuerwehrListen.Models
@using FeuerwehrListen.Repositories
@using Microsoft.AspNetCore.Components
@using FeuerwehrListen.Components.Shared
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject FireSafetyWatchRepository WatchRepo
@inject FireSafetyWatchRequirementRepository RequirementRepo
@inject FireSafetyWatchEntryRepository EntryRepo
@inject MemberRepository MemberRepo
@inject NavigationManager Navigation
@inject ListNotificationService ListNotificationService
@inject IJSRuntime JS
@inject EmailSenderService EmailSender
@inject SettingsService SettingsService
@rendermode InteractiveServer

<PageTitle>Details Brandsicherheitswache</PageTitle>

<div class="container mt-4">
    @if (_watch == null)
    {
        <p><em>Lade...</em></p>
    }
    else
    {
        <div class="mb-4">
            <h1>@_watch.Name</h1>
            <p class="lead text-muted">@_watch.Location | @_watch.EventDateTime.ToString("dd.MM.yyyy HH:mm 'Uhr'")</p>
            <div class="d-flex flex-wrap gap-2">
                <AuthorizeView Roles="Admin">
                    @if (_watch.Status == ListStatus.Open)
                    {
                        <button class="btn btn-warning" @onclick="CloseWatch">Wache abschließen</button>
                    }
                </AuthorizeView>
                <a href="/firesafetywatches" class="btn btn-secondary">Zurück zur Übersicht</a>
            </div>
        </div>

        <QrScanner IsActive="@(_watch?.Status == ListStatus.Open)" OnCodeScanned="HandleQrCodeScanned" OnManualEntryRequested="ShowNumpadDirect" />

        @if (_confirmationVisible)
        {
            <div class="entry-confirmation-overlay">
                <i class="bi bi-check-circle-fill"></i>
                <div class="entry-confirmation-name">@_confirmationName</div>
                <small class="text-muted">eingetragen</small>
            </div>
        }

        @foreach (var group in _groupedRequirements)
        {
            <div class="card bg-dark text-white mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        @if (group.Key.VehicleId != null)
                        {
                            @group.Key.VehicleName
                        }
                        else
                        {
                            @("Ohne Fahrzeug")
                        }
                    </h5>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var req in group)
                    {
                        var entriesForReq = _entries.Where(e => e.RequirementId == req.Id).ToList();
                        for (int i = 0; i < req.Amount; i++)
                        {
                            var entry = entriesForReq.ElementAtOrDefault(i);
                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@(req.FunctionDef?.Name ?? "Trupp")</strong>
                                </div>
                                <div>
                                    @if (entry != null)
                                    {
                                        <span>@entry.Member.FirstName @entry.Member.LastName</span>
                                        <AuthorizeView Roles="Admin">
                                            @if (_watch.Status == ListStatus.Open)
                                            {
                                                <button class="btn btn-sm btn-outline-danger ms-2" @onclick="() => Unregister(entry.Id)">Austragen</button>
                                            }
                                        </AuthorizeView>
                                    }
                                    else
                                    {
                                        @if (_watch.Status == ListStatus.Open)
                                        {
                                            <button class="btn btn-sm btn-success" @onclick="() => Register(req.Id)">Eintragen</button>
                                        }
                                    }
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
        }
    }
</div>

<Numpad @ref="_numpad" OnInput="HandleNumpadInput" OnSearchByName="ShowMemberSelectionModal" OnReorderQrTag="HandleReorderQrTag" />
<MemberSelectionModal @ref="_memberSelectionModal" OnMemberSelected="HandleMemberSelected" />
<QrRequirementSelectionModal @ref="_qrReqModal" Requirements="_requirements" OnRequirementSelected="HandleQrRequirementSelected" />

@code {
    [Parameter]
    public int Id { get; set; }

    private FireSafetyWatch _watch = null!;
    private List<FireSafetyWatchRequirement> _requirements = new();
    private List<FireSafetyWatchEntry> _entries = new();
    private IEnumerable<IGrouping<dynamic, FireSafetyWatchRequirement>> _groupedRequirements = Enumerable.Empty<IGrouping<dynamic, FireSafetyWatchRequirement>>();
    private MemberSelectionModal _memberSelectionModal = null!;
    private Numpad _numpad = null!;
    private int _selectedRequirementId;
    private QrRequirementSelectionModal? _qrReqModal;
    private Member? _pendingQrMember;
    private bool _confirmationVisible;
    private string _confirmationName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _watch = await WatchRepo.GetByIdAsync(Id);
        if (_watch != null)
        {
            _requirements = await RequirementRepo.GetByWatchIdAsync(Id);
            _entries = await EntryRepo.GetByWatchIdAsync(Id);
            
            _groupedRequirements = _requirements.GroupBy(r => new { r.VehicleId, VehicleName = r.Vehicle?.Name })
                                                .OrderBy(g => g.Key.VehicleId != null ? 0 : 1);
        }
    }

    private async Task HandleQrCodeScanned(string value)
    {
        var input = value.Trim();
        Member? member = null;
        if (int.TryParse(input, out _))
            member = await MemberRepo.GetByMemberNumberAsync(input);
        if (member == null)
        {
            var results = await MemberRepo.SearchAsync(input);
            if (results.Count == 1)
                member = results.First();
        }
        if (member != null)
        {
            _pendingQrMember = member;
            _qrReqModal?.Show(_entries);
        }
    }

    private async Task HandleQrRequirementSelected(int requirementId)
    {
        if (_pendingQrMember != null)
        {
            _selectedRequirementId = requirementId;
            await HandleMemberSelected(_pendingQrMember.Id);
            _pendingQrMember = null;
        }
    }

    private void Register(int requirementId)
    {
        _selectedRequirementId = requirementId;
        _numpad.Show();
    }

    private void ShowMemberSelectionModal()
    {
        _memberSelectionModal.Show();
    }

    private async Task HandleNumpadInput(string input)
    {
        if (int.TryParse(input, out _))
        {
            var member = await MemberRepo.GetByMemberNumberAsync(input);
            if (member != null)
            {
                await HandleMemberSelected(member.Id);
                return;
            }
        }
        
        var members = await MemberRepo.SearchAsync(input);
        if (members.Count == 1)
        {
            await HandleMemberSelected(members.First().Id);
        }
        else
        {
            _memberSelectionModal.Show(members);
        }
    }

    private async Task HandleReorderQrTag(string memberNumber)
    {
        var settings = await SettingsService.GetAllSettingsAsync();
        settings.TryGetValue(SettingKeys.QrReorderRecipients, out var recipients);
        if (string.IsNullOrWhiteSpace(recipients)) return;
        var member = await MemberRepo.GetByMemberNumberAsync(memberNumber);
        var name = member != null ? $"{member.FirstName} {member.LastName} ({member.MemberNumber})" : memberNumber;
        try
        {
            await EmailSender.SendAsync(new[] { recipients }, "QR-Tag Nachbestellung",
                $"Nachbestellung eines QR-Tags für:\n\n{name}\n\nBitte neuen QR-Code Ausweis erstellen.");
        }
        catch { }
    }

    private void ShowNumpadDirect()
    {
        _numpad.Show();
    }

    private async Task HandleMemberSelected(int memberId)
    {
        // Duplikat-Check
        if (_entries.Any(e => e.MemberId == memberId))
        {
            var member = await MemberRepo.GetByIdAsync(memberId);
            // Bereits in Ergebnis vorhanden - Fehlermeldung zeigen wäre gut, aber BSW hat kein _errorMessage Feld
            // Stattdessen einfach Sound und return
            try { await JS.InvokeVoidAsync("playSound", "error"); } catch { }
            return;
        }

        var entry = new FireSafetyWatchEntry
        {
            FireSafetyWatchId = Id,
            RequirementId = _selectedRequirementId,
            MemberId = memberId
        };
        await EntryRepo.InsertAsync(entry);

        // Sound + Bestätigung
        try { await JS.InvokeVoidAsync("playSound", "success"); } catch { }
        var m = await MemberRepo.GetByIdAsync(memberId);
        if (m != null)
        {
            _confirmationName = $"{m.FirstName} {m.LastName}";
            _confirmationVisible = true;
            StateHasChanged();
            _ = Task.Run(async () =>
            {
                await Task.Delay(2000);
                await InvokeAsync(() => { _confirmationVisible = false; StateHasChanged(); });
            });
        }

        await LoadData();
        StateHasChanged();
    }

    private async Task Unregister(int entryId)
    {
        await EntryRepo.DeleteAsync(entryId);
        await LoadData();
        StateHasChanged();
    }
    
    private async Task CloseWatch()
    {
        _watch.Status = ListStatus.Closed;
        _watch.ClosedAt = DateTime.Now;
        await WatchRepo.UpdateAsync(_watch);
        await ListNotificationService.NotifyFireSafetyWatchClosedAsync(_watch);
        await LoadData();
    }
}
