@page "/operation/{Id:int}/edit-entries"
@using FeuerwehrListen.Models
@using FeuerwehrListen.Services
@using FeuerwehrListen.Repositories
@using FeuerwehrListen.Components.Shared
@inject OperationListRepository OperationRepo
@inject OperationEntryRepository EntryRepo
@inject OperationEntryFunctionRepository EntryFunctionRepo
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Einträge bearbeiten</PageTitle>

@if (_list != null)
{
    <div class="container mt-4">
        <div class="mb-4">
            <h1>Einträge bearbeiten</h1>
            <p class="lead">Einsatz @_list.OperationNumber — @_list.Keyword</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="alert alert-info">@_message</div>
        }

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Einträge (@_entries.Count)</h5>
            </div>
            <div class="card-body">
                @if (_entries.Count == 0)
                {
                    <p class="text-muted">Keine Einträge vorhanden</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Name/ID</th>
                                    <th>Fahrzeug</th>
                                    <th>Funktionen</th>
                                    <th>Atemschutz</th>
                                    <th>Eingetragen</th>
                                    <th>Aktion</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (entry, index) in _entries.Select((e, i) => (e, i)))
                                {
                                    var funcs = _functionsByEntryId.TryGetValue(entry.Id, out var list)
                                        ? string.Join(", ", list.Select(x => x.Name))
                                        : "";
                                    <tr>
                                        <td>@(index + 1)</td>
                                        <td><strong>@entry.NameOrId</strong></td>
                                        <td>@entry.Vehicle</td>
                                        <td>@funcs</td>
                                        <td>
                                            @if (entry.WithBreathingApparatus)
                                            {
                                                <span class="badge bg-warning">Ja</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Nein</span>
                                            }
                                        </td>
                                        <td>@entry.EnteredAt.ToString("HH:mm:ss")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEntry(entry.Id)">
                                                <i class="bi bi-trash"></i> Löschen
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="mt-3">
            <button class="btn btn-secondary" @onclick='() => Navigation.NavigateTo($"/operation/{Id}")'>
                <i class="bi bi-arrow-left me-2"></i>Zurück zur Liste
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private OperationList? _list;
    private List<OperationEntry> _entries = new();
    private Dictionary<int, List<OperationFunctionDef>> _functionsByEntryId = new();
    private string _message = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _list = await OperationRepo.GetByIdAsync(Id);
        if (_list != null)
        {
            _entries = await EntryRepo.GetByListIdAsync(Id);
            var ids = _entries.Select(e => e.Id).ToList();
            _functionsByEntryId = await EntryFunctionRepo.GetFunctionsForEntriesAsync(ids);
        }
    }

    private async Task DeleteEntry(int entryId)
    {
        try
        {
            await EntryRepo.DeleteAsync(entryId);
            await LoadData();
            _message = "Eintrag gelöscht.";
        }
        catch (Exception ex)
        {
            _message = $"Fehler beim Löschen: {ex.Message}";
        }
    }
}
