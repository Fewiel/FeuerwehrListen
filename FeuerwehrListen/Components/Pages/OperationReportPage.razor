@page "/operation/{OperationListId:int}/bericht"
@using FeuerwehrListen.Models
@using FeuerwehrListen.Services
@using FeuerwehrListen.Repositories
@using FeuerwehrListen.Components.Layout
@using FeuerwehrListen.Components.Shared
@inject OperationListRepository OperationRepo
@inject OperationReportRepository ReportRepo
@inject OperationEntryRepository EntryRepo
@inject OperationEntryFunctionRepository EntryFunctionRepo
@inject VehicleRepository VehicleRepo
@inject NavigationManager Navigation
@inject DownloadTokenService TokenService
@inject IJSRuntime JS
@inject FeuerwehrListen.Services.NextcloudService Nextcloud

<PageTitle>Einsatzbericht - @(_list?.OperationNumber)</PageTitle>

<style>
    .rb-check { display: flex; align-items: center; gap: .5rem; padding: .35rem .25rem; margin: 0; cursor: pointer; }
    .rb-check input[type=checkbox] { width: 1.15rem; height: 1.15rem; margin: 0; flex: 0 0 auto; }
    .rb-check span { line-height: 1.25; }
    .report-savebar { position: sticky; bottom: 0; z-index: 20; background: rgba(245,246,248,.94); backdrop-filter: blur(6px); border-top: 1px solid var(--tw-line-strong, #D6DBE1); padding: .8rem 1rem; margin-top: 1.5rem; border-radius: .6rem .6rem 0 0; }
</style>

<UserAuthCheck>
    <div class="container mt-4">
        @if (_list == null)
        {
            <div class="alert alert-danger">Einsatz nicht gefunden.</div>
        }
        else if (_report != null)
        {
            <div class="d-flex justify-content-between align-items-start mb-2 flex-wrap gap-2">
                <div>
                    <h1 class="mb-1">Einsatzbericht</h1>
                    <p class="lead mb-0">Einsatz @_list.OperationNumber &middot; @_list.Keyword</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary" @onclick="GoBack">
                        <i class="bi bi-arrow-left"></i> Zur&uuml;ck zum Einsatz
                    </button>
                    <button class="btn btn-outline-danger" @onclick="ExportPdf">
                        <i class="bi bi-file-earmark-pdf"></i> PDF
                    </button>
                </div>
            </div>
            <p class="text-muted mb-4">
                <i class="bi bi-info-circle me-1"></i>
                Nur ausf&uuml;llen, was zutrifft &ndash; leere Felder sind kein Problem. Du kannst jederzeit unten speichern.
            </p>

            @* ---------- Kopfdaten ---------- *@
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Einsatzdaten</h5></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Nr.</label>
                            <input type="text" class="form-control" value="@_list.OperationNumber" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Alarmstichwort</label>
                            <input type="text" class="form-control" value="@_list.Keyword" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Alarmierungszeit</label>
                            <input type="text" class="form-control" value="@_list.AlertTime.ToString("dd.MM.yyyy HH:mm")" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ort, Ortsteil</label>
                            <input type="text" class="form-control" @bind="_report.OrtOrtsteil" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Stra&szlig;e</label>
                            <input type="text" class="form-control" @bind="_report.Strasse" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Einsatzleiter</label>
                            <input type="text" class="form-control" @bind="_report.Einsatzleiter" />
                        </div>
                    </div>
                </div>
            </div>

            @* ---------- Einsatzart (genau eine Kategorie) ---------- *@
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Einsatzart</h5></div>
                <div class="card-body">
                    <p class="text-muted mb-2">Bitte genau eine Einsatzart w&auml;hlen.</p>
                    <div class="btn-group flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="einsatzart" id="katBrand" autocomplete="off"
                               checked="@(SelectedKategorie == Kategorie.Brand)"
                               @onchange="@(() => SelectedKategorie = Kategorie.Brand)" />
                        <label class="btn btn-outline-danger" for="katBrand"><i class="bi bi-fire me-1"></i>Brandeinsatz</label>

                        <input type="radio" class="btn-check" name="einsatzart" id="katTh" autocomplete="off"
                               checked="@(SelectedKategorie == Kategorie.ThAbcOel)"
                               @onchange="@(() => SelectedKategorie = Kategorie.ThAbcOel)" />
                        <label class="btn btn-outline-danger" for="katTh"><i class="bi bi-tools me-1"></i>TH- / ABC- und &Ouml;leins&auml;tze</label>

                        <input type="radio" class="btn-check" name="einsatzart" id="katFehl" autocomplete="off"
                               checked="@(SelectedKategorie == Kategorie.Fehlalarm)"
                               @onchange="@(() => SelectedKategorie = Kategorie.Fehlalarm)" />
                        <label class="btn btn-outline-danger" for="katFehl"><i class="bi bi-exclamation-circle me-1"></i>Fehlalarm</label>
                    </div>

                    @if (SelectedKategorie == Kategorie.Brand)
                    {
                        <div class="mt-4">
                            <div class="row g-1 mb-3">
                                <div class="col-6 col-md-3"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.BrandKleinbrandA" /><span>Kleinbrand A</span></label></div>
                                <div class="col-6 col-md-3"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.BrandKleinbrandB" /><span>Kleinbrand B</span></label></div>
                                <div class="col-6 col-md-3"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.BrandMittelbrand" /><span>Mittelbrand</span></label></div>
                                <div class="col-6 col-md-3"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.BrandGrossbrand" /><span>Gro&szlig;brand</span></label></div>
                            </div>
                            <div class="row g-3">
                                <div class="col-md-4"><label class="form-label">Art des Brandobjektes</label><input type="text" class="form-control" @bind="_report.BrandArtObjekt" /></div>
                                <div class="col-md-4"><label class="form-label">Ausbruchstelle</label><input type="text" class="form-control" @bind="_report.BrandAusbruchstelle" /></div>
                                <div class="col-md-4"><label class="form-label">Brandursache</label><input type="text" class="form-control" @bind="_report.BrandUrsache" /></div>
                            </div>
                        </div>
                    }
                    else if (SelectedKategorie == Kategorie.ThAbcOel)
                    {
                        <div class="mt-4 row g-1">
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThVuMitEingekl" /><span>VU mit eingekl. Person</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThVuOhneEingekl" /><span>VU ohne eingekl. Person</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThZugunfall" /><span>Zugunfall</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThFlugzeugunfall" /><span>Flugzeugunfall</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThExplosion" /><span>Explosion</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThGasgeruch" /><span>Gasgeruch</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThSonstigerAbc" /><span>Sonstiger ABC-Einsatz</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThWasserEisrettung" /><span>Wasser-/Eisrettung</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThMenschenNotlage" /><span>Menschen in Notlage</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThTiereNotlage" /><span>Tiere in Notlage</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThVerkehrshindernis" /><span>Verkehrshindernis/-st&ouml;rung</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThWasserSturmschaden" /><span>Wasser-/Sturmschaden</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThGefahrFallenderGegenstand" /><span>Gefahr durch fallenden Gegenstand</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThAuslaufendeGuelle" /><span>Auslaufende G&uuml;lle</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThOeleinsatz" /><span>&Ouml;leinsatz</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.ThSonstigeHilfeleistung" /><span>Sonstige Hilfeleistung</span></label></div>
                        </div>
                    }
                    else if (SelectedKategorie == Kategorie.Fehlalarm)
                    {
                        <div class="mt-4 row g-1">
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.FehlGutenGlauben" /><span>Alarmierung im guten Glauben (blinder Alarm)</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.FehlBoeswillig" /><span>B&ouml;swillige Alarmierung</span></label></div>
                            <div class="col-12 col-md-6"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.FehlBrandmeldeanlage" /><span>Fehlalarm durch Brandmeldeanlage</span></label></div>
                        </div>
                    }
                </div>
            </div>

            @* ---------- Lagebericht ---------- *@
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-card-text me-2"></i>Lagebericht / eingesetzte Mittel</h5></div>
                <div class="card-body">
                    <textarea class="form-control" rows="5" @bind="_report.Lagebericht"></textarea>
                </div>
            </div>

            @* ---------- Kostenpflichtiger Einsatz ---------- *@
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-currency-euro me-2"></i>Kostenpflichtiger Einsatz</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label d-block">Ist der Einsatz kostenpflichtig?</label>
                        <div class="btn-group flex-wrap" role="group">
                            <input type="radio" class="btn-check" name="kostenpfl" id="kpJa" autocomplete="off"
                                   checked="@(_report.KostenpflichtStatus == KostenpflichtStatus.Ja)"
                                   @onchange="@(() => _report.KostenpflichtStatus = KostenpflichtStatus.Ja)" />
                            <label class="btn btn-outline-success" for="kpJa">Ja</label>

                            <input type="radio" class="btn-check" name="kostenpfl" id="kpNein" autocomplete="off"
                                   checked="@(_report.KostenpflichtStatus == KostenpflichtStatus.Nein)"
                                   @onchange="@(() => _report.KostenpflichtStatus = KostenpflichtStatus.Nein)" />
                            <label class="btn btn-outline-secondary" for="kpNein">Nein</label>

                            <input type="radio" class="btn-check" name="kostenpfl" id="kpUnb" autocomplete="off"
                                   checked="@(_report.KostenpflichtStatus == KostenpflichtStatus.Unbekannt)"
                                   @onchange="@(() => _report.KostenpflichtStatus = KostenpflichtStatus.Unbekannt)" />
                            <label class="btn btn-outline-secondary" for="kpUnb">unbekannt</label>
                        </div>
                    </div>

                    <div class="row">
                            <div class="col-lg-6">
                                <h6 class="fw-semibold">Verursacher / Fahrzeughalter</h6>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Name, Vorname" @bind="_report.VerursacherName" /></div>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Anschrift" @bind="_report.VerursacherAnschrift" /></div>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Geburtsdatum" @bind="_report.VerursacherGeburtsdatum" /></div>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Kfz-Kennzeichen" @bind="_report.VerursacherKfz" /></div>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Ggf. Name des Fahrers" @bind="_report.VerursacherFahrer" /></div>
                            </div>
                            <div class="col-lg-6">
                                <h6 class="fw-semibold">Gesch&auml;digter / Fahrzeughalter</h6>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Name, Vorname" @bind="_report.GeschaedigterName" /></div>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Anschrift" @bind="_report.GeschaedigterAnschrift" /></div>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Geburtsdatum" @bind="_report.GeschaedigterGeburtsdatum" /></div>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Kfz-Kennzeichen" @bind="_report.GeschaedigterKfz" /></div>
                                <div class="mb-2"><input type="text" class="form-control" placeholder="Ggf. Name des Fahrers" @bind="_report.GeschaedigterFahrer" /></div>
                            </div>
                    </div>
                    <small class="text-muted">Verursacher- und Gesch&auml;digten-Daten k&ouml;nnen unabh&auml;ngig von der Kostenpflicht erfasst werden. Bei kostenpflichtigen Eins&auml;tzen bitte zus&auml;tzlich die Kosten-Anlage verwenden.</small>
                </div>
            </div>

            @* ---------- Dienststellen / Funktionen vor Ort ---------- *@
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-people me-2"></i>Dienststellen / Funktionen vor Ort</h5></div>
                <div class="card-body">
                    @* --- Externe Kräfte (eigene, bearbeitbare Liste) --- *@
                    <div class="mb-3 p-3 rounded" style="background:#F5F6F8;">
                        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                            <label class="form-label fw-semibold mb-0"><i class="bi bi-truck-front me-1"></i>Externe Kr&auml;fte</label>
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="ToggleExternalForceForm">
                                <i class="bi @(_showExternalForceForm ? "bi-dash-lg" : "bi-plus-lg")"></i> Externe Kr&auml;fte erfassen
                            </button>
                        </div>
                        @if (_showExternalForceForm)
                        {
                            <div class="row g-2 align-items-end mb-2">
                                <div class="col-12 col-md-5"><label class="form-label small mb-1">Rufname</label><input class="form-control" placeholder="z. B. HVX-1-LF20-1" @bind="_newForceRufname" @onkeydown="ExternalForceKeyDown" /></div>
                                <div class="col-8 col-md-4"><label class="form-label small mb-1">St&auml;rke</label><input class="form-control" placeholder="z. B. 1/8" @bind="_newForceStaerke" @onkeydown="ExternalForceKeyDown" /></div>
                                <div class="col-4 col-md-3"><button type="button" class="btn btn-success w-100" @onclick="AddExternalForce"><i class="bi bi-check-lg"></i> Eintragen</button></div>
                            </div>
                        }
                        @if (_externalForces.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead><tr><th>Rufname</th><th style="width:30%">St&auml;rke</th><th class="text-end" style="width:1%"></th></tr></thead>
                                    <tbody>
                                        @foreach (var f in _externalForces)
                                        {
                                            <tr @key="f.Id">
                                                <td><input class="form-control form-control-sm" @bind="f.Rufname" @bind:after="() => UpdateExternalForce(f)" /></td>
                                                <td><input class="form-control form-control-sm" @bind="f.Staerke" @bind:after="() => UpdateExternalForce(f)" /></td>
                                                <td class="text-end"><button type="button" class="btn btn-sm btn-outline-danger" title="Entfernen" @onclick="() => RemoveExternalForce(f)"><i class="bi bi-trash"></i></button></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mb-0">Noch keine externen Kr&auml;fte erfasst.</p>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label">weitere Fw / LZ</label>
                        <textarea class="form-control" rows="2" @bind="_report.WeitereFwLz"></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-6 col-md-3"><label class="form-label">Anzahl KTW</label><input type="number" min="0" class="form-control" @bind="_report.AnzahlKtw" /></div>
                        <div class="col-6 col-md-3"><label class="form-label">Anzahl RTW</label><input type="number" min="0" class="form-control" @bind="_report.AnzahlRtw" /></div>
                        <div class="col-6 col-md-3"><label class="form-label">Anzahl NA</label><input type="number" min="0" class="form-control" @bind="_report.AnzahlNa" /></div>
                        <div class="col-6 col-md-3"><label class="form-label">Anzahl RTH</label><input type="number" min="0" class="form-control" @bind="_report.AnzahlRth" /></div>
                    </div>
                    <div class="row g-1">
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.OrgLRd" /><span>OrgL RD</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.Lna" /><span>LNA</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.DrkErsthelfer" /><span>DRK Ersthelfer</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.PolizeiKripo" /><span>Polizei/Kripo</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.StadtBillerbeck" /><span>Stadt Billerbeck</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.Kbm" /><span>KBM</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.Schornsteinfeger" /><span>Schornsteinfeger</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.UntereWasserbehoerde" /><span>Untere Wasserbeh&ouml;rde</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.Veterinaer" /><span>Veterin&auml;r</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.Thw" /><span>THW</span></label></div>
                        <div class="col-6 col-md-4"><label class="rb-check"><input class="form-check-input" type="checkbox" @bind="_report.Objektbetreiber" /><span>Objektbetreiber</span></label></div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Sonst. Einheiten</label>
                        <input type="text" class="form-control" @bind="_report.SonstEinheiten" />
                    </div>
                </div>
            </div>

            @* ---------- Eingesetzte Mittel ---------- *@
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-tools me-2"></i>Eingesetzte Mittel (@_mittel.Count)</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="OpenMittelModal"><i class="bi bi-check2-square me-1"></i>Ausw&auml;hlen</button>
                </div>
                <div class="card-body">
                    @if (_mittel.Count == 0)
                    {
                        <p class="text-muted mb-0">Noch keine Mittel ausgew&auml;hlt. &Uuml;ber „Ausw&auml;hlen" &ouml;ffnest du die Liste (Ger&auml;te &amp; Material).</p>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var m in _mittel)
                            {
                                <span class="badge rounded-pill bg-primary">@m.Name@(m.Anzahl > 0 ? $" · {m.Anzahl}" : "")@(!string.IsNullOrWhiteSpace(m.Dauer) ? $" · {m.Dauer}" : "")</span>
                            }
                        </div>
                    }
                </div>
            </div>

            @* ---------- Personenschäden + Schadenshöhe ---------- *@
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-clipboard2-pulse me-2"></i>Personensch&auml;den &amp; Schadensh&ouml;he</h5></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label d-block">Menschenrettung durchgef&uuml;hrt?</label>
                        <div class="btn-group flex-wrap" role="group">
                            <input type="radio" class="btn-check" name="menschenrettung" id="mrJa" autocomplete="off"
                                   checked="@_report.HatMenschenrettung"
                                   @onchange="@(() => _report.HatMenschenrettung = true)" />
                            <label class="btn btn-outline-success" for="mrJa">Ja</label>

                            <input type="radio" class="btn-check" name="menschenrettung" id="mrNein" autocomplete="off"
                                   checked="@(!_report.HatMenschenrettung)"
                                   @onchange="@(() => _report.HatMenschenrettung = false)" />
                            <label class="btn btn-outline-secondary" for="mrNein">Nein</label>
                        </div>
                    </div>
                    @if (_report.HatMenschenrettung)
                    {
                        <div class="row g-3 mb-3">
                            <div class="col-md-6"><label class="form-label">Dauer der Menschenrettung</label><input type="text" class="form-control" placeholder="z. B. 25 min" @bind="_report.MenschenrettungDauer" /></div>
                            <div class="col-md-6"><label class="form-label">Personalaufwand</label><input type="text" class="form-control" placeholder="z. B. 8 Kräfte / Angriffstrupp" @bind="_report.MenschenrettungPersonalaufwand" /></div>
                        </div>
                    }
                    <div class="row g-3">
                        <div class="col-6 col-md-4"><label class="form-label">Anzahl Verletzte</label><input type="number" min="0" class="form-control" @bind="_report.AnzahlVerletzte" /></div>
                        <div class="col-6 col-md-4"><label class="form-label">Anzahl Tote</label><input type="number" min="0" class="form-control" @bind="_report.AnzahlTote" /></div>
                        <div class="col-6 col-md-4"><label class="form-label">Anzahl verletzte FM (SB)</label><input type="number" min="0" class="form-control" @bind="_report.AnzahlVerletzteFm" /></div>
                        <div class="col-md-6"><label class="form-label">Gesch&auml;tzter Sachschaden (&euro;)</label><input type="text" class="form-control" @bind="_report.SchadenSachschaden" /></div>
                        <div class="col-md-6"><label class="form-label">H&ouml;he der erhaltenen Werte (&euro;)</label><input type="text" class="form-control" @bind="_report.SchadenErhalteneWerte" /></div>
                    </div>
                </div>
            </div>

            @* ---------- Kräfteerfassung aus Einsatzliste (read-only) ---------- *@
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h5 class="mb-0"><i class="bi bi-person-badge me-2"></i>Eingesetzte Kr&auml;fte &middot; Eigene (@EntriesWithVehicle.Count())</h5>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="badge bg-danger" title="Führer / Mannschaft / Gesamt">St&auml;rke @_gesamtStaerke</span>
                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="OpenVehicleStrengthModal"><i class="bi bi-truck me-1"></i>St&auml;rken je Fahrzeug</button>
                    </div>
                </div>
                <div class="card-body">
                    <p class="text-muted small mb-2">Gesamtst&auml;rke (F&uuml;hrer / Mannschaft / Gesamt) aus Fahrzeug-St&auml;rken + externen Kr&auml;ften: <strong>@_gesamtStaerke</strong></p>
                    <p class="text-muted small mb-2"><i class="bi bi-info-circle me-1"></i>Diese Liste zeigt nur <strong>eigene</strong> Kr&auml;fte (mit Fahrzeug). <strong>Externe Kr&auml;fte</strong> werden oben unter „Dienststellen / Externe Kr&auml;fte" erfasst.</p>
                    @if (_vehicleStrengths.Count > 0)
                    {
                        <div class="mb-3 d-flex flex-wrap gap-2">
                            @foreach (var vs in _vehicleStrengths)
                            {
                                <span class="badge rounded-pill bg-secondary">@vs.VehicleName: @vs.Staerke</span>
                            }
                        </div>
                    }
                    @if (!EntriesWithVehicle.Any())
                    {
                        <p class="text-muted mb-0">Keine Kr&auml;fte mit Fahrzeug in der Einsatzliste erfasst.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead><tr><th>#</th><th>Name/ID</th><th>Fahrzeug</th><th>Funktionen</th><th>Atemschutz</th></tr></thead>
                                <tbody>
                                    @{ var idx = 1; }
                                    @foreach (var entry in EntriesWithVehicle)
                                    {
                                        var funcs = _functionsByEntryId.TryGetValue(entry.Id, out var fl)
                                            ? string.Join(", ", fl.Select(x => x.Name))
                                            : entry.Function.ToString();
                                        <tr>
                                            <td>@idx</td>
                                            <td>@entry.NameOrId</td>
                                            <td>@entry.Vehicle</td>
                                            <td>@funcs</td>
                                            <td>@(entry.WithBreathingApparatus ? "Ja" : "Nein")</td>
                                        </tr>
                                        idx++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @* ---------- Einsatzbilder (Nextcloud) ---------- *@
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-images me-2"></i>Einsatzbilder</h5>
                    @if (_ncConfigured)
                    {
                        @if (_ncUploadedCount > 0)
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>@_ncUploadedCount Bild(er) hochgeladen</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle me-1"></i>Noch keine Bilder</span>
                        }
                    }
                </div>
                <div class="card-body">
                    @if (!_ncConfigured)
                    {
                        <p class="text-muted mb-0">Nextcloud ist nicht konfiguriert. Ein Administrator kann die Zug&auml;nge in den Einstellungen hinterlegen.</p>
                    }
                    else
                    {
                        <p class="text-muted">Bilder werden automatisch nach <code>@_ncFolder</code> hochgeladen.</p>
                        <div class="mb-3">
                            <InputFile OnChange="OnImagesSelected" multiple accept="image/*" class="form-control" />
                        </div>
                        @if (_selectedImages.Count > 0)
                        {
                            <ul class="list-group mb-3">
                                @foreach (var f in _selectedImages)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span><i class="bi bi-image me-2"></i>@f.Name <small class="text-muted">(@FormatSize(f.Size))</small></span>
                                    </li>
                                }
                            </ul>
                            <button type="button" class="btn btn-primary" @onclick="UploadImages" disabled="@_ncUploading">
                                @if (_ncUploading)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                <i class="bi bi-cloud-arrow-up me-1"></i>@_selectedImages.Count Bild(er) hochladen
                            </button>
                        }
                        @if (!string.IsNullOrEmpty(_ncUploadMessage))
                        {
                            <div class="mt-2 @(_ncUploadError ? "text-danger" : "text-success")">
                                <i class="bi @(_ncUploadError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill") me-1"></i>@_ncUploadMessage
                            </div>
                        }
                    }
                </div>
            </div>

            @* ---------- Unterschriften ---------- *@
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-pen me-2"></i>Unterschriften</h5></div>
                <div class="card-body">
                    <p class="text-muted mb-3">Direkt hier digital unterschreiben &ndash; oder das Feld frei lassen und nach dem Ausdruck von Hand unterschreiben.</p>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label">Unterschrift IuK</label>
                            <SignaturePad @ref="_sigIuk" Initial="@_report.UnterschriftIukImage" />
                            <input type="text" class="form-control mt-2" placeholder="Name (in Druckbuchstaben)" @bind="_report.UnterschriftIuk" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Unterschrift Einsatzleiter</label>
                            <SignaturePad @ref="_sigEl" Initial="@_report.UnterschriftEinsatzleiterImage" />
                            <input type="text" class="form-control mt-2" placeholder="Name (in Druckbuchstaben)" @bind="_report.UnterschriftEinsatzleiter" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="report-savebar d-flex align-items-center gap-2 flex-wrap">
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    else
                    {
                        <i class="bi bi-check-lg me-1"></i>
                    }
                    Bericht speichern
                </button>
                <button class="btn btn-outline-secondary" @onclick="GoBack">Zur&uuml;ck zum Einsatz</button>
                @if (_showSuccess)
                {
                    <span class="text-success ms-1"><i class="bi bi-check-circle-fill me-1"></i>Gespeichert</span>
                }
                @if (_showError)
                {
                    <span class="text-danger ms-1"><i class="bi bi-exclamation-triangle-fill me-1"></i>Fehler beim Speichern</span>
                }
            </div>

            @* ---------- Modal: Eingesetzte Mittel auswählen ---------- *@
            @if (_showMittelModal)
            {
                <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
                    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-tools me-2"></i>Eingesetzte Mittel ausw&auml;hlen</h5>
                                <button type="button" class="btn-close" @onclick="CloseMittelModal"></button>
                            </div>
                            <div class="modal-body">
                                <p class="text-muted small">Schalter aktivieren, dann <strong>Anzahl</strong> und <strong>Dauer</strong> (z.&nbsp;B. „2 Std") angeben. Ganz unten k&ouml;nnen beliebig viele „Sonstiges" erg&auml;nzt werden.</p>
                                @foreach (var item in _mittelEditor)
                                {
                                    <div class="d-flex align-items-center gap-2 py-2 border-bottom">
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input" type="checkbox" id="@($"mittel_{item.Key}")" @bind="item.Active" />
                                        </div>
                                        <label class="flex-grow-1 mb-0" for="@($"mittel_{item.Key}")">@item.Name</label>
                                        <input type="number" min="0" class="form-control form-control-sm" style="width:75px" @bind="item.Anzahl" disabled="@(!item.Active)" title="Anzahl" placeholder="Anz." />
                                        <input type="text" class="form-control form-control-sm" style="width:110px" @bind="item.Dauer" disabled="@(!item.Active)" title="Dauer" placeholder="Dauer" />
                                    </div>
                                }

                                <h6 class="fw-semibold mt-3 mb-2">Sonstiges</h6>
                                @for (int i = 0; i < _customMittel.Count; i++)
                                {
                                    var idx = i;
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <input class="form-control form-control-sm" placeholder="Bezeichnung" @bind="_customMittel[idx].Name" />
                                        <input type="number" min="0" class="form-control form-control-sm" style="width:75px" @bind="_customMittel[idx].Anzahl" title="Anzahl" placeholder="Anz." />
                                        <input type="text" class="form-control form-control-sm" style="width:110px" @bind="_customMittel[idx].Dauer" title="Dauer" placeholder="Dauer" />
                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Entfernen" @onclick="() => _customMittel.RemoveAt(idx)"><i class="bi bi-trash"></i></button>
                                    </div>
                                }
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="AddCustomMittel"><i class="bi bi-plus-lg me-1"></i>Sonstiges hinzuf&uuml;gen</button>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" @onclick="CloseMittelModal">Abbrechen</button>
                                <button type="button" class="btn btn-primary" @onclick="SaveMittel"><i class="bi bi-check-lg me-1"></i>&Uuml;bernehmen</button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ---------- Modal: Stärken je Fahrzeug ---------- *@
            @if (_showVehicleStrengthModal)
            {
                <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
                    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-truck me-2"></i>St&auml;rken je Fahrzeug</h5>
                                <button type="button" class="btn-close" @onclick="CloseVehicleStrengthModal"></button>
                            </div>
                            <div class="modal-body">
                                <p class="text-muted small">Format <code>F&uuml;hrer/Mannschaft</code> (z.&nbsp;B. <code>1/8</code> = 1 GF + 8 Mannschaft). Beim Abschlie&szlig;en der Einsatzliste werden gesetzte Fahrzeuge aus den tats&auml;chlichen Eintr&auml;gen nachkorrigiert.</p>
                                @if (_vehicleStrengthEditor.Count == 0)
                                {
                                    <p class="text-muted mb-0">Keine Fahrzeuge angelegt.</p>
                                }
                                else
                                {
                                    @foreach (var item in _vehicleStrengthEditor)
                                    {
                                        <div class="d-flex align-items-center gap-3 py-2 border-bottom">
                                            <label class="flex-grow-1 mb-0 fw-semibold">@item.VehicleName</label>
                                            <input class="form-control form-control-sm" style="width:120px" placeholder="1/8" @bind="item.Staerke" />
                                        </div>
                                    }
                                }
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" @onclick="CloseVehicleStrengthModal">Abbrechen</button>
                                <button type="button" class="btn btn-primary" @onclick="SaveVehicleStrengths"><i class="bi bi-check-lg me-1"></i>&Uuml;bernehmen</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="d-flex justify-content-center py-5">
                <div class="spinner-border text-light" role="status"><span class="visually-hidden">Laden...</span></div>
            </div>
        }
    </div>
</UserAuthCheck>

@code {
    [Parameter] public int OperationListId { get; set; }

    private OperationList? _list;
    private OperationReport? _report;
    private List<OperationEntry> _entries = new();
    private Dictionary<int, List<OperationFunctionDef>> _functionsByEntryId = new();

    private bool _saving;
    private bool _showSuccess;
    private bool _showError;

    private SignaturePad? _sigIuk;
    private SignaturePad? _sigEl;

    // --- Externe Kräfte ---
    private List<OperationReportExternalForce> _externalForces = new();
    private bool _showExternalForceForm;
    private string? _newForceRufname;
    private string? _newForceStaerke;

    // --- Eingesetzte Mittel ---
    private static readonly string[] PredefinedMittel = new[]
    {
        "Lastkraftwagen bis 7,5 t",
        "Lastkraftwagen über 7,5 t",
        "Tragkraftspritze",
        "Schmutzwasserpumpe",
        "Notstromaggregat",
        "Motorsäge",
        "Industriesauger",
        "Schaumwasserwerfer",
        "Atemschutzgerät",
        "Rettungsschere einschl. Aggregat",
        "Spreizer einschl. Aggregat",
        "Be- und Entlüftungsgerät",
        "Wärmebildkamera",
        "Löschmittel (Liter)",
        "Ölbindemittel (Sack/Kanister)",
        "Mess- und Prüfröhrchen (Stück)"
    };

    private List<OperationReportMittel> _mittel = new();
    private bool _showMittelModal;

    private class MittelEditItem
    {
        public string Key { get; set; } = "";
        public string Name { get; set; } = "";
        public bool Active { get; set; }
        public int Anzahl { get; set; }
        public string? Dauer { get; set; }
    }

    private List<MittelEditItem> _mittelEditor = new();
    private List<MittelEditItem> _customMittel = new();

    // --- Eingesetzte Kräfte / Stärke ---
    private List<Vehicle> _vehicles = new();
    private List<OperationReportVehicleStrength> _vehicleStrengths = new();
    private string _gesamtStaerke = "0/0/0/0";
    private bool _showVehicleStrengthModal;
    private List<OperationReportVehicleStrength> _vehicleStrengthEditor = new();

    // --- Einsatzbilder (Nextcloud) ---
    private bool _ncConfigured;
    private bool _ncChecked;
    private string _ncFolder = string.Empty;
    private int _ncUploadedCount;
    private List<IBrowserFile> _selectedImages = new();
    private bool _ncUploading;
    private bool _ncUploadError;
    private string _ncUploadMessage = string.Empty;

    private enum Kategorie { Keine, Brand, ThAbcOel, Fehlalarm }

    private Kategorie SelectedKategorie
    {
        get => _report!.IsBrandeinsatz ? Kategorie.Brand
             : _report.IsThAbcOel ? Kategorie.ThAbcOel
             : _report.IsFehlalarm ? Kategorie.Fehlalarm
             : Kategorie.Keine;
        set
        {
            // Genau eine Kategorie darf aktiv sein
            _report!.IsBrandeinsatz = value == Kategorie.Brand;
            _report.IsThAbcOel = value == Kategorie.ThAbcOel;
            _report.IsFehlalarm = value == Kategorie.Fehlalarm;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _list = await OperationRepo.GetByIdAsync(OperationListId);
        if (_list == null) return;

        _report = await ReportRepo.GetOrCreateAsync(OperationListId);

        // Prefill Straße aus der Einsatzliste-Adresse, falls noch leer
        if (string.IsNullOrWhiteSpace(_report.Strasse) && !string.IsNullOrWhiteSpace(_list.Address))
        {
            _report.Strasse = _list.Address;
        }

        _entries = await EntryRepo.GetByListIdAsync(OperationListId);
        var entryIds = _entries.Select(e => e.Id).ToList();
        _functionsByEntryId = await EntryFunctionRepo.GetFunctionsForEntriesAsync(entryIds);

        _externalForces = await ReportRepo.GetExternalForcesAsync(_report.Id);
        _mittel = await ReportRepo.GetMittelAsync(_report.Id);

        _vehicles = (await VehicleRepo.GetActiveAsync()).Where(v => !StrengthCalc.IsNoVehicle(v.Name)).ToList();
        _vehicleStrengths = await ReportRepo.GetVehicleStrengthsAsync(_report.Id);
        RecalcGesamt();

        _ncConfigured = Nextcloud.IsConfigured;
        if (_ncConfigured && _list != null)
            _ncFolder = Nextcloud.BuildOperationFolder(_list.AlertTime.Year, _list.OperationNumber);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Bild-Anzahl in Nextcloud erst nach dem ersten Render prüfen (blockiert die Seite nicht).
        if (firstRender && _ncConfigured && !_ncChecked && _list != null)
        {
            _ncChecked = true;
            var count = await Nextcloud.CountFilesAsync(_ncFolder);
            if (count >= 0)
            {
                _ncUploadedCount = count;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    // Einträge mit echtem Fahrzeug (ohne "Ohne Fahrzeug") für die Kräfte-Tabelle
    private IEnumerable<OperationEntry> EntriesWithVehicle => _entries.Where(e => !StrengthCalc.IsNoVehicle(e.Vehicle));

    private void RecalcGesamt()
    {
        _gesamtStaerke = StrengthCalc.CombinedTotal(
            _entries, _functionsByEntryId,
            _vehicleStrengths.Select(v => (v.VehicleName, v.Staerke)),
            _externalForces.Select(e => e.Staerke));
    }

    // --- Stärken je Fahrzeug ---
    private void OpenVehicleStrengthModal()
    {
        _vehicleStrengthEditor = _vehicles.Select(v =>
        {
            var existing = _vehicleStrengths.FirstOrDefault(s => s.VehicleName == v.Name);
            return new OperationReportVehicleStrength { VehicleName = v.Name, Staerke = existing?.Staerke };
        }).ToList();
        _showVehicleStrengthModal = true;
    }

    private void CloseVehicleStrengthModal() => _showVehicleStrengthModal = false;

    private async Task SaveVehicleStrengths()
    {
        await ReportRepo.ReplaceVehicleStrengthsAsync(_report!.Id, _vehicleStrengthEditor);
        _vehicleStrengths = await ReportRepo.GetVehicleStrengthsAsync(_report.Id);
        RecalcGesamt();
        _showVehicleStrengthModal = false;
    }

    private void OnImagesSelected(InputFileChangeEventArgs e)
    {
        _selectedImages = e.GetMultipleFiles(50).ToList();
        _ncUploadMessage = string.Empty;
        _ncUploadError = false;
    }

    private async Task UploadImages()
    {
        if (_list == null || _selectedImages.Count == 0) return;
        _ncUploading = true;
        _ncUploadError = false;
        _ncUploadMessage = string.Empty;
        var ok = 0;
        var skipped = 0;
        var errors = new List<string>();
        try
        {
            // Bereits vorhandene Dateien einlesen -> Duplikate nicht erneut hochladen.
            var existing = await Nextcloud.GetExistingFileNamesAsync(_ncFolder);
            var uploadedThisBatch = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            foreach (var file in _selectedImages)
            {
                var name = SafeName(file.Name);
                if (existing.Contains(name) || uploadedThisBatch.Contains(name))
                {
                    skipped++;
                    continue;
                }
                try
                {
                    using var ms = new MemoryStream();
                    await file.OpenReadStream(20 * 1024 * 1024).CopyToAsync(ms);
                    await Nextcloud.UploadAsync(_ncFolder, name, ms.ToArray(), file.ContentType);
                    uploadedThisBatch.Add(name);
                    ok++;
                }
                catch (Exception ex)
                {
                    errors.Add($"{file.Name}: {ex.Message}");
                }
            }

            var count = await Nextcloud.CountFilesAsync(_ncFolder);
            _ncUploadedCount = count >= 0 ? count : _ncUploadedCount + ok;

            var parts = new List<string> { $"{ok} hochgeladen" };
            if (skipped > 0) parts.Add($"{skipped} übersprungen (bereits vorhanden)");
            if (errors.Count > 0) parts.Add($"{errors.Count} fehlgeschlagen");

            if (errors.Count == 0)
            {
                _ncUploadMessage = string.Join(", ", parts) + ".";
                _selectedImages = new();
            }
            else
            {
                _ncUploadError = true;
                _ncUploadMessage = string.Join(", ", parts) + ": " + string.Join("; ", errors);
            }
        }
        finally
        {
            _ncUploading = false;
        }
    }

    private static string SafeName(string name)
    {
        foreach (var c in System.IO.Path.GetInvalidFileNameChars())
            name = name.Replace(c, '_');
        return name;
    }

    private static string FormatSize(long bytes)
        => bytes < 1024 * 1024 ? $"{bytes / 1024} KB" : $"{bytes / 1024.0 / 1024.0:F1} MB";

    // --- Externe Kräfte ---
    private void ToggleExternalForceForm() => _showExternalForceForm = !_showExternalForceForm;

    private async Task AddExternalForce()
    {
        if (string.IsNullOrWhiteSpace(_newForceRufname) && string.IsNullOrWhiteSpace(_newForceStaerke))
            return;
        var force = new OperationReportExternalForce
        {
            OperationReportId = _report!.Id,
            Rufname = _newForceRufname?.Trim(),
            Staerke = _newForceStaerke?.Trim()
        };
        force.Id = await ReportRepo.InsertExternalForceAsync(force);
        _externalForces.Add(force);
        RecalcGesamt();
        // Felder für das nächste Fahrzeug leeren
        _newForceRufname = string.Empty;
        _newForceStaerke = string.Empty;
    }

    private async Task ExternalForceKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await AddExternalForce();
    }

    private async Task UpdateExternalForce(OperationReportExternalForce force)
    {
        await ReportRepo.UpdateExternalForceAsync(force);
        RecalcGesamt();
    }

    private async Task RemoveExternalForce(OperationReportExternalForce force)
    {
        await ReportRepo.DeleteExternalForceAsync(force.Id);
        _externalForces.Remove(force);
        RecalcGesamt();
    }

    // --- Eingesetzte Mittel ---
    private void OpenMittelModal()
    {
        _mittelEditor = PredefinedMittel.Select((name, i) =>
        {
            var existing = _mittel.FirstOrDefault(m => !m.IsCustom && m.Name == name);
            return new MittelEditItem
            {
                Key = i.ToString(),
                Name = name,
                Active = existing != null,
                Anzahl = existing?.Anzahl ?? 0,
                Dauer = existing?.Dauer
            };
        }).ToList();

        _customMittel = _mittel.Where(m => m.IsCustom)
            .Select(m => new MittelEditItem { Name = m.Name ?? "", Active = true, Anzahl = m.Anzahl, Dauer = m.Dauer })
            .ToList();

        _showMittelModal = true;
    }

    private void CloseMittelModal() => _showMittelModal = false;

    private void AddCustomMittel() => _customMittel.Add(new MittelEditItem { Active = true });

    private async Task SaveMittel()
    {
        var result = new List<OperationReportMittel>();
        foreach (var e in _mittelEditor.Where(e => e.Active))
            result.Add(new OperationReportMittel { Name = e.Name, Anzahl = e.Anzahl, Dauer = e.Dauer?.Trim(), IsCustom = false });
        foreach (var c in _customMittel.Where(c => !string.IsNullOrWhiteSpace(c.Name)))
            result.Add(new OperationReportMittel { Name = c.Name.Trim(), Anzahl = c.Anzahl, Dauer = c.Dauer?.Trim(), IsCustom = true });

        await ReportRepo.ReplaceMittelAsync(_report!.Id, result);
        _mittel = await ReportRepo.GetMittelAsync(_report.Id);
        _showMittelModal = false;
    }

    private async Task Save()
    {
        if (_report == null) return;
        _saving = true;
        _showSuccess = false;
        _showError = false;
        try
        {
            // Digitale Unterschriften aus den Zeichenflächen übernehmen
            if (_sigIuk != null)
                _report.UnterschriftIukImage = await _sigIuk.GetDataUrlAsync();
            if (_sigEl != null)
                _report.UnterschriftEinsatzleiterImage = await _sigEl.GetDataUrlAsync();

            await ReportRepo.UpdateAsync(_report);
            _showSuccess = true;
        }
        catch
        {
            _showError = true;
        }
        finally
        {
            _saving = false;
        }

        // Status sofort anzeigen (bei async-Handlern rendert Blazor sonst erst am Ende neu)
        StateHasChanged();

        // Erfolgsmeldung nach kurzer Zeit automatisch ausblenden
        if (_showSuccess)
        {
            await Task.Delay(3000);
            _showSuccess = false;
            StateHasChanged();
        }
    }

    private void GoBack() => Navigation.NavigateTo($"/operation/{OperationListId}");

    private async Task ExportPdf()
    {
        try
        {
            var path = $"/api/export/operation-report/{OperationListId}/pdf";
            var token = TokenService.CreateToken(path);
            var baseUri = Navigation.BaseUri.TrimEnd('/');
            var url = $"{baseUri}{path}?token={Uri.EscapeDataString(token)}";
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
        catch { }
    }
}
