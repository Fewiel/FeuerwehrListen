@using FeuerwehrListen.Models
@using Microsoft.AspNetCore.Components.Web

<div class="modal fade @(_showOverviewModal ? "show" : "")" style="@(_showOverviewModal ? "display:block; background: rgba(0,0,0,.5);" : "display:none;")" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-light border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">Eintrag bestätigen</h5>
                <button type="button" class="btn-close btn-close-white" @onclick="CloseOverviewModal"></button>
            </div>
            <div class="modal-body py-2">
                <table class="table table-borderless table-dark mb-0">
                    <tbody>
                        <tr>
                            <td class="text-muted" style="width: 140px;"><i class="bi bi-person-fill"></i> Mitglied</td>
                            <td class="text-light fw-bold">@_memberName</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="bi bi-truck"></i> Fahrzeug</td>
                            <td class="text-light fw-bold">@_vehicleName</td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="bi bi-person-check"></i> Funktionen</td>
                            <td>
                                @if (_functionNames.Any())
                                {
                                    <span class="d-flex flex-wrap gap-1">
                                        @foreach (var functionName in _functionNames)
                                        {
                                            <span class="badge bg-primary">@functionName</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">Keine</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted"><i class="bi bi-shield-check"></i> Atemschutz</td>
                            <td>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           role="switch"
                                           @bind="_withBreathingApparatus"
                                           id="breathingCheckOverview" />
                                    <label class="form-check-label text-light" for="breathingCheckOverview">
                                        Ja, unter Atemschutz
                                    </label>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-secondary" @onclick="CloseOverviewModal">Zurück</button>
                <button type="button" class="btn btn-success" @onclick="ConfirmEntry">
                    <i class="bi bi-check-circle"></i> Bestätigen
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<(string memberName, string vehicleName, List<string> functionNames, bool withBreathingApparatus)> OnEntryConfirmed { get; set; }
    [Parameter] public EventCallback OnModalClosed { get; set; }

    private bool _showOverviewModal = false;
    private string _memberName = string.Empty;
    private string _vehicleName = string.Empty;
    private List<string> _functionNames = new();
    private bool _withBreathingApparatus = false;

    public void ShowModal(string memberName, string vehicleName, List<string> functionNames, bool withBreathingApparatus)
    {
        _showOverviewModal = true;
        _memberName = memberName;
        _vehicleName = vehicleName;
        _functionNames = functionNames;
        _withBreathingApparatus = withBreathingApparatus;
        StateHasChanged();
    }

    private async Task ConfirmEntry()
    {
        await OnEntryConfirmed.InvokeAsync((_memberName, _vehicleName, _functionNames, _withBreathingApparatus));
        CloseOverviewModal();
    }

    private void CloseOverviewModal()
    {
        _showOverviewModal = false;
        OnModalClosed.InvokeAsync();
        StateHasChanged();
    }
}
